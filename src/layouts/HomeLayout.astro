---
import '../styles/v1/tokens.css';
import '../styles/v1/home.css';
import '../styles/v1/variants.css';
import CookieBanner from '../components/CookieBanner.astro';
import ClarityAnalytics from '../components/ClarityAnalytics.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import Seo from '../components/Seo.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Lorraine K. Lee', description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/images/v1/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
    <Seo title={title} description={description} />
    <GoogleAnalytics />
    <ClarityAnalytics />
  </head>
  <body>
    <slot />
    <CookieBanner />
    <ScrollToTop />
  </body>
</html>
