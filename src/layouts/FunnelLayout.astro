---
/*
 * FunnelLayout — conversion landing-page chrome.
 *
 * Per the CLI-42 nav decision, funnel/landing pages use a MINIMAL nav (logo
 * only, no menu, no competing CTAs) to reduce exit points. This layout loads
 * the same editorial design tokens as the rest of the site so the funnel is
 * visually consistent, but deliberately omits the full SiteNav, the global
 * banner, and the marketing footer links.
 */
import '../styles/editorial/tokens.css';
import '../styles/editorial/base.css';
import '../styles/editorial/templates.css';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/images/editorial/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
  </head>
  <body>
    <div class="shell">
      {/* Minimal funnel nav: logo only, links home, no menu (CLI-42). */}
      <nav class="funnel-nav">
        <div class="funnel-nav-inner">
          <a class="nav-logo" href="/" aria-label="Lorraine Lee, home">
            <img src="/images/editorial/logo-primary.png" alt="Lorraine Lee" />
          </a>
        </div>
      </nav>

      <main>
        <slot />
      </main>

      <footer class="funnel-footer">
        <div class="grid12">
          <div class="funnel-footer-inner">
            <div class="funnel-footer-copy">
              &copy; {year} Lorraine Lee &middot; RISE Learning Solutions Corp.
            </div>
            <div class="funnel-footer-links">
              <a href="/privacy-policy">Privacy Policy</a>
              <a href="/terms-privacy-legal">Terms &amp; Conditions</a>
            </div>
          </div>
        </div>
      </footer>
    </div>
    <CookieBanner />

    <style>
      /* Minimal funnel chrome — logo-only nav + lean footer. */
      .funnel-nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(251, 248, 242, 0.85);
        backdrop-filter: saturate(160%) blur(14px);
        -webkit-backdrop-filter: saturate(160%) blur(14px);
        border-bottom: 1px solid var(--border-soft);
      }
      .funnel-nav-inner {
        width: 100%;
        max-width: var(--grid-max);
        margin: 0 auto;
        padding: 16px var(--grid-pad);
        display: flex;
        align-items: center;
        justify-content: center;
        height: 64px;
      }
      .funnel-nav .nav-logo img {
        height: 30px;
        display: block;
      }

      .funnel-footer {
        background: var(--paper-deep);
        padding: 40px 0;
        margin-top: clamp(40px, 6vw, 80px);
      }
      .funnel-footer-inner {
        grid-column: 1 / -1;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
        font-family: var(--font-sans);
        font-size: 12px;
        color: var(--fg-muted);
      }
      .funnel-footer-links {
        display: flex;
        gap: 24px;
      }
      .funnel-footer-links a {
        color: var(--fg-muted);
        text-decoration: none;
        transition: color 200ms var(--ease-out);
      }
      .funnel-footer-links a:hover {
        color: var(--accent);
      }
    </style>

    <script>
      // Lightweight scroll-reveal (mirrors the editorial layout) so funnel
      // sections fade in. No external dependencies / islands.
      const reduceMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches;

      document
        .querySelectorAll<HTMLElement>('.reveal-stagger')
        .forEach((parent) => {
          Array.from(parent.children).forEach((child, i) => {
            const el = child as HTMLElement;
            el.classList.add('reveal');
            if (!el.style.transitionDelay) {
              el.style.transitionDelay = i * 70 + 'ms';
            }
          });
        });

      const revealEls = document.querySelectorAll<HTMLElement>('.reveal');
      if (reduceMotion || !('IntersectionObserver' in window)) {
        revealEls.forEach((el) => el.classList.add('is-in'));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              entry.target.classList.add('is-in');
              observer.unobserve(entry.target);
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        revealEls.forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
