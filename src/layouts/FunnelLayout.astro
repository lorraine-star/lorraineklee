---
/*
 * FunnelLayout — conversion landing-page chrome.
 *
 * Uses the full site nav for consistency with the rest of the site, plus a
 * lean footer. Loads the same editorial design tokens so the funnel matches
 * the design system. The reveal script below is hardened so funnel content can
 * never stay hidden if its scroll-reveal JS fails to run (see fc-js below).
 */
import '../styles/editorial/tokens.css';
import '../styles/editorial/base.css';
import '../styles/editorial/templates.css';
import EditorialNav from '../components/editorial/EditorialNav.astro';
import CookieBanner from '../components/CookieBanner.astro';
import ClarityAnalytics from '../components/ClarityAnalytics.astro';
import ScrollToTop from '../components/ScrollToTop.astro';

interface Props {
  title: string;
  description?: string;
  activeId?: string;
}

const { title, description, activeId = 'learn' } = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/images/editorial/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700&family=Inter:wght@400;500;600;700;800&family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,500;1,600&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
    <ClarityAnalytics />
  </head>
  <body>
    <div class="shell">
      <EditorialNav activeId={activeId} />

      <main>
        <slot />
      </main>

      <footer class="funnel-footer">
        <div class="grid12">
          <div class="funnel-footer-inner">
            <div class="funnel-footer-copy">
              &copy; {year} Lorraine Lee &middot; RISE Learning Solutions Corp.
            </div>
            <div class="funnel-footer-links">
              <a href="/privacy-policy">Privacy Policy</a>
              <a href="/terms-privacy-legal">Terms &amp; Conditions</a>
            </div>
          </div>
        </div>
      </footer>
    </div>
    <CookieBanner />
    <ScrollToTop />

    <style>
      /* Lean funnel footer. */
      .funnel-footer {
        background: var(--paper-deep);
        padding: 40px 0;
        margin-top: clamp(40px, 6vw, 80px);
      }
      .funnel-footer-inner {
        grid-column: 1 / -1;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
        font-family: var(--font-sans);
        font-size: 12px;
        color: var(--fg-muted);
      }
      .funnel-footer-links {
        display: flex;
        gap: 24px;
      }
      .funnel-footer-links a {
        color: var(--fg-muted);
        text-decoration: none;
        transition: color 200ms var(--ease-out);
      }
      .funnel-footer-links a:hover {
        color: var(--accent);
      }

      /* Scroll-reveal fallback: the shared .reveal rule (templates.css) hides
         content at opacity:0 until the reveal script adds .is-in. If that
         script never runs, `html.fc-js` is never set, so this higher-specificity
         override keeps every reveal block fully visible. When JS does run, the
         observer animates them in normally. */
      :global(html:not(.fc-js) .reveal) {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
    </style>

    <script>
      import { initReveals } from '../scripts/reveals';

      // Mark JS as live FIRST. The funnel page only hides reveal content while
      // `html.fc-js` is present, so if this script never runs the content is
      // shown by default rather than stuck invisible.
      document.documentElement.classList.add('fc-js');

      // Shared scroll-reveal (same module as the editorial layout) so funnel
      // sections fade in. `forceRevealAfter` keeps the funnel's hard guarantee
      // that content can never stay hidden in embedded/in-app renderers.
      initReveals({ staggerStep: 70, forceRevealAfter: 2500 });
    </script>
  </body>
</html>
