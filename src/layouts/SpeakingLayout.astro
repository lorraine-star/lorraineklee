---
import '../styles/editorial/tokens.css';
import '../styles/editorial/base.css';
import '../styles/editorial/templates.css';
import Banner from '../components/editorial/Banner.astro';
import EditorialNav from '../components/editorial/EditorialNav.astro';
import EditorialFooter from '../components/editorial/EditorialFooter.astro';
import CookieBanner from '../components/CookieBanner.astro';
import ScrollToTop from '../components/ScrollToTop.astro';

interface Props {
  title: string;
  description?: string;
  activeId?: string;
}

const { title, description, activeId = 'home' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/images/editorial/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
  </head>
  <body>
    <div class="shell">
      <Banner />
      <EditorialNav activeId={activeId} />
      <main>
        <slot />
      </main>
      <EditorialFooter />
    </div>
    <CookieBanner />
    <ScrollToTop />

    <script>
      // The staggered "waterfall" reveal lives in a shared module so it stays
      // identical across the editorial layouts (see scripts/reveals.ts).
      import { initReveals } from '../scripts/reveals';

      // --- Dismissible banner ---
      const banner = document.getElementById('site-banner');
      document
        .querySelector('[data-banner-dismiss]')
        ?.addEventListener('click', () => banner?.setAttribute('hidden', ''));

      const reduceMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches;

      // --- Animated count-up numbers ---
      function animateCount(el: HTMLElement) {
        const to = parseFloat(el.dataset.to || '0');
        const decimals = parseInt(el.dataset.decimals || '0', 10);
        const duration = parseInt(el.dataset.duration || '1400', 10);
        const format = (v: number) =>
          decimals > 0 ? v.toFixed(decimals) : Math.round(v).toLocaleString();
        if (reduceMotion) {
          el.textContent = format(to);
          return;
        }
        const start = performance.now();
        const tick = (now: number) => {
          const t = Math.min(1, (now - start) / duration);
          const eased = 1 - Math.pow(1 - t, 3);
          el.textContent = format(eased * to);
          if (t < 1) requestAnimationFrame(tick);
          else el.textContent = format(to);
        };
        requestAnimationFrame(tick);
      }

      function setupCounts() {
        const counts = document.querySelectorAll<HTMLElement>('.count-up');
        if (!('IntersectionObserver' in window)) {
          counts.forEach(animateCount);
          return;
        }
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              animateCount(entry.target as HTMLElement);
              observer.unobserve(entry.target);
            }
          },
          { threshold: 0.4 }
        );
        counts.forEach((el) => {
          el.textContent = parseInt(el.dataset.decimals || '0', 10) > 0 ? '0.0' : '0';
          observer.observe(el);
        });
      }

      // --- Smooth in-page anchors ---
      function setupAnchors() {
        document.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          const a = target.closest?.('a[href^="#"]') as HTMLAnchorElement | null;
          if (!a) return;
          const id = a.getAttribute('href')!.slice(1);
          if (!id) return;
          const dest = document.getElementById(id);
          if (!dest) return;
          e.preventDefault();
          dest.scrollIntoView({ behavior: 'smooth', block: 'start' });
          dest.classList.remove('anchor-pulse');
          void dest.offsetWidth;
          dest.classList.add('anchor-pulse');
          setTimeout(() => dest.classList.remove('anchor-pulse'), 1400);
        });
      }

      // --- Disclosure accordions ("See all other talks" + keynote/other-talk
      // cards). Cards can be nested inside the "See all other talks" panel, so
      // opening an inner card must re-measure ancestor panels to avoid clipping.
      function setupAccordions() {
        const ACC_SEL = '.topic-acc, .other-talks-acc';
        const PANEL_SEL = ':scope > .topic-panel, :scope > .other-talks-panel';

        const panelOf = (acc: HTMLElement) =>
          acc.querySelector<HTMLElement>(PANEL_SEL);

        // Measure an accordion's natural panel height with the panel (and any
        // open descendant panels) temporarily uncapped, so transitions in
        // flight don't corrupt the reading.
        const measureAcc = (acc: HTMLElement) => {
          const panel = panelOf(acc);
          if (!panel) return;
          const touched: Array<[HTMLElement, string]> = [];
          const uncap = (p: HTMLElement) => {
            touched.push([p, p.style.maxHeight]);
            p.style.maxHeight = 'none';
          };
          uncap(panel);
          panel
            .querySelectorAll<HTMLElement>('.topic-panel, .other-talks-panel')
            .forEach((dp) => {
              const dacc = dp.closest<HTMLElement>(ACC_SEL);
              if (dacc && dacc.dataset.open === 'true') uncap(dp);
            });
          const h = panel.scrollHeight;
          touched.forEach(([p, prev]) => {
            p.style.maxHeight = prev;
          });
          acc.style.setProperty('--panel-h', h + 'px');
        };

        const allAccs = Array.from(
          document.querySelectorAll<HTMLElement>(ACC_SEL)
        );
        allAccs.forEach(measureAcc);
        window.addEventListener(
          'resize',
          () => allAccs.forEach(measureAcc),
          { passive: true }
        );

        const groups = [
          { acc: '.other-talks-acc', trigger: ':scope > .other-talks-trigger' },
          { acc: '.topic-acc', trigger: ':scope > .topic-acc-trigger' },
        ];

        for (const group of groups) {
          document
            .querySelectorAll<HTMLElement>(group.acc)
            .forEach((acc) => {
              const trigger = acc.querySelector<HTMLElement>(group.trigger);
              const panel = panelOf(acc);
              if (!trigger || !panel) return;

              const toggle = () => {
                const isOpen = acc.dataset.open === 'true';
                acc.dataset.open = isOpen ? 'false' : 'true';
                trigger.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
                panel.setAttribute('aria-hidden', isOpen ? 'true' : 'false');
                // Re-measure this accordion and every ancestor accordion.
                let node: HTMLElement | null = acc;
                while (node) {
                  measureAcc(node);
                  node = node.parentElement?.closest<HTMLElement>(ACC_SEL) ?? null;
                }
              };

              trigger.addEventListener('click', toggle);
              // Triggers that aren't native <button>s (e.g. div[role="button"]
              // cards) need explicit keyboard activation.
              if (trigger.tagName !== 'BUTTON') {
                trigger.addEventListener('keydown', (e) => {
                  if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    toggle();
                  }
                });
              }
            });
        }
      }

      initReveals();
      setupCounts();
      setupAnchors();
      setupAccordions();
    </script>
  </body>
</html>
