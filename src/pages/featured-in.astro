---
import SpeakingLayout from '../layouts/SpeakingLayout.astro';
import TrustAsSeenIn from '../components/TrustAsSeenIn.astro';
import { reader } from '../lib/keystatic';
import { safeUrl } from '../lib/url';

const page = await reader.singletons.featuredIn.read();
if (!page) {
	throw new Error('Missing Featured In content (src/content/featured-in/index.yaml)');
}
const { hero, highlights_section, appearances_section, final_cta } = page;

const isExternal = (url: string) => /^https?:\/\//i.test(url);

// safeUrl() collapses unsafe/invalid URLs (e.g. javascript:) to '#'. Treat that
// sentinel as "no link" so cards render without a dead CTA and CTA-URL fallbacks
// still kick in, rather than linking to '#'.
const cleanUrl = (value: string | null | undefined) => {
	const url = safeUrl(value);
	return url === '#' ? '' : url;
};

// Default CTA label per appearance type. Editors can override via cta_label.
const CTA_DEFAULTS: Record<string, string> = {
	Article: 'Read more',
	Newsletter: 'Read more',
	Award: 'Read more',
	Podcast: 'Listen',
	Video: 'Watch',
	Interview: 'Watch',
	Book: 'Learn more',
	Report: 'Read the report',
	Resource: 'View resource',
	Event: 'Learn more',
};

const all = (await reader.collections.featuredAppearances.all())
	.map((a) => {
		const href = cleanUrl(a.entry.url);
		return {
			slug: a.slug,
			...a.entry,
			href,
			ctaLabel:
				a.entry.cta_label ||
				CTA_DEFAULTS[a.entry.appearance_type] ||
				'Read more',
		};
	})
	.sort((x, y) => (x.priority ?? 100) - (y.priority ?? 100));

const highlights = all.filter((a) => a.featured);
const appearances = all.filter((a) => !a.featured);

// Build appearance type counts for filter pills
const appearanceTypes = Array.from(
	new Set(appearances.map((a) => a.appearance_type))
).sort();
const counts: Record<string, number> = { all: appearances.length };
for (const type of appearanceTypes) {
	counts[type] = appearances.filter((a) => a.appearance_type === type).length;
}

const heroPrimaryUrl = cleanUrl(hero.primary_cta_url) || '/speaking';
const heroSecondaryUrl = cleanUrl(hero.secondary_cta_url) || '#appearances';
const finalCtaUrl = cleanUrl(final_cta.cta_url) || '/contact';
---

<SpeakingLayout
	title="Featured In | Lorraine K. Lee"
	description={hero.lead}
	activeId="thought-leadership"
>
	{/* ---------- Hero ---------- */}
	<section class="page-hero page-hero--center section--cream">
		<div class="grid12 page-hero-grid">
			<div class="page-hero-copy fade-up">
				<div class="page-hero-eyebrow">
					<span class="dot"></span>
					<span class="eyebrow" style="color: var(--ink-500);">{hero.eyebrow}</span>
				</div>
				<h1>{hero.headline} <em>{hero.headline_accent}</em></h1>
				<p class="lead-large">{hero.lead}</p>
				<div class="hero-cta-row">
					<a
						class="btn primary large"
						href={heroPrimaryUrl}
						target={isExternal(heroPrimaryUrl) ? '_blank' : undefined}
						rel={isExternal(heroPrimaryUrl) ? 'noopener noreferrer' : undefined}
					>
						{hero.primary_cta_label} <span aria-hidden="true">&rarr;</span>
					</a>
					{
						hero.secondary_cta_label && (
							<a class="anchor-link" href={heroSecondaryUrl}>
								{hero.secondary_cta_label}{' '}
								<span class="arrow" aria-hidden="true">&rarr;</span>
							</a>
						)
					}
				</div>
			</div>
		</div>
	</section>

	{/* ---------- Logo wall (global "As Seen In") ---------- */}
	<TrustAsSeenIn />

	{/* ---------- Highlights (featured cards) ---------- */}
	{
		highlights.length > 0 && (
			<section class="section section--compact">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{highlights_section.eyebrow}</span>
						<h2>
							{highlights_section.heading}{' '}
							<em>{highlights_section.heading_accent}</em>
						</h2>
						{highlights_section.lead && (
							<p class="lead">{highlights_section.lead}</p>
						)}
					</div>
					<div class="fi-highlights reveal-stagger">
						{highlights.map((a) => {
							const Tag = a.href ? 'a' : 'div';
							return (
								<Tag
									class="fi-highlight"
									id={a.slug}
									href={a.href || undefined}
									target={a.href && isExternal(a.href) ? '_blank' : undefined}
									rel={
										a.href && isExternal(a.href)
											? 'noopener noreferrer'
											: undefined
									}
								>
									<div class="fi-card-top">
										{a.logo ? (
											<img
												class="fi-logo"
												src={a.logo}
												alt={a.source_name}
												loading="lazy"
											/>
										) : (
											<span class="fi-source">{a.source_name}</span>
										)}
										<span class={`fi-chip fi-chip--${a.appearance_type.toLowerCase()}`}>
											{a.appearance_type}
										</span>
									</div>
									<h3 class="fi-h-title">{a.title}</h3>
									{a.description && <p class="fi-desc">{a.description}</p>}
									<div class="fi-foot">
										{a.date && <span class="fi-date">{a.date}</span>}
										{a.href && (
											<span class="fi-cta">
												{a.ctaLabel} <span aria-hidden="true">&#8599;</span>
											</span>
										)}
									</div>
								</Tag>
							);
						})}
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Appearances filter and grid ---------- */}
	<section class="section section--compact anchor-target" id="appearances">
		<div class="grid12">
			<div class="section-head section-head--center">
				<span class="eyebrow">{appearances_section.eyebrow}</span>
				<h2>
					{appearances_section.heading}{' '}
					<em>{appearances_section.heading_accent}</em>
				</h2>
				{appearances_section.lead && (
					<p class="lead">{appearances_section.lead}</p>
				)}
			</div>

			{/* Filter pills */}
			<div class="fi-filter-pills" role="tablist" aria-label="Appearance types">
				<button
					type="button"
					class="fi-filter-pill is-active"
					data-filter="all"
					role="tab"
					aria-selected="true"
				>
					All appearances
					<span class="fi-filter-pill-count">{counts.all}</span>
				</button>
				{
					appearanceTypes.map((type) => (
						<button
							type="button"
							class="fi-filter-pill"
							data-filter={type}
							role="tab"
							aria-selected="false"
						>
							{type}
							<span class="fi-filter-pill-count">{counts[type]}</span>
						</button>
					))
				}
			</div>

			{/* Grid */}
			<div class="fi-grid reveal-stagger" data-appearance-grid>
				{appearances.map((a) => {
					const Tag = a.href ? 'a' : 'div';
					return (
						<Tag
							class={`fi-card${a.href ? '' : ' fi-card--static'}`}
							id={a.slug}
							data-appearance-type={a.appearance_type}
							href={a.href || undefined}
							target={a.href && isExternal(a.href) ? '_blank' : undefined}
							rel={
								a.href && isExternal(a.href) ? 'noopener noreferrer' : undefined
							}
						>
							<div class="fi-card-top">
								{a.logo ? (
									<img
										class="fi-logo"
										src={a.logo}
										alt={a.source_name}
										loading="lazy"
									/>
								) : (
									<span class="fi-source">{a.source_name}</span>
								)}
								<span class={`fi-chip fi-chip--${a.appearance_type.toLowerCase()}`}>
									{a.appearance_type}
								</span>
							</div>
							<h3 class="fi-title">{a.title}</h3>
							{a.description && <p class="fi-desc">{a.description}</p>}
							<div class="fi-foot">
								{a.date && <span class="fi-date">{a.date}</span>}
								{a.href && (
									<span class="fi-cta">
										{a.ctaLabel} <span aria-hidden="true">&#8599;</span>
									</span>
								)}
							</div>
						</Tag>
					);
				})}
			</div>

			{/* Empty state */}
			<div class="fi-grid-empty" data-grid-empty hidden>
				<p>No appearances in this category yet.</p>
			</div>
		</div>
	</section>

	{/* ---------- Final CTA ---------- */}
	<section class="section">
		<div class="grid12">
			<div class="final-cta reveal">
				<div class="final-cta-inner">
					<span class="eyebrow">{final_cta.eyebrow}</span>
					<h2>
						{final_cta.heading} <em>{final_cta.heading_accent}</em>
					</h2>
					<p>{final_cta.body}</p>
					<div class="hero-cta-row" style="justify-content: center;">
						<a class="btn yellow large" href={finalCtaUrl}>
							{final_cta.cta_label} <span aria-hidden="true">&rarr;</span>
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>
</SpeakingLayout>

<style>
	/* ================================================================
	   Featured In — press / credibility cards.
	   Primitives (page-hero, section--*, section-head, eyebrow,
	   final-cta, btn) come from styles/editorial/.
	   ================================================================ */

	/* ---- Hero CTA row (centered hero — scoped so the final-CTA row is untouched) ---- */
	.page-hero-copy .hero-cta-row {
		justify-content: center;
		gap: 18px;
		margin-top: 32px;
	}

	/* ---- Shared card chrome ---- */
	.fi-card-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 16px;
	}
	.fi-logo {
		max-height: 26px;
		max-width: 130px;
		width: auto;
		height: auto;
		object-fit: contain;
		opacity: 0.85;
		filter: grayscale(1);
		transition: opacity 240ms var(--ease-out), filter 240ms var(--ease-out);
	}
	.fi-card:hover .fi-logo,
	.fi-highlight:hover .fi-logo {
		opacity: 1;
		filter: none;
	}
	.fi-source {
		font-family: var(--font-sans);
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
	}
	.fi-chip {
		flex: 0 0 auto;
		font-family: var(--font-sans);
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-500);
		background: var(--paper-deep);
		border: 1px solid var(--border-soft);
		border-radius: 999px;
		padding: 4px 11px;
	}
	.fi-chip--award {
		color: var(--accent);
		background: var(--brand-blue-50, rgba(43, 70, 200, 0.08));
		border-color: transparent;
	}
	.fi-chip--podcast,
	.fi-chip--video,
	.fi-chip--interview {
		color: var(--ink-700);
		background: rgba(245, 178, 41, 0.16);
		border-color: transparent;
	}

	.fi-desc {
		margin: 0;
		font-family: var(--font-sans);
		font-size: 14px;
		line-height: 1.55;
		color: var(--ink-500);
	}
	.fi-foot {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin-top: auto;
		padding-top: 16px;
	}
	.fi-date {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--ink-300);
	}
	.fi-cta {
		margin-left: auto;
		font-family: var(--font-sans);
		font-size: 13px;
		font-weight: 700;
		color: var(--accent);
		white-space: nowrap;
	}
	.fi-cta span {
		display: inline-block;
		transition: transform 200ms var(--ease-out);
	}
	.fi-card:hover .fi-cta span,
	.fi-highlight:hover .fi-cta span {
		transform: translate(2px, -2px);
	}

	/* ---- Highlights (featured) ---- */
	.fi-highlights {
		grid-column: 1 / -1;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
	}
	.fi-highlight {
		display: flex;
		flex-direction: column;
		padding: 26px 26px 24px;
		background: var(--white);
		border: 1px solid var(--border-soft);
		border-top: 3px solid var(--accent);
		border-radius: 16px;
		text-decoration: none;
		color: inherit;
		transition: transform 260ms var(--ease-out), box-shadow 260ms var(--ease-out);
	}
	a.fi-highlight:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-lg);
	}
	.fi-h-title {
		margin: 0 0 12px;
		font-family: var(--font-serif);
		font-weight: 500;
		font-size: 22px;
		line-height: 1.25;
		color: var(--ink-900);
	}

	/* ---- Filter pills (mirrors the courses/learn category filter) ---- */
	.fi-filter-pills {
		grid-column: 1 / -1;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 10px;
		margin: 4px 0 28px;
	}
	.fi-filter-pill {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		min-height: 40px;
		padding: 9px 18px;
		background: #fff;
		border: 1px solid var(--border-soft);
		border-radius: 999px;
		font-family: var(--font-sans);
		font-size: 13px;
		font-weight: 600;
		color: var(--ink-700);
		cursor: pointer;
		transition: color 160ms var(--ease-out), background 160ms var(--ease-out),
			border-color 160ms var(--ease-out);
	}
	.fi-filter-pill:hover {
		color: var(--accent);
		border-color: var(--accent);
	}
	.fi-filter-pill.is-active {
		color: #fff;
		background: var(--ink-900);
		border-color: var(--ink-900);
	}
	.fi-filter-pill:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}
	.fi-filter-pill-count {
		font-size: 11px;
		font-weight: 700;
		opacity: 0.7;
		font-variant-numeric: tabular-nums;
	}

	/* ---- Main grid ---- */
	.fi-grid {
		grid-column: 1 / -1;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px;
	}
	.fi-card {
		display: flex;
		flex-direction: column;
		padding: 22px 22px 20px;
		background: var(--white);
		border: 1px solid var(--border-soft);
		border-radius: 14px;
		text-decoration: none;
		color: inherit;
		transition: transform 240ms var(--ease-out), box-shadow 240ms var(--ease-out),
			border-color 240ms var(--ease-out);
	}
	a.fi-card:hover {
		transform: translateY(-3px);
		border-color: var(--ink-200);
		box-shadow: var(--shadow-md);
	}
	.fi-card--static {
		background: transparent;
	}
	.fi-card[hidden] {
		display: none !important;
	}
	.fi-title {
		margin: 0 0 10px;
		font-family: var(--font-serif);
		font-weight: 500;
		font-size: 18px;
		line-height: 1.3;
		color: var(--ink-900);
	}

	/* ---- Empty state ---- */
	.fi-grid-empty {
		grid-column: 1 / -1;
		padding: 48px 24px;
		text-align: center;
		background: var(--paper-light);
		border-radius: 12px;
	}
	.fi-grid-empty p {
		margin: 0;
		font-family: var(--font-sans);
		font-size: 16px;
		color: var(--ink-500);
	}

	/* ---- Responsive ---- */
	@media (max-width: 980px) {
		.fi-highlights,
		.fi-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 600px) {
		.fi-highlights,
		.fi-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	// Lightweight appearance-type filter (vanilla DOM).
	// Filters the grid by data-appearance-type and keeps count + empty state in sync.
	function setupAppearanceFilter() {
		const bar = document.querySelector<HTMLElement>('.fi-filter-pills');
		const grid = document.querySelector<HTMLElement>('[data-appearance-grid]');
		const empty = document.querySelector<HTMLElement>('[data-grid-empty]');
		if (!bar || !grid) return;

		const pills = Array.from(
			bar.querySelectorAll<HTMLButtonElement>('.fi-filter-pill')
		);
		const cards = Array.from(
			grid.querySelectorAll<HTMLElement>('.fi-card')
		);

		const apply = (filter: string) => {
			let shown = 0;
			for (const card of cards) {
				const match = filter === 'all' || card.dataset.appearanceType === filter;
				card.hidden = !match;
				if (match) shown++;
			}
			if (empty) empty.hidden = shown !== 0;
		};

		bar.addEventListener('click', (e) => {
			const pill = (e.target as HTMLElement).closest<HTMLButtonElement>(
				'.fi-filter-pill'
			);
			if (!pill) return;
			for (const p of pills) {
				const active = p === pill;
				p.classList.toggle('is-active', active);
				p.setAttribute('aria-selected', active ? 'true' : 'false');
			}
			apply(pill.dataset.filter || 'all');
		});
	}

	setupAppearanceFilter();
</script>
