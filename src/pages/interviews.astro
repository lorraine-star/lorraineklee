---
import SpeakingLayout from '../layouts/SpeakingLayout.astro';
import { reader } from '../lib/keystatic';
import { safeUrl } from '../lib/url';

const page = await reader.singletons.interviewsPage.read();
if (!page) {
	throw new Error(
		'Missing interviews page content (src/content/interviews-page/index.yaml)'
	);
}
const { hero, featured_section, guest_section, guest_appearances, final_cta } =
	page;

const interviews = (await reader.collections.interviews.all())
	.map((i) => ({ slug: i.slug, ...i.entry }))
	.sort((a, b) => (a.order ?? 0) - (b.order ?? 0));

const heroCtaUrl = safeUrl(hero.cta_url) || '/learn#course';
const finalCtaUrl = safeUrl(final_cta.cta_url) || '/learn#course';
const isExternal = (url: string) => /^https?:\/\//i.test(url);

const embedUrl = (id: string) => `https://www.youtube.com/embed/${id}`;
const watchUrl = (id: string) => `https://www.youtube.com/watch?v=${id}`;
const thumbUrl = (id: string) => `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;

// Guest appearances: keep only items that resolve to a real link.
const guests = (guest_appearances ?? [])
	.map((g) => {
		const id = (g.youtube_id ?? '').trim();
		const href = id ? watchUrl(id) : safeUrl(g.url);
		return { ...g, id, href };
	})
	.filter((g) => g.href);
---

<SpeakingLayout
	title="Guest Interviews | Lorraine K. Lee"
	description={hero.lead}
	activeId="thought-leadership"
>
	{/* ---------- Hero ---------- */}
	<section class="page-hero page-hero--center">
		<div class="grid12 page-hero-grid">
			<div class="page-hero-copy fade-up">
				<div class="page-hero-eyebrow">
					<span class="dot"></span>
					<span class="eyebrow" style="color: var(--ink-500);">{hero.eyebrow}</span>
				</div>
				<h1>{hero.headline} <em>{hero.headline_accent}</em></h1>
				<p class="lead-large">{hero.lead}</p>
				{
					hero.cta_label && (
						<div class="hero-cta-row">
							<a
								class="btn primary large"
								href={heroCtaUrl}
								target={isExternal(heroCtaUrl) ? '_blank' : undefined}
								rel={isExternal(heroCtaUrl) ? 'noopener noreferrer' : undefined}
							>
								{hero.cta_label} <span aria-hidden="true">&rarr;</span>
							</a>
							<a class="anchor-link" href="#guest-interviews">
								Browse interviews{' '}
								<span class="arrow" aria-hidden="true">&rarr;</span>
							</a>
						</div>
					)
				}
			</div>
		</div>
	</section>

	{/* ---------- Featured interviews (CMS collection) ---------- */}
	{
		interviews.length > 0 && (
			<section class="section section--compact anchor-target" id="featured-interviews">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{featured_section.eyebrow}</span>
						<h2>
							{featured_section.heading}{' '}
							<em>{featured_section.heading_accent}</em>
						</h2>
						{featured_section.lead && <p class="lead">{featured_section.lead}</p>}
					</div>
					<div class="moderation-grid reveal-stagger">
						{interviews.map((it) => {
							const link = it.video_url ? safeUrl(it.video_url) : '';
							return (
								<div class="moderation-card" id={it.slug}>
									<div class="clip-frame">
										{it.youtube_id ? (
											<iframe
												src={embedUrl(it.youtube_id)}
												title={it.title}
												allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
												allowfullscreen
												loading="lazy"
											/>
										) : link ? (
											<a
												class="clip-link"
												href={link}
												target="_blank"
												rel="noopener noreferrer"
												aria-label={`Watch: ${it.title}`}
											>
												<span class="play-ring" aria-hidden="true">&#9654;</span>
												<span class="note">Watch the interview &#8599;</span>
											</a>
										) : (
											<div class="reel-placeholder">
												<div class="play-ring" aria-hidden="true">&#9654;</div>
												<div class="note">Video coming soon</div>
											</div>
										)}
									</div>
									<div class="clip-body">
										{it.guest && <span class="clip-guest">{it.guest}</span>}
										<h3>{it.title}</h3>
										{it.description && <p>{it.description}</p>}
									</div>
								</div>
							);
						})}
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Guest appearances (Lorraine as guest) ---------- */}
	{
		guests.length > 0 && (
			<section class="section section--compact section--cream anchor-target" id="guest-interviews">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{guest_section.eyebrow}</span>
						<h2>
							{guest_section.heading} <em>{guest_section.heading_accent}</em>
						</h2>
						{guest_section.lead && <p class="lead">{guest_section.lead}</p>}
					</div>
					<div class="interview-cards reveal-stagger">
						{guests.map((g) => (
							<a
								class="interview-card"
								href={g.href}
								target="_blank"
								rel="noopener noreferrer"
							>
								<div class="interview-thumb">
									{g.id ? (
										<img
											src={thumbUrl(g.id)}
											alt=""
											loading="lazy"
											width="480"
											height="360"
										/>
									) : (
										<div class="interview-thumb-deco" aria-hidden="true" />
									)}
									<span class="play" aria-hidden="true">
										<svg viewBox="0 0 24 24" fill="currentColor">
											<path d="M8 5v14l11-7z" />
										</svg>
									</span>
								</div>
								<div class="interview-card-body">
									{g.show && <span class="interview-show">{g.show}</span>}
									<h3>{g.title}</h3>
									<span class="interview-link">
										Watch it here <span aria-hidden="true">&#8599;</span>
									</span>
								</div>
							</a>
						))}
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Final CTA ---------- */}
	<section class="section">
		<div class="grid12">
			<div class="final-cta">
				<div class="final-cta-inner">
					<span class="eyebrow">{final_cta.eyebrow}</span>
					<h2>
						{final_cta.heading} <em>{final_cta.heading_accent}</em>
					</h2>
					<p>{final_cta.body}</p>
					<a class="btn yellow large" href={finalCtaUrl}>
						{final_cta.cta_label} <span aria-hidden="true">&rarr;</span>
					</a>
				</div>
			</div>
		</div>
	</section>
</SpeakingLayout>

<style>
	/* Guest / interviewer label above the title in featured cards. */
	.clip-guest {
		display: inline-block;
		font-family: var(--font-sans);
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 8px;
	}
	/* Link-style placeholder for a featured interview hosted off YouTube. */
	.clip-frame .clip-link {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 12px;
		color: #fff;
		text-decoration: none;
		background: var(--ink-900);
		transition: background 0.25s ease;
	}
	.clip-frame .clip-link:hover {
		background: #11183a;
	}
	.clip-frame .clip-link .play-ring {
		display: grid;
		place-items: center;
		width: 56px;
		height: 56px;
		border-radius: 50%;
		border: 2px solid rgba(255, 255, 255, 0.7);
		font-size: 18px;
		padding-left: 4px;
	}
	.clip-frame .clip-link .note {
		font-family: var(--font-sans);
		font-size: 13px;
		font-weight: 600;
		letter-spacing: 0.02em;
	}

	/* Guest-appearance cards: lightweight thumbnail links (no embedded iframes). */
	.interview-cards {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}
	.interview-card {
		display: flex;
		flex-direction: column;
		background: #fff;
		border: 1px solid var(--border-soft);
		border-radius: 16px;
		overflow: hidden;
		text-decoration: none;
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}
	.interview-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 26px 56px -40px rgba(14, 21, 48, 0.5);
	}
	.interview-thumb {
		position: relative;
		aspect-ratio: 16 / 9;
		background: var(--ink-900);
		overflow: hidden;
	}
	.interview-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.interview-thumb-deco {
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, var(--ink-900), #2a3566);
	}
	.interview-thumb .play {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		display: grid;
		place-items: center;
		width: 52px;
		height: 52px;
		border-radius: 50%;
		background: rgba(14, 21, 48, 0.72);
		color: #fff;
		transition: background 0.25s ease, transform 0.25s ease;
	}
	.interview-thumb .play svg {
		width: 22px;
		height: 22px;
		margin-left: 2px;
	}
	.interview-card:hover .interview-thumb .play {
		background: var(--accent);
		transform: translate(-50%, -50%) scale(1.06);
	}
	.interview-card-body {
		display: flex;
		flex-direction: column;
		gap: 8px;
		padding: 18px 20px 22px;
		flex: 1;
	}
	.interview-show {
		font-family: var(--font-sans);
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: var(--ink-500);
	}
	.interview-card-body h3 {
		font-family: var(--font-serif);
		font-weight: 500;
		font-size: 19px;
		line-height: 1.25;
		color: var(--ink-900);
		margin: 0;
		flex: 1;
	}
	.interview-link {
		font-family: var(--font-sans);
		font-size: 13px;
		font-weight: 600;
		color: var(--accent);
	}
	@media (max-width: 900px) {
		.interview-cards {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 560px) {
		.interview-cards {
			grid-template-columns: 1fr;
		}
	}
</style>
