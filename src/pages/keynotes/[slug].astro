---
import SpeakingLayout from '../../layouts/SpeakingLayout.astro';
import { reader } from '../../lib/keystatic';
import { safeUrl } from '../../lib/url';

export async function getStaticPaths() {
	const keynotes = await reader.collections.keynotes.all();
	return keynotes.map((keynote) => ({
		params: { slug: keynote.slug },
		props: { keynote: keynote.entry },
	}));
}

const { keynote } = Astro.props;
const clipEmbed = safeUrl(keynote.clip_url);
const hasTrack = (keynote.talk_track ?? []).length > 0;
const hasTakeaways = (keynote.takeaways ?? []).length > 0;

// Reuse the shared final CTA authored on the Speaking page.
const speaking = await reader.singletons.speaking.read();
const final_cta = speaking?.final_cta;
---

<SpeakingLayout
	title={`Lorraine K. Lee — ${keynote.title}`}
	description={keynote.description}
	activeId="speaking"
>
	<section class="page-hero page-hero--center">
		<div class="grid12 page-hero-grid">
			<div class="talk-page-hero fade-up">
				<a class="talk-page-back" href="/keynotes">
					<span aria-hidden="true">&larr;</span> All keynotes
				</a>
				{keynote.format && <div class="talk-format">{keynote.format}</div>}
				<h1>{keynote.title}</h1>
				{keynote.description && <p class="lead-large">{keynote.description}</p>}
				<div class="hero-cta-row">
					<a class="btn primary large" href="/contact">
						Book this talk <span aria-hidden="true">&rarr;</span>
					</a>
					<a class="anchor-link" href="/keynotes">
						See other keynotes <span class="arrow" aria-hidden="true">&rarr;</span>
					</a>
				</div>
			</div>
		</div>
	</section>

	{
		clipEmbed && (
			<section class="section section--tight talk-clip-section">
				<div class="grid12">
					<div class="talk-page-clip reveal">
						<iframe
							src={clipEmbed}
							title={`${keynote.title} — clip`}
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
							allowfullscreen
							loading="lazy"
						/>
					</div>
				</div>
			</section>
		)
	}

	{
		(hasTrack || hasTakeaways) && (
			<section class="section section--compact talk-content-section">
				<div class="grid12">
					<div class="talk-page-grid reveal-stagger">
						{hasTrack && (
							<div>
								<h2>Talk track</h2>
								<ol class="talk-page-track">
									{keynote.talk_track!.map((row) => (
										<li>
											<span class="t-time">{row.time}</span>
											<span>{row.label}</span>
										</li>
									))}
								</ol>
							</div>
						)}
						{hasTakeaways && (
							<div>
								<h2>What the audience walks away with</h2>
								<ul class="talk-page-takeaways">
									{keynote.takeaways!.map((row) => (
										<li>{row}</li>
									))}
								</ul>
							</div>
						)}
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Final CTA (shared with /speaking) ---------- */}
	{
		final_cta && (
			<section class="section">
				<div class="grid12">
					<div class="final-cta">
						<div class="final-cta-inner">
							<span class="eyebrow">{final_cta.eyebrow}</span>
							<h2>
								{final_cta.heading} <em>{final_cta.heading_accent}</em>
							</h2>
							<p>{final_cta.body}</p>
							<a class="btn yellow large" href={safeUrl(final_cta.cta_url)}>
								{final_cta.cta_label} <span aria-hidden="true">&rarr;</span>
							</a>
						</div>
					</div>
				</div>
			</section>
		)
	}
</SpeakingLayout>

<style>
	/* CLI-123: tighten this page's own vertical rhythm without touching the
	   shared .talk-page-hero (defined in templates.css). The clip sits directly
	   under the hero, so drop its top padding to close the gap. When the
	   track/takeaways block is the first content section (no clip), trim its
	   top padding too so it doesn't float far below the hero. */
	.talk-clip-section {
		padding-top: 0;
	}
	.talk-content-section {
		padding-top: clamp(20px, 3vw, 36px);
	}
</style>
