---
import HomeLayout from '../layouts/HomeLayout.astro';
import BookPromo from '../components/BookPromo.astro';
import StudentTestimonials from '../components/StudentTestimonials.astro';
import Testimonials from '../components/Testimonials.astro';
import TrustAsSeenIn from '../components/TrustAsSeenIn.astro';
import '../styles/editorial/templates.css';

const globalItems = [
  { id: 'trust-as-seen-in', label: 'Press marquee' },
  { id: 'book-promo', label: 'Book promo' },
  { id: 'testimonials', label: 'Client testimonials' },
  { id: 'student-testimonials', label: 'Student testimonials' },
];
---

<HomeLayout
  title="Global Design Audit | Lorraine K. Lee"
  description="Temporary audit page for shared global sections."
>
  <div class="shell audit-shell">
    <header class="audit-header">
      <div>
        <p class="audit-kicker">Temporary audit page</p>
        <h1>Global Design Audit</h1>
        <p class="audit-intro">
          Shared sections rendered from their canonical components.
        </p>
      </div>
      <nav class="audit-nav" aria-label="Global items">
        {globalItems.map((item) => <a href={`#${item.id}`}>{item.label}</a>)}
      </nav>
    </header>

    <section class="audit-item" id="trust-as-seen-in">
      <div class="audit-label">
        <span>Global item</span>
        <code>trust-as-seen-in</code>
      </div>
      <TrustAsSeenIn />
    </section>

    <section class="audit-item" id="book-promo">
      <div class="audit-label">
        <span>Global item</span>
        <code>book-promo</code>
      </div>
      <BookPromo />
    </section>

    <section class="audit-item" id="testimonials">
      <div class="audit-label">
        <span>Global item</span>
        <code>testimonials</code>
      </div>
      <Testimonials />
    </section>

    <section class="audit-item" id="student-testimonials">
      <div class="audit-label">
        <span>Global item</span>
        <code>student-testimonials</code>
      </div>
      <StudentTestimonials id="student-testimonials-section" />
    </section>
  </div>
</HomeLayout>

<style>
  .audit-shell {
    background: var(--paper);
    min-height: 100vh;
  }

  .audit-header {
    width: 100%;
    max-width: var(--grid-max);
    margin: 0 auto;
    padding: clamp(32px, 5vw, 64px) var(--grid-pad) clamp(20px, 4vw, 40px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: end;
  }

  .audit-kicker,
  .audit-label span {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .audit-header h1 {
    margin: 8px 0 10px;
    font-family: var(--font-serif);
    font-size: clamp(40px, 6vw, 76px);
    font-weight: 500;
    line-height: 1;
    color: var(--ink-900);
  }

  .audit-intro {
    margin: 0;
    max-width: 560px;
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-700);
  }

  .audit-nav {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .audit-nav a {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 0 12px;
    border: 1px solid var(--border-soft);
    border-radius: 999px;
    background: var(--white);
    color: var(--ink-700);
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
  }

  .audit-nav a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .audit-item {
    scroll-margin-top: 24px;
    border-top: 1px solid var(--border-soft);
  }

  .audit-label {
    width: 100%;
    max-width: var(--grid-max);
    margin: 0 auto;
    padding: 22px var(--grid-pad);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .audit-label code {
    padding: 6px 9px;
    border: 1px solid var(--border-soft);
    border-radius: 6px;
    background: var(--white);
    color: var(--ink-900);
    font-family: var(--font-mono);
    font-size: 13px;
  }

  @media (max-width: 760px) {
    .audit-header {
      grid-template-columns: 1fr;
    }

    .audit-nav {
      justify-content: flex-start;
    }

    .audit-label {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
