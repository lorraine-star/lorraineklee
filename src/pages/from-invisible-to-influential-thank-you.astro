---
/*
 * /from-invisible-to-influential-thank-you/ — funnel confirmation step.
 *
 * Recreates the original WP thank-you page that Kit redirects to after a
 * successful signup. Same minimal funnel chrome (CLI-42); copy lives in
 * Keystatic alongside the funnel page.
 */
import FunnelLayout from '../layouts/FunnelLayout.astro';
import { reader } from '../lib/keystatic';
import { safeUrl } from '../lib/url';

const fc = await reader.singletons.freeCourse.read();
if (!fc) {
  throw new Error('Missing free-course content (src/content/free-course/index.yaml)');
}
const ty = fc.thank_you;
// safeUrl() collapses unsafe/invalid values to '#', which is truthy, so guard
// against it explicitly to keep the LinkedIn fallback meaningful.
const safeCta = safeUrl(ty.cta_url);
const ctaUrl =
  safeCta && safeCta !== '#' ? safeCta : 'https://linkedin.com/in/lorraineklee';
const isExternal = /^https?:\/\//i.test(ctaUrl);
---

<FunnelLayout
  title="You're in | From Invisible to Influential"
  description="Thanks for signing up for the free 5-day course. Day 1 is on its way to your inbox."
>
  <section class="ty">
    <div class="grid12 ty-grid">
      <div class="ty-copy fade-up">
        <span class="eyebrow ty-eyebrow">{ty.eyebrow}</span>
        <p class="ty-intro">{ty.intro}</p>
        <h1 class="ty-headline">{ty.headline}</h1>
        <p class="ty-closing">{ty.closing}</p>
        {
          ty.cta_label && (
            <a
              class="btn primary large ty-cta"
              href={ctaUrl}
              target={isExternal ? '_blank' : undefined}
              rel={isExternal ? 'noopener noreferrer' : undefined}
            >
              {ty.cta_label} <span aria-hidden="true">&rarr;</span>
            </a>
          )
        }
      </div>
      {
        ty.image && (
          <div class="ty-media fade-up" style="animation-delay: 80ms;">
            <img class="ty-img" src={ty.image} alt={ty.image_alt} decoding="async" />
          </div>
        )
      }
    </div>
  </section>
</FunnelLayout>

<style>
  .ty {
    padding: clamp(56px, 9vw, 120px) 0 clamp(48px, 7vw, 96px);
  }
  .ty-grid {
    align-items: center;
    row-gap: 40px;
  }
  .ty-copy {
    grid-column: 1 / span 7;
  }
  .ty-media {
    grid-column: 8 / span 5;
  }
  .ty-eyebrow {
    color: var(--accent);
  }
  .ty-intro {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(20px, 2.2vw, 28px);
    color: var(--ink-700);
    margin: 14px 0 18px;
  }
  .ty-headline {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(28px, 3.4vw, 46px);
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--ink-900);
    margin: 0 0 24px;
    text-wrap: balance;
  }
  .ty-closing {
    font-family: var(--font-sans);
    font-size: clamp(16px, 1.2vw, 18px);
    color: var(--ink-700);
    margin: 0 0 28px;
  }
  .ty-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-lg);
  }
  @media (max-width: 900px) {
    .ty-copy {
      grid-column: 1 / -1;
      order: 2;
    }
    .ty-media {
      grid-column: 1 / -1;
      order: 1;
      max-width: 420px;
      margin: 0 auto;
    }
  }
</style>
