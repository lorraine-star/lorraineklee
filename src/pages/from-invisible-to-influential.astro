---
/*
 * /from-invisible-to-influential/ — the free 5-day email course funnel.
 *
 * Canonical URL confirmed in CLI-95. Visual design restyled in CLI-135 to the
 * Claude Design "editorial" pass: cream paper, Playfair/Inter type, pill
 * buttons, a two-column photo hero with a floating stat, full-width dark opt-in
 * band, a blue roadmap panel with a cut-out photo and glassmorphic day cards, a
 * one-card testimonial carousel with emoji icons, a red/green comparison, and a
 * dark final CTA. The roadmap + trust sections share one seamless tinted glow
 * backdrop.
 *
 * Structure, section order, and copy still follow the original funnel 1:1.
 * Copy lives in Keystatic (src/content/free-course/index.yaml); headings use
 * ==text== for the italic accent and **text** for bold (see emphasize()). Kit
 * form mechanics stay hard-wired in FreeCourseForm.astro so copy edits can
 * never break email capture.
 */
import FunnelLayout from '../layouts/FunnelLayout.astro';
import FreeCourseForm from '../components/FreeCourseForm.astro';
import { reader } from '../lib/keystatic';
import { emphasize } from '../lib/emphasis';

const fc = await reader.singletons.freeCourse.read();
if (!fc) {
  throw new Error('Missing free-course content (src/content/free-course/index.yaml)');
}

const { hero, problem, roadmap, days, trust, different, final } = fc;
const ROADMAP_IMG = '/images/free-course/roadmap-photo.png';

// Split a credibility item into its bold lead-in (card heading) and the rest.
const splitLead = (text: string) => {
  const m = text.match(/^\*\*(.+?)\*\*\s*([\s\S]*)$/);
  return m ? { head: m[1], body: m[2] } : { head: '', body: text };
};
const digit = (label: string) => label.replace(/[^0-9]/g, '');

// The roadmap title italicises the "Invisible to Influential" phrase. Split it
// out so the lead-in stays upright and only the phrase is emphasised.
const ROADMAP_ITALIC = 'Invisible to Influential';
const roadmapIdx = roadmap.heading.indexOf(ROADMAP_ITALIC);
const roadmapTitleLead = roadmapIdx >= 0 ? roadmap.heading.slice(0, roadmapIdx) : roadmap.heading;
const roadmapTitleItalic = roadmapIdx >= 0 ? roadmap.heading.slice(roadmapIdx) : '';

// Emoji credibility icons, in the funnel's fixed card order (the trust list is
// verbatim-locked, so positional mapping is stable): promotion, book, Stanford,
// Fortune 500, LinkedIn editor, course reach, follower growth, hired-at-LinkedIn.
const TRUST_EMOJI = ['📈', '📕', '🎓', '🏢', '✍️', '👥', '🚀', '🤝'];

// Inline Lucide-style icons (no CDN dependency); colored via currentColor.
const ICON_SPARKLES = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/></svg>`;
const ICON_CHECK = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`;
const ICON_ARROW = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`;
const ICON_X = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="M6 6l12 12"/></svg>`;
const ICON_CHEV_L = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>`;
const ICON_CHEV_R = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>`;
const SPARK = `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0 L13.8 10.2 L24 12 L13.8 13.8 L12 24 L10.2 13.8 L0 12 L10.2 10.2 Z"></path></svg>`;
---

<FunnelLayout title={fc.seo_title} description={fc.seo_description}>
  <div class="fitf">
    {/* ============ 1. HERO ============ */}
    <section class="fitf-section fitf-hero" id="top">
      <div class="fitf-container">
        <div class="fitf-hero-grid">
          <div class="fitf-hero-copy">
            <span class="fitf-starmark" set:html={ICON_SPARKLES} />
            <p class="fitf-eyebrow">{hero.eyebrow}</p>
            <h1 class="fitf-hero-h1">
              {hero.headline}{' '}
              <span class="fitf-accent-i">{hero.headline_suffix}</span>
            </h1>
            <p class="fitf-hero-sub" set:html={emphasize(hero.support)}></p>
          </div>

          <div class="fitf-hero-photo">
            <div class="fitf-photo-frame">
              <img src={hero.image_desktop} alt={hero.image_alt} fetchpriority="high" decoding="async" />
            </div>
            <div class="fitf-hero-stat">
              <span class="num">250k+</span>
              <span class="lbl">professionals taught<br />across LinkedIn Learning</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ============ Opt-in band (full width, dark) ============ */}
    <section class="fitf-section fitf-section--tight">
      <div class="fitf-container">
        <div class="fitf-optin fitf-optin--wide">
          <div class="fitf-optin-intro">
            <p class="fitf-optin-eyebrow">Free 5-day email course</p>
            <h3 class="fitf-optin-title">Send me Day 1, <span class="fitf-optin-free">free.</span></h3>
          </div>
          <div class="fitf-optin-body">
            <FreeCourseForm
              formId="8913437"
              idPrefix="fc-hero"
              buttonLabel={hero.form_button_label}
              namePlaceholder={hero.name_placeholder}
              emailPlaceholder={hero.email_placeholder}
            />
            <p class="fitf-fine">No spam. Unsubscribe anytime.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ============ 2. Does this sound like you ============ */}
    <section class="fitf-section fitf-section--alt">
      <div class="fitf-container">
        <div class="fitf-section-head">
          <h2 set:html={emphasize(problem.heading)}></h2>
        </div>
        <div class="fitf-pains">
          {
            problem.bullets.map((b) => (
              <div class="fitf-pain">
                <span class="fitf-pain-mark" set:html={ICON_CHECK} />
                <p set:html={emphasize(b)}></p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* ============ Shared glow backdrop: roadmap + trust ============ */}
    <div class="fitf-glow">
      {/* ---- 3. Roadmap ---- */}
      <section class="fitf-section fitf-roadmap" id="roadmap">
        <div class="fitf-container">
          <div class="fitf-roadmap-hero">
            <div class="fitf-roadmap-text">
              <p class="fitf-roadmap-eyebrow">{roadmap.eyebrow}</p>
              <h2 class="fitf-roadmap-title">
                {roadmapTitleLead}{roadmapTitleItalic && <em>{roadmapTitleItalic}</em>}
              </h2>
            </div>
            <img class="fitf-roadmap-photo" src={ROADMAP_IMG} alt="Lorraine K. Lee holding her book Unforgettable Presence" loading="lazy" />
            <span class="fitf-spark fitf-spark--1" set:html={SPARK} />
            <span class="fitf-spark fitf-spark--2" set:html={SPARK} />
            <span class="fitf-spark fitf-spark--3" set:html={SPARK} />
            <span class="fitf-spark fitf-spark--4" set:html={SPARK} />
          </div>

          <div class="fitf-days">
            {
              days.map((d) => (
                <article class="fitf-day">
                  <div class="fitf-day-num">{digit(d.day_label)}</div>
                  <div>
                    <h3 class="fitf-day-title">{d.title}</h3>
                    <p class="fitf-day-sub">{d.intro}</p>
                    <p class="fitf-day-learn">You'll learn :</p>
                    <ul>
                      {d.bullets.map((b) => (
                        <li>
                          <span class="fitf-day-ico" set:html={ICON_ARROW} />
                          <span set:html={emphasize(b)}></span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      {/* ---- 4. Trust ---- */}
      <section class="fitf-section fitf-trust">
        <div class="fitf-container">
          <div class="fitf-section-head">
            <h2 set:html={emphasize(trust.heading)}></h2>
          </div>
          <div class="fitf-carousel">
            <div class="fitf-carousel-track">
              {
                trust.items.map((it, i) => {
                  const { head, body } = splitLead(it.text);
                  return (
                    <article class="fitf-trust-card">
                      <span class="fitf-trust-ico" aria-hidden="true">{TRUST_EMOJI[i] ?? '⭐'}</span>
                      {head && <h3>{head}</h3>}
                      <p set:html={emphasize(body)}></p>
                    </article>
                  );
                })
              }
            </div>
            <button class="fitf-carousel-btn prev" type="button" aria-label="Previous testimonial" set:html={ICON_CHEV_L} />
            <button class="fitf-carousel-btn next" type="button" aria-label="Next testimonial" set:html={ICON_CHEV_R} />
          </div>
        </div>
      </section>
    </div>

    {/* ============ 5. NOT vs IS ============ */}
    <section class="fitf-section">
      <div class="fitf-container">
        <div class="fitf-section-head">
          <h2 set:html={emphasize(different.heading)}></h2>
        </div>
        <div class="fitf-compare">
          <div class="fitf-compare-col no">
            <p class="fitf-compare-ch">What this is not</p>
            <ul>
              {
                different.not_items.map((item) => (
                  <li>
                    <span class="fitf-compare-ico" set:html={ICON_X} />
                    <span set:html={emphasize(item)}></span>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="fitf-compare-col yes">
            <p class="fitf-compare-ch">What this is</p>
            <ul>
              {
                different.is_items.map((item) => (
                  <li>
                    <span class="fitf-compare-ico" set:html={ICON_ARROW} />
                    <span set:html={emphasize(item)}></span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ============ 6. Final CTA ============ */}
    <section class="fitf-section fitf-final" id="signup">
      <div class="fitf-container">
        <div class="fitf-final-grid">
          <div>
            <span class="fitf-starmark fitf-starmark--dark" set:html={ICON_SPARKLES} />
            <h2 class="fitf-final-h" set:html={emphasize(final.heading)}></h2>
            {final.lede && <p class="fitf-final-lede">{final.lede}</p>}
          </div>
          <div class="fitf-optin fitf-optin--final">
            <p class="fitf-optin-eyebrow">Start day 1 today</p>
            <h3 class="fitf-optin-title">Where should I send the course?</h3>
            <div class="fitf-optin-body">
              <FreeCourseForm
                formId="8913490"
                idPrefix="fc-final"
                buttonLabel={final.form_button_label}
                namePlaceholder={hero.name_placeholder}
                emailPlaceholder={hero.email_placeholder}
              />
              <p class="fitf-fine">No spam. Unsubscribe anytime.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Trust carousel behaviour. Kept inside the slotted content (not as a
        sibling of FunnelLayout) so it renders inside <body> and runs; a
        page-level sibling script would be emitted after </html> and never
        attach its handlers. */}
    <script>
      // Trust carousel: endless loop + step-one-card prev/next.
      // Clone the card set once before and once after the originals, park the
      // viewport in the middle copy, and — whenever the user drifts more than
      // half a set into a buffer — jump by exactly one set width. The jump is
      // invisible because the copies are identical, so scrolling never hits an
      // end. Recentering is debounced so it only fires once scrolling settles,
      // which avoids fighting the smooth button animations.
      document.querySelectorAll<HTMLElement>('.fitf-carousel').forEach((c) => {
        const track = c.querySelector<HTMLElement>('.fitf-carousel-track');
        if (!track) return;
        const originals = Array.from(track.children) as HTMLElement[];
        const n = originals.length;
        if (n < 2) return;

        const beforeFrag = document.createDocumentFragment();
        const afterFrag = document.createDocumentFragment();
        originals.forEach((node) => {
          const b = node.cloneNode(true) as HTMLElement;
          const a = node.cloneNode(true) as HTMLElement;
          b.setAttribute('aria-hidden', 'true');
          a.setAttribute('aria-hidden', 'true');
          b.dataset.clone = '1';
          a.dataset.clone = '1';
          beforeFrag.appendChild(b);
          afterFrag.appendChild(a);
        });
        track.insertBefore(beforeFrag, originals[0]);
        track.appendChild(afterFrag);

        const kids = () => track.children as HTMLCollectionOf<HTMLElement>;
        // Scroll position that centres a given card in the viewport.
        const center = (el: HTMLElement) =>
          el.offsetLeft - (track.clientWidth - el.offsetWidth) / 2;
        // Measured fresh each call. Offsets depend on layout and viewport width,
        // so reading them lazily means first-paint timing can never leave us
        // with a stale period of 0 (which would disable the loop).
        const metrics = () => {
          const k = kids();
          return { period: k[n].offsetLeft - k[0].offsetLeft, home: center(k[n]) };
        };

        const setLeft = (x: number) => {
          const prev = track.style.scrollBehavior;
          track.style.scrollBehavior = 'auto'; // jump instantly, not smooth
          track.scrollLeft = x;
          track.style.scrollBehavior = prev;
        };

        const recenter = () => {
          const { period, home } = metrics();
          if (!(period > 1)) return; // need a real measured period
          const sl = track.scrollLeft;
          const lo = home - period / 2;
          // Map scrollLeft into one period-wide band centred on home, by whole
          // periods (modulo, no loop). Identical clones make the shift invisible.
          const target = lo + (((sl - lo) % period) + period) % period;
          if (Math.abs(target - sl) > 1) setLeft(target);
        };

        let settleTimer = 0;
        track.addEventListener(
          'scroll',
          () => {
            window.clearTimeout(settleTimer);
            settleTimer = window.setTimeout(recenter, 120);
          },
          { passive: true }
        );

        let resizeTimer = 0;
        window.addEventListener('resize', () => {
          window.clearTimeout(resizeTimer);
          resizeTimer = window.setTimeout(recenter, 150);
        });

        const step = () => {
          const el = track.querySelector<HTMLElement>('.fitf-trust-card');
          return (el ? el.getBoundingClientRect().width : 320) + 20;
        };
        c.querySelector<HTMLButtonElement>('.fitf-carousel-btn.next')?.addEventListener(
          'click',
          () => track.scrollBy({ left: step(), behavior: 'smooth' })
        );
        c.querySelector<HTMLButtonElement>('.fitf-carousel-btn.prev')?.addEventListener(
          'click',
          () => track.scrollBy({ left: -step(), behavior: 'smooth' })
        );

        // Park in the middle copy. Run after layout settles (double rAF) and
        // again on full load, since the clones' real offsets aren't known until
        // the cards have been laid out.
        const park = () => {
          const { period, home } = metrics();
          if (period) setLeft(home);
        };
        requestAnimationFrame(() => requestAnimationFrame(park));
        window.addEventListener('load', park);
      });
    </script>
  </div>
</FunnelLayout>

<style>
  /* ============================================================
     Free-course SALES FUNNEL — editorial restyle (CLI-135).
     Inherits the site design tokens (tokens.css). All scoped under .fitf.
     ============================================================ */
  .fitf {
    background: var(--paper);
    color: var(--ink-700);
    font-family: var(--font-sans);
  }

  .fitf-container {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 var(--gutter);
    width: 100%;
  }
  .fitf-section {
    padding: clamp(34px, 4vw, 60px) 0;
  }
  .fitf-section--tight {
    padding: clamp(22px, 3vw, 40px) 0;
  }
  .fitf-section--alt {
    background: var(--paper-deep);
  }

  /* ---- Shared accents rendered via set:html ---- */
  .fitf :global(mark),
  .fitf-accent-i {
    background: none;
    color: var(--accent);
    font-style: italic;
    font-weight: var(--fw-regular);
    padding: 0;
  }
  .fitf :global(strong) {
    color: var(--ink-900);
    font-weight: var(--fw-bold);
  }

  .fitf-starmark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-pill);
    background: var(--brand-blue-100);
    color: var(--accent);
    margin-bottom: 22px;
  }
  .fitf-starmark :global(svg) {
    width: 28px;
    height: 28px;
  }

  .fitf-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 16px;
  }

  /* ---- Section head ---- */
  .fitf-section-head {
    max-width: 760px;
    margin: 0 auto clamp(26px, 3.5vw, 42px);
    text-align: center;
  }
  .fitf-section-head h2 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(30px, 3.6vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink-900);
    text-wrap: balance;
    margin: 0;
  }

  /* ============ 1. HERO ============ */
  .fitf-hero {
    padding: clamp(32px, 4vw, 60px) 0 clamp(28px, 3.5vw, 48px);
  }
  .fitf-hero-grid {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    gap: clamp(40px, 5vw, 80px);
    align-items: start;
  }
  .fitf-hero-h1 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(28px, 3.2vw, 44px);
    line-height: 1.12;
    letter-spacing: -0.015em;
    color: var(--ink-900);
    text-wrap: balance;
    margin: 0 0 20px;
  }
  .fitf-hero-sub {
    font-family: var(--font-sans);
    font-size: clamp(18px, 1.5vw, 22px);
    line-height: 1.5;
    color: var(--ink-700);
    margin: 0;
    max-width: 600px;
    text-wrap: pretty;
  }
  .fitf-hero-sub :global(strong) {
    color: var(--ink-900);
    font-weight: var(--fw-semibold);
    font-style: normal;
  }

  .fitf-hero-photo {
    position: relative;
  }
  .fitf-photo-frame {
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    background: radial-gradient(120% 90% at 50% 10%, var(--brand-blue-300) 0%, var(--brand-blue-100) 55%, var(--paper-deep) 100%);
    aspect-ratio: 5 / 6;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .fitf-photo-frame img {
    width: 100%;
    height: 104%;
    object-fit: contain;
    object-position: center bottom;
    display: block;
    filter: drop-shadow(0 22px 38px rgba(15, 30, 75, 0.22));
  }
  .fitf-hero-stat {
    position: absolute;
    bottom: -22px;
    left: -22px;
    background: #fff;
    border-radius: var(--radius-lg);
    padding: 14px 18px;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border-soft);
    display: flex;
    align-items: center;
    gap: 13px;
    max-width: 250px;
  }
  .fitf-hero-stat .num {
    font-family: var(--font-serif);
    font-size: 38px;
    font-weight: 500;
    color: var(--accent);
    line-height: 1;
  }
  .fitf-hero-stat .lbl {
    font-size: 12px;
    color: var(--ink-700);
    line-height: 1.35;
  }

  /* ============ Opt-in form (dark) ============ */
  .fitf-optin {
    background: var(--ink-900);
    color: var(--paper);
    border-radius: var(--radius-xl);
    padding: clamp(26px, 3vw, 36px);
  }
  .fitf-optin-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--brand-yellow-500);
    margin: 0 0 8px;
  }
  .fitf-optin-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 25px;
    line-height: 1.18;
    color: var(--paper);
    margin: 0 0 22px;
  }
  .fitf-optin-free {
    color: var(--brand-yellow-500);
    font-style: italic;
  }
  .fitf-fine {
    font-size: 12px;
    color: rgba(251, 248, 242, 0.5);
    margin: 13px 0 0;
  }

  /* Full-width band below the hero */
  .fitf-optin--wide {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(24px, 3.5vw, 56px);
    align-items: center;
  }
  .fitf-optin--wide .fitf-optin-title {
    margin-bottom: 0;
  }
  .fitf-optin--wide .fitf-fine {
    text-align: left;
  }
  .fitf-optin--final .fitf-fine {
    text-align: center;
  }

  /* FreeCourseForm internals (.fc-*) restyled to the dark opt-in look. */
  .fitf-optin :global(.fc-form) {
    display: grid;
    gap: 14px 16px;
    margin: 0;
  }
  .fitf-optin--wide :global(.fc-form) {
    grid-template-columns: 1fr 1fr;
  }
  .fitf-optin--final :global(.fc-form) {
    grid-template-columns: 1fr;
  }
  .fitf-optin :global(.fc-field) {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  /* Surface the visually-hidden field labels as styled opt-in labels. */
  .fitf-optin :global(.fc-field label) {
    position: static;
    width: auto;
    height: auto;
    clip: auto;
    margin: 0 0 8px;
    padding: 0;
    overflow: visible;
    white-space: normal;
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--brand-yellow-500);
  }
  .fitf-optin :global(.fc-input) {
    width: 100%;
    padding: 15px 20px;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(255, 255, 255, 0.2);
