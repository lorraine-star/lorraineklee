---
/*
 * /from-invisible-to-influential/ — the free 5-day email course funnel.
 *
 * Canonical URL confirmed in CLI-95. This is a 1:1 recreation of the original
 * WordPress funnel (structure, copy, form behavior) under our design system,
 * with the minimal funnel nav from CLI-42. Copy is reproduced verbatim from the
 * published WP page and lives in Keystatic (src/content/free-course/index.yaml);
 * the Kit form mechanics are hard-wired in FreeCourseForm.astro.
 *
 * Legacy/vanity URLs (/free-course, /landing-01, /5-day-course) 301 here via
 * vercel.json.
 */
import FunnelLayout from '../layouts/FunnelLayout.astro';
import FreeCourseForm from '../components/FreeCourseForm.astro';
import { reader } from '../lib/keystatic';
import { emphasize } from '../lib/emphasis';

const fc = await reader.singletons.freeCourse.read();
if (!fc) {
  throw new Error('Missing free-course content (src/content/free-course/index.yaml)');
}

const { hero, problem, roadmap, days, trust, different, final } = fc;
const STARS = '/images/free-course/stars.svg';
---

<FunnelLayout title={fc.seo_title} description={fc.seo_description}>
  {/* ---------- Hero + top signup ---------- */}
  <section class="fc-hero">
    <div class="grid12 fc-hero-grid">
      <div class="fc-hero-copy fade-up">
        <div class="fc-eyebrow-row">
          <img class="fc-stars" src={STARS} alt="" width="116" height="22" />
          <span class="eyebrow fc-eyebrow">{hero.eyebrow}</span>
        </div>
        <h1 class="fc-headline">{hero.headline}</h1>
        <p class="fc-headline-suffix">{hero.headline_suffix}</p>
        <p class="fc-support" set:html={emphasize(hero.support)}></p>

        <div class="fc-form-card">
          <FreeCourseForm
            formId="8913437"
            idPrefix="fc-hero"
            buttonLabel={hero.form_button_label}
            namePlaceholder={hero.name_placeholder}
            emailPlaceholder={hero.email_placeholder}
          />
        </div>
      </div>

      <div class="fc-hero-media fade-up" style="animation-delay: 80ms;">
        <picture>
          <source media="(max-width: 760px)" srcset={hero.image_mobile} />
          <img
            class="fc-hero-img"
            src={hero.image_desktop}
            alt={hero.image_alt}
            fetchpriority="high"
            decoding="async"
          />
        </picture>
      </div>
    </div>
  </section>

  {/* ---------- Does this sound like you? ---------- */}
  <section class="section fc-problem">
    <div class="grid12">
      <div class="fc-block">
        <div class="section-head section-head--center">
          <h2>{problem.heading}</h2>
        </div>
        <ul class="fc-problem-list reveal-stagger">
          {
            problem.bullets.map((b) => (
              <li class="fc-problem-item">
                <span class="fc-check" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                </span>
                <span set:html={emphasize(b)}></span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  {/* ---------- 5-day roadmap ---------- */}
  <section class="section section--cream fc-roadmap" id="roadmap">
    <div class="grid12">
      <div class="fc-block">
        <div class="section-head section-head--center">
          <span class="eyebrow">{roadmap.eyebrow}</span>
          <h2>{roadmap.heading}</h2>
        </div>
        <div class="fc-days reveal-stagger">
          {
            days.map((d) => (
              <article class="fc-day">
                <div class="fc-day-tag">{d.day_label}</div>
                <div class="fc-day-body">
                  <h3 class="fc-day-title">{d.title}</h3>
                  <p class="fc-day-intro">{d.intro}</p>
                  <p class="fc-day-learn">You'll learn:</p>
                  <ul class="fc-day-list">
                    {d.bullets.map((b) => (
                      <li set:html={emphasize(b)}></li>
                    ))}
                  </ul>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  {/* ---------- Why trust me? ---------- */}
  <section class="section fc-trust">
    <div class="grid12">
      <div class="fc-block">
        <div class="section-head section-head--center">
          <h2>{trust.heading}</h2>
        </div>
        <ul class="fc-trust-list reveal-stagger">
          {
            trust.bullets.map((b) => (
              <li class="fc-trust-item">
                <span class="fc-trust-mark" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2l2.95 6.74L22 9.74l-5.5 4.78L18.18 22 12 18.27 5.82 22l1.68-7.48L2 9.74l7.05-1z" />
                  </svg>
                </span>
                <span set:html={emphasize(b)}></span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  {/* ---------- Why this isn't like every other course ---------- */}
  <section class="section section--cream fc-different">
    <div class="grid12">
      <div class="fc-block">
        <div class="section-head section-head--center">
          <h2>{different.heading}</h2>
        </div>
        <div class="fc-different-grid reveal-stagger">
          <div class="fc-col fc-col--not">
            <ul>
              {
                different.not_items.map((item) => (
                  <li class="fc-not-item">
                    <span class="fc-x" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                      </svg>
                    </span>
                    <span set:html={emphasize(item)}></span>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="fc-col fc-col--is">
            <ul>
              {
                different.is_items.map((item) => (
                  <li class="fc-is-item">
                    <span class="fc-check fc-check--solid" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                    </span>
                    <span set:html={emphasize(item)}></span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ---------- Final CTA + bottom signup ---------- */}
  <section class="section fc-final" id="signup">
    <div class="grid12">
      <div class="final-cta reveal">
        <div class="final-cta-inner">
          <img class="fc-stars fc-stars--final" src={STARS} alt="" width="132" height="26" />
          <h2>{final.heading}</h2>
          <div class="fc-form-card fc-form-card--final">
            <FreeCourseForm
              formId="8913490"
              idPrefix="fc-final"
              buttonLabel={final.form_button_label}
              namePlaceholder={hero.name_placeholder}
              emailPlaceholder={hero.email_placeholder}
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</FunnelLayout>

<style>
  /* ============================================================
     Free-course funnel — all styles scoped under .fc-* so they
     never patch shared/global classes.
     ============================================================ */

  /* ---------- Hero ---------- */
  .fc-hero {
    padding: clamp(40px, 6vw, 84px) 0 clamp(48px, 7vw, 96px);
    position: relative;
    overflow: hidden;
  }
  .fc-hero-grid {
    align-items: center;
    row-gap: 40px;
  }
  .fc-hero-copy {
    grid-column: 1 / span 7;
  }
  .fc-hero-media {
    grid-column: 8 / span 5;
  }
  .fc-eyebrow-row {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }
  .fc-stars {
    height: 22px;
    width: auto;
    display: block;
  }
  .fc-eyebrow {
    color: var(--accent);
    letter-spacing: 0.18em;
  }
  .fc-headline {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(34px, 4.6vw, 60px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink-900);
    margin: 0 0 14px;
    text-wrap: balance;
  }
  .fc-headline-suffix {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(20px, 2.4vw, 30px);
    line-height: 1.2;
    color: var(--accent);
    margin: 0 0 22px;
  }
  .fc-support {
    font-family: var(--font-sans);
    font-size: clamp(16px, 1.2vw, 18px);
    line-height: 1.6;
    color: var(--ink-700);
    margin: 0 0 28px;
    max-width: 46ch;
  }
  .fc-support :global(strong) {
    color: var(--ink-900);
    font-weight: 700;
  }

  .fc-hero-media {
    position: relative;
  }
  .fc-hero-img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center top;
    display: block;
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-lg);
  }

  /* ---------- Signup form ---------- */
  .fc-form-card {
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-xl);
    padding: clamp(20px, 2.4vw, 28px);
    box-shadow: var(--shadow-md);
    max-width: 480px;
  }
  .fc-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 0;
  }
  .fc-input {
    width: 100%;
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--ink-900);
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 14px 16px;
    transition: border-color 200ms var(--ease-out), box-shadow 200ms var(--ease-out);
  }
  .fc-input::placeholder {
    color: var(--ink-300);
  }
  .fc-input:focus-visible {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--brand-blue-100);
  }
  .fc-submit {
    width: 100%;
    justify-content: center;
    margin-top: 4px;
  }
  .fc-submit[disabled] {
    opacity: 0.7;
    cursor: progress;
  }
  .fc-form-error {
    margin: 0;
    font-size: 13px;
    color: var(--danger);
    text-align: center;
  }
  .fc-form-error[hidden] {
    display: none;
  }

  /* ---------- Shared block width ---------- */
  .fc-block {
    grid-column: 1 / -1;
  }
  .fc-problem .section-head,
  .fc-trust .section-head,
  .fc-roadmap .section-head,
  .fc-different .section-head {
    margin-bottom: clamp(36px, 4vw, 56px);
  }

  /* ---------- Problem list ---------- */
  .fc-problem-list {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 820px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px 28px;
  }
  .fc-problem-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink-700);
  }
  .fc-check {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--brand-blue-100);
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }
  .fc-check svg {
    width: 15px;
    height: 15px;
  }

  /* ---------- 5-day roadmap ---------- */
  .fc-days {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 860px;
    margin: 0 auto;
  }
  .fc-day {
    display: grid;
    grid-template-columns: 132px 1fr;
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 240ms var(--ease-out), box-shadow 240ms var(--ease-out);
  }
  .fc-day:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .fc-day-tag {
    background: var(--ink-900);
    color: var(--paper);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 24px 12px;
  }
  .fc-day-body {
    padding: clamp(22px, 2.4vw, 32px);
  }
  .fc-day-title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: var(--ink-900);
    margin: 0 0 8px;
  }
  .fc-day-intro {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-700);
    margin: 0 0 16px;
  }
  .fc-day-learn {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 10px;
  }
  .fc-day-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .fc-day-list li {
    position: relative;
    padding-left: 26px;
    font-family: var(--font-sans);
    font-size: 15.5px;
    line-height: 1.55;
    color: var(--ink-700);
  }
  .fc-day-list li::before {
    content: '';
    position: absolute;
    left: 4px;
    top: 9px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--brand-yellow-500);
  }
  .fc-day-list :global(strong),
  .fc-trust-item :global(strong),
  .fc-not-item :global(strong),
  .fc-is-item :global(strong) {
    color: var(--ink-900);
    font-weight: 700;
  }

  /* ---------- Why trust me ---------- */
  .fc-trust-list {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 820px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .fc-trust-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-family: var(--font-sans);
    font-size: 16.5px;
    line-height: 1.6;
    color: var(--ink-700);
  }
  .fc-trust-mark {
    flex-shrink: 0;
    color: var(--brand-yellow-500);
    margin-top: 2px;
  }
  .fc-trust-mark svg {
    width: 22px;
    height: 22px;
    filter: drop-shadow(0 1px 0 rgba(14, 21, 48, 0.08));
  }

  /* ---------- Why this isn't like every other course ---------- */
  .fc-different-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    max-width: 900px;
    margin: 0 auto;
  }
  .fc-col {
    border-radius: var(--radius-xl);
    padding: clamp(24px, 2.6vw, 36px);
    border: 1px solid var(--border-soft);
  }
  .fc-col--not {
    background: var(--bg-card);
  }
  .fc-col--is {
    background: var(--ink-900);
  }
  .fc-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .fc-not-item,
  .fc-is-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.5;
  }
  .fc-not-item {
    color: var(--ink-700);
  }
  .fc-is-item {
    color: var(--paper);
  }
  .fc-is-item :global(strong) {
    color: var(--white);
  }
  .fc-x,
  .fc-check--solid {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }
  .fc-x {
    background: rgba(194, 69, 69, 0.12);
    color: var(--danger);
  }
  .fc-check--solid {
    background: var(--brand-yellow-500);
    color: var(--ink-900);
  }
  .fc-x svg,
  .fc-check--solid svg {
    width: 15px;
    height: 15px;
  }

  /* ---------- Final CTA ---------- */
  .fc-final .final-cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .fc-stars--final {
    height: 26px;
    margin-bottom: 18px;
  }
  .fc-form-card--final {
    width: 100%;
    max-width: 440px;
    margin-top: 28px;
    text-align: left;
  }

  /* Scroll-reveal styling itself lives in the shared editorial templates.css
     (.reveal / .reveal.is-in). FunnelLayout adds a JS-fallback so the funnel
     never hides content if its reveal script fails to load. */

  /* ---------- Responsive ---------- */
  @media (max-width: 900px) {
    .fc-hero-copy {
      grid-column: 1 / -1;
      order: 2;
    }
    .fc-hero-media {
      grid-column: 1 / -1;
      order: 1;
      max-width: 460px;
      margin: 0 auto;
    }
    .fc-form-card {
      max-width: 520px;
    }
  }
  @media (max-width: 680px) {
    .fc-problem-list {
      grid-template-columns: 1fr;
    }
    .fc-different-grid {
      grid-template-columns: 1fr;
    }
    .fc-day {
      grid-template-columns: 1fr;
    }
    .fc-day-tag {
      justify-content: flex-start;
      padding: 12px 20px;
      letter-spacing: 0.2em;
    }
  }
</style>

<script>
  // --- Kit/ConvertKit form submit (shared by both funnel forms) ---
  // Posts the exact Kit fields, then advances to the thank-you step. Falls
  // back to a native submit (Kit's own redirect) if the fetch fails.
  const THANK_YOU = '/from-invisible-to-influential-thank-you/';

  document.querySelectorAll<HTMLFormElement>('[data-fc-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const btn = form.querySelector<HTMLButtonElement>('.fc-submit');
      const label = form.querySelector<HTMLElement>('[data-fc-label]');
      const error = form.querySelector<HTMLElement>('[data-fc-error]');
      const originalLabel = label?.textContent ?? '';
      error?.setAttribute('hidden', '');
      if (btn) btn.disabled = true;
      if (label) label.textContent = 'Sending…';

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        if (!res.ok) throw new Error(`Kit responded ${res.status}`);
        window.location.assign(THANK_YOU);
        return;
      } catch (err) {
        // Network/CORS failure: let the browser post natively to Kit, which is
        // configured to redirect to the same thank-you URL.
        try {
          HTMLFormElement.prototype.submit.call(form);
          return;
        } catch {
          if (btn) btn.disabled = false;
          if (label) label.textContent = originalLabel;
          error?.removeAttribute('hidden');
        }
      }
    });
  });
</script>
