---
import SpeakingLayout from '../layouts/SpeakingLayout.astro';
import TrustAsSeenIn from '../components/TrustAsSeenIn.astro';
import { reader } from '../lib/keystatic';
import { safeUrl } from '../lib/url';

const mediaKit = await reader.singletons.mediaKit.read();
if (!mediaKit) {
	throw new Error('Missing media kit content (src/content/media-kit/index.yaml)');
}

const {
	hero,
	quick_facts,
	bios_section,
	bios,
	headshots_section,
	headshots,
	assets_section,
	assets,
	topics_section,
	topics,
	press_section,
	featured_links,
	final_cta,
} = mediaKit;

const isExternal = (url: string) => /^https?:\/\//i.test(url);
const pad2 = (n: number) => String(n).padStart(2, '0');
---

<SpeakingLayout
	title="Lorraine K. Lee | Media Kit"
	description={hero.lead}
	activeId="about"
>
	{/* ---------- Hero ---------- */}
	<section class="page-hero section--cream">
		<div class="grid12 page-hero-grid">
			<div class="page-hero-copy fade-up">
				<div class="page-hero-eyebrow">
					<span class="dot"></span>
					<span class="eyebrow" style="color: var(--ink-500);">
						{hero.eyebrow}
					</span>
				</div>
				<h1>{hero.headline} <em>{hero.headline_accent}</em></h1>
				<p class="lead-large">{hero.lead}</p>
				<div class="hero-cta-row">
					<a class="btn primary large" href={safeUrl(hero.primary_cta_url)}>
						{hero.primary_cta_label} <span aria-hidden="true">&rarr;</span>
					</a>
					<a class="btn outline" href={safeUrl(hero.secondary_cta_url)}>
						{hero.secondary_cta_label}
					</a>
				</div>
				{
					hero.contact_note && (
						<p class="mk-contact-note">{hero.contact_note}</p>
					)
				}
			</div>
			<div class="page-hero-aside fade-up" style="animation-delay: 120ms;">
				<div class="about-hero-photo">
					<div class="photo-mask">
						<img src={hero.headshot} alt={hero.headshot_alt} />
					</div>
					{
						hero.stat_value && (
							<div class="floating-card">
								<div class="num">{hero.stat_value}</div>
								<div class="lbl">{hero.stat_label}</div>
							</div>
						)
					}
				</div>
			</div>
		</div>
	</section>

	{/* ---------- Quick facts (press sheet) ---------- */}
	{
		quick_facts?.length > 0 && (
			<section class="section section--tight">
				<div class="grid12">
					<dl class="mk-factsheet reveal-stagger">
						{quick_facts.map((f) => (
							<div class="mk-fact">
								<dt>{f.label}</dt>
								<dd>{f.value}</dd>
							</div>
						))}
					</dl>
				</div>
			</section>
		)
	}

	{/* ---------- Bios ---------- */}
	{
		bios?.length > 0 && (
			<section class="section section--cream" id="bios">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{bios_section.eyebrow}</span>
						<h2>
							{bios_section.heading} <em>{bios_section.heading_accent}</em>
						</h2>
						{bios_section.note && (
							<p class="lead">{bios_section.note}</p>
						)}
					</div>
					<div class="mk-bios reveal-stagger">
						{bios.map((b) => (
							<article class="mk-bio">
								<div class="mk-bio-marker">{b.length_label}</div>
								<p class="mk-bio-text">{b.text}</p>
								<button class="mk-copy" type="button" data-copy={b.text}>
									<span class="mk-copy-icon" aria-hidden="true" />
									<span class="mk-copy-label">Copy</span>
								</button>
							</article>
						))}
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Headshots ---------- */}
	{
		headshots?.length > 0 && (
			<section class="section" id="headshots">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{headshots_section.eyebrow}</span>
						<h2>
							{headshots_section.heading}{' '}
							<em>{headshots_section.heading_accent}</em>
						</h2>
					</div>
					<div class="mk-gallery reveal-stagger">
						{headshots.map((h) => {
							const dl = safeUrl(h.download_url) || h.image;
							return (
								<figure class="mk-shot">
									<div class="mk-shot-frame">
										<img src={h.image} alt={h.alt} loading="lazy" />
									</div>
									<figcaption>
										<span class="mk-shot-label">{h.label}</span>
										<a class="mk-shot-dl" href={dl} download>
											Download <span aria-hidden="true">&darr;</span>
										</a>
									</figcaption>
								</figure>
							);
						})}
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Brand & press assets ---------- */}
	{
		assets?.length > 0 && (
			<section class="section section--cream" id="assets">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{assets_section.eyebrow}</span>
						<h2>
							{assets_section.heading}{' '}
							<em>{assets_section.heading_accent}</em>
						</h2>
					</div>
					<div class="mk-assets reveal-stagger">
						{assets.map((a) => {
							const url = safeUrl(a.url) || '#';
							const external = isExternal(url);
							return (
								<a
									class="mk-asset"
									href={url}
									target={external ? '_blank' : undefined}
									rel={external ? 'noopener noreferrer' : undefined}
								>
									<span class="mk-asset-chip">{a.format || 'FILE'}</span>
									<span class="mk-asset-body">
										<span class="mk-asset-label">{a.label}</span>
										{a.description && (
											<span class="mk-asset-desc">{a.description}</span>
										)}
									</span>
									<span class="mk-asset-action">
										{external ? 'Open' : 'Download'}
										<span class="mk-asset-arrow" aria-hidden="true">
											{external ? '↗' : '↓'}
										</span>
									</span>
								</a>
							);
						})}
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Speaking & media topics ---------- */}
	{
		topics?.length > 0 && (
			<section class="section" id="topics">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{topics_section.eyebrow}</span>
						<h2>
							{topics_section.heading}{' '}
							<em>{topics_section.heading_accent}</em>
						</h2>
					</div>
					<div class="learn-list reveal-stagger">
						{topics.map((t, i) => (
							<div class="learn-item">
								<div class="ln">{pad2(i + 1)}</div>
								<div>
									<h4>{t.title}</h4>
									<p>{t.description}</p>
								</div>
							</div>
						))}
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Featured in ---------- */}
	<section class="section section--cream" id="press">
		<div class="grid12">
			<div class="section-head section-head--center">
				<span class="eyebrow">{press_section.eyebrow}</span>
				<h2>
					{press_section.heading}{' '}
					<em>{press_section.heading_accent}</em>
				</h2>
			</div>
		</div>
		<TrustAsSeenIn />
		{
			featured_links?.length > 0 && (
				<div class="grid12">
					<ul class="mk-press reveal-stagger">
						{featured_links.map((l) => {
							const url = safeUrl(l.url) || '#';
							const external = isExternal(url);
							return (
								<li class="mk-press-item">
									<a
										href={url}
										target={external ? '_blank' : undefined}
										rel={external ? 'noopener noreferrer' : undefined}
									>
										<span class="mk-press-outlet">{l.outlet}</span>
										<span class="mk-press-title">{l.title}</span>
										<span class="mk-press-arrow" aria-hidden="true">&rarr;</span>
									</a>
								</li>
							);
						})}
					</ul>
				</div>
			)
		}
	</section>

	{/* ---------- Final CTA ---------- */}
	<section class="section">
		<div class="grid12">
			<div class="final-cta reveal">
				<div class="final-cta-inner">
					<span class="eyebrow">{final_cta.eyebrow}</span>
					<h2>
						{final_cta.heading} <em>{final_cta.heading_accent}</em>
					</h2>
					<p>{final_cta.body}</p>
					<div class="hero-cta-row" style="justify-content: center;">
						<a class="btn yellow large" href={safeUrl(final_cta.cta_url)}>
							{final_cta.cta_label} <span aria-hidden="true">&rarr;</span>
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>
</SpeakingLayout>

<script>
	// Copy-to-clipboard for the bio cards.
	document.querySelectorAll<HTMLButtonElement>('.mk-copy').forEach((btn) => {
		const label = btn.querySelector<HTMLElement>('.mk-copy-label');
		btn.addEventListener('click', async () => {
			const text = btn.dataset.copy || '';
			try {
				await navigator.clipboard.writeText(text);
			} catch {
				const ta = document.createElement('textarea');
				ta.value = text;
				ta.style.position = 'fixed';
				ta.style.opacity = '0';
				document.body.appendChild(ta);
				ta.select();
				document.execCommand('copy');
				document.body.removeChild(ta);
			}
			const original = label ? label.textContent : null;
			if (label) label.textContent = 'Copied';
			btn.classList.add('is-copied');
			window.setTimeout(() => {
				if (label) label.textContent = original;
				btn.classList.remove('is-copied');
			}, 1600);
		});
	});
</script>

<style>
	/* ================================================================
	   Media Kit — page-specific sections.
	   Primitives (page-hero, about-hero-photo, section--*, section-head,
	   eyebrow, learn-list, final-cta, btn) come from styles/editorial/.
	   ================================================================ */

	/* ---- Hero contact note ---- */
	.mk-contact-note {
		margin: 22px 0 0;
		font-family: var(--font-sans);
		font-size: 13.5px;
		line-height: 1.5;
		color: var(--ink-500);
	}

	/* ---- Quick facts: press sheet ---- */
	.mk-factsheet {
		grid-column: 1 / -1;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0;
		border-top: 1px solid var(--ink-200);
		border-bottom: 1px solid var(--ink-200);
	}
	.mk-fact {
		padding: 26px 32px;
		border-right: 1px solid var(--border-soft);
		border-bottom: 1px solid var(--border-soft);
	}
	/* remove the outer-right / bottom edges so only interior rules show */
	.mk-fact:nth-child(3n) {
		border-right: none;
	}
	.mk-fact dt {
		font-family: var(--font-sans);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 10px;
	}
	.mk-fact dd {
		margin: 0;
		font-family: var(--font-sans);
		font-size: 15px;
		line-height: 1.55;
		color: var(--ink-900);
	}

	/* ---- Bios: stacked editorial panels ---- */
	.mk-bios {
		grid-column: 1 / -1;
		max-width: 940px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
	}
	.mk-bio {
		display: grid;
		grid-template-columns: 170px 1fr auto;
		gap: 28px;
		align-items: start;
		padding: 32px 0;
		border-top: 1px solid var(--border-soft);
	}
	.mk-bio:last-child {
		border-bottom: 1px solid var(--border-soft);
	}
	.mk-bio-marker {
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: 500;
		font-size: 19px;
		line-height: 1.3;
		color: var(--accent);
		padding-top: 2px;
	}
	.mk-bio-text {
		margin: 0;
		font-family: var(--font-sans);
		font-size: 16px;
		line-height: 1.66;
		color: var(--ink-700);
	}
	.mk-copy {
		justify-self: end;
		flex: 0 0 auto;
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-sans);
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--ink-900);
		background: transparent;
		border: 1.5px solid var(--ink-900);
		border-radius: 999px;
		padding: 9px 16px;
		cursor: pointer;
		white-space: nowrap;
		transition:
			background 200ms var(--ease-out),
			color 200ms var(--ease-out),
			border-color 200ms var(--ease-out),
			transform 200ms var(--ease-out);
	}
	.mk-copy:hover {
		background: var(--ink-900);
		color: #fff;
		transform: translateY(-2px);
	}
	.mk-copy-icon {
		width: 13px;
		height: 13px;
		border: 1.5px solid currentColor;
		border-radius: 3px;
		position: relative;
	}
	.mk-copy-icon::before {
		content: '';
		position: absolute;
		width: 13px;
		height: 13px;
		border: 1.5px solid currentColor;
		border-radius: 3px;
		top: -4px;
		left: -4px;
		background: inherit;
	}
	.mk-copy.is-copied {
		background: var(--accent);
		border-color: var(--accent);
		color: #fff;
	}

	/* ---- Headshots gallery ---- */
	.mk-gallery {
		grid-column: 1 / -1;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px;
	}
	.mk-shot {
		margin: 0;
	}
	.mk-shot-frame {
		border-radius: 18px;
		overflow: hidden;
		background: var(--paper-deep);
		aspect-ratio: 4 / 5;
		box-shadow: var(--shadow-md);
		transition:
			transform 320ms var(--ease-out),
			box-shadow 320ms var(--ease-out);
	}
	.mk-shot-frame img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.mk-shot:hover .mk-shot-frame {
		transform: translateY(-4px);
		box-shadow: var(--shadow-lg);
	}
	.mk-shot figcaption {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin-top: 16px;
	}
	.mk-shot-label {
		font-family: var(--font-serif);
		font-size: 18px;
		font-style: italic;
		color: var(--ink-900);
	}
	.mk-shot-dl {
		font-family: var(--font-sans);
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--accent);
		text-decoration: none;
		white-space: nowrap;
	}
	.mk-shot-dl span {
		display: inline-block;
		transition: transform 200ms var(--ease-out);
	}
	.mk-shot-dl:hover span {
		transform: translateY(3px);
	}

	/* ---- Brand & press assets ---- */
	.mk-assets {
		grid-column: 1 / -1;
		max-width: 900px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 14px;
	}
	.mk-asset {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 24px;
		padding: 22px 26px;
		background: var(--white);
		border: 1px solid var(--border-soft);
		border-radius: 16px;
		text-decoration: none;
		color: inherit;
		transition:
			transform 240ms var(--ease-out),
			box-shadow 240ms var(--ease-out),
			border-color 240ms var(--ease-out);
	}
	.mk-asset:hover {
		transform: translateY(-3px);
		border-color: var(--ink-200);
		box-shadow: var(--shadow-md);
	}
	.mk-asset-chip {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 56px;
		height: 56px;
		padding: 0 10px;
		border-radius: 12px;
		background: var(--brand-blue-50);
		color: var(--accent);
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.04em;
	}
	.mk-asset-body {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.mk-asset-label {
		font-family: var(--font-serif);
		font-size: 19px;
		color: var(--ink-900);
		line-height: 1.25;
	}
	.mk-asset-desc {
		font-family: var(--font-sans);
		font-size: 14px;
		line-height: 1.5;
		color: var(--ink-500);
	}
	.mk-asset-action {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-sans);
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--accent);
		white-space: nowrap;
	}
	.mk-asset-arrow {
		display: inline-block;
		transition: transform 240ms var(--ease-out);
	}
	.mk-asset:hover .mk-asset-arrow {
		transform: translate(2px, 2px);
	}

	/* ---- Featured-in press links ---- */
	.mk-press {
		grid-column: 1 / -1;
		max-width: 940px;
		margin: 8px auto 0;
		list-style: none;
		padding: 0;
		border-top: 1px solid var(--border-soft);
	}
	.mk-press-item {
		border-bottom: 1px solid var(--border-soft);
	}
	.mk-press-item a {
		display: grid;
		grid-template-columns: 190px 1fr auto;
		align-items: baseline;
		gap: 24px;
		padding: 22px 12px;
		text-decoration: none;
		color: inherit;
		transition:
			background 200ms var(--ease-out),
			padding-left 200ms var(--ease-out);
	}
	.mk-press-item a:hover {
		background: var(--white);
		padding-left: 20px;
	}
	.mk-press-outlet {
		font-family: var(--font-sans);
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent);
	}
	.mk-press-title {
		font-family: var(--font-serif);
		font-size: 19px;
		line-height: 1.35;
		color: var(--ink-900);
	}
	.mk-press-arrow {
		color: var(--ink-300);
		transition:
			transform 200ms var(--ease-out),
			color 200ms var(--ease-out);
	}
	.mk-press-item a:hover .mk-press-arrow {
		transform: translateX(5px);
		color: var(--accent);
	}

	/* ---- Responsive ---- */
	@media (max-width: 900px) {
		.mk-factsheet {
			grid-template-columns: repeat(2, 1fr);
		}
		.mk-fact:nth-child(3n) {
			border-right: 1px solid var(--border-soft);
		}
		.mk-fact:nth-child(2n) {
			border-right: none;
		}
		.mk-gallery {
			grid-template-columns: repeat(2, 1fr);
		}
		.mk-bio {
			grid-template-columns: 1fr;
			gap: 14px;
		}
		.mk-bio-marker {
			padding-top: 0;
		}
		.mk-copy {
			justify-self: start;
		}
		.mk-press-item a {
			grid-template-columns: 1fr auto;
			gap: 6px 20px;
		}
		.mk-press-outlet {
			grid-column: 1 / -1;
		}
	}

	@media (max-width: 560px) {
		.mk-factsheet {
			grid-template-columns: 1fr;
		}
		.mk-fact,
		.mk-fact:nth-child(3n),
		.mk-fact:nth-child(2n) {
			border-right: none;
		}
		.mk-gallery {
			grid-template-columns: 1fr;
			max-width: 360px;
			margin-left: auto;
			margin-right: auto;
		}
		.mk-asset {
			grid-template-columns: auto 1fr;
			gap: 16px;
		}
		.mk-asset-action {
			grid-column: 2 / -1;
			justify-self: start;
		}
	}
</style>
