---
import SpeakingLayout from '../layouts/SpeakingLayout.astro';
import { reader } from '../lib/keystatic';

const learn = await reader.singletons.learn.read();
if (!learn) {
	throw new Error('Missing learn content (src/content/learn/index.yaml)');
}

const { hero, courses, mid_cta, stanford } = learn;

const platformOrder = ['LinkedIn Learning', 'Stanford', 'Free'];
const filters = [
	{ id: 'All', label: 'All', count: courses.length },
	...platformOrder
		.filter((p) => courses.some((c) => c.platform === p))
		.map((p) => ({
			id: p,
			label: p,
			count: courses.filter((c) => c.platform === p).length,
		})),
];

const platformClass = (p: string) =>
	p === 'Free'
		? 'platform-tag free'
		: p === 'Stanford'
			? 'platform-tag stanford'
			: 'platform-tag';

const isExternal = (url: string) => /^https?:\/\//i.test(url);
---

<SpeakingLayout
	title="Lorraine K. Lee — Learn"
	description={hero.lead}
	activeId="learn"
>
	{/* ---------- Hero ---------- */}
	<section class="page-hero page-hero--center">
		<div class="grid12 page-hero-grid">
			<div class="page-hero-copy fade-up">
				<div class="page-hero-eyebrow">
					<span class="dot"></span>
					<span class="eyebrow" style="color: var(--ink-500);">
						{hero.eyebrow}
					</span>
				</div>
				<h1>{hero.headline} <em>{hero.headline_accent}</em></h1>
				<p class="lead-large">{hero.lead}</p>
			</div>
		</div>
	</section>

	{/* ---------- Filter + course grid ---------- */}
	<section class="section section--tight" style="padding-top: 0;">
		<div class="grid12">
			<div class="learn-filter-wrap">
				<div class="filter-bar filter-bar--animated">
					<span class="filter-pill" aria-hidden="true"></span>
					{
						filters.map((f, i) => (
							<button
								class:list={['filter-tab', { active: i === 0 }]}
								type="button"
								data-filter={f.id}
							>
								{f.label}
								<span class="count">{f.count}</span>
							</button>
						))
					}
				</div>
			</div>

			<div class="course-grid-cards reveal-stagger">
				{
					courses.map((c) => {
						const url = c.url ?? '';
						const external = isExternal(url);
						const href = url || '/contact';
						return (
							<a
								class="course-card"
								data-platform={c.platform}
								href={href}
								target={external ? '_blank' : undefined}
								rel={external ? 'noopener noreferrer' : undefined}
							>
								<div class="course-thumb">
									<div class="course-thumb-deco" aria-hidden="true">
										{c.glyph}
									</div>
									<span class={platformClass(c.platform)}>{c.platform}</span>
									<div class="play" aria-hidden="true">
										<svg viewBox="0 0 24 24" fill="currentColor">
											<path d="M8 5v14l11-7z" />
										</svg>
									</div>
									{c.duration && <span class="duration">{c.duration}</span>}
								</div>
								<div class="course-card-body">
									<h3>{c.title}</h3>
									<p class="course-desc">{c.description}</p>
									<span class="course-link">
										{external ? 'Watch course' : 'Learn more'}{' '}
										<span aria-hidden="true">&rarr;</span>
									</span>
								</div>
							</a>
						);
					})
				}
			</div>
		</div>
	</section>

	{/* ---------- Mid-page CTA ---------- */}
	<section class="section section--tight">
		<div class="grid12">
			<div class="mid-cta reveal">
				<div>
					<h3>{mid_cta.heading} <em>{mid_cta.heading_accent}</em></h3>
					<p>{mid_cta.body}</p>
				</div>
				<a class="btn primary large" href={mid_cta.cta_url}>
					{mid_cta.cta_label} <span aria-hidden="true">&rarr;</span>
				</a>
			</div>
		</div>
	</section>

	{/* ---------- Stanford callout ---------- */}
	<section class="section section--tight">
		<div class="grid12">
			<div class="stanford-callout reveal">
				<div class="stanford-mark" aria-hidden="true">S</div>
				<div class="stanford-body">
					<span class="eyebrow">{stanford.eyebrow}</span>
					<h3>{stanford.heading}</h3>
					<p>{stanford.body}</p>
				</div>
				{
					stanford.cta_label && stanford.cta_url && (
						<a class="btn outline" href={stanford.cta_url}>
							{stanford.cta_label} <span aria-hidden="true">&rarr;</span>
						</a>
					)
				}
			</div>
		</div>
	</section>
</SpeakingLayout>

<script>
	function initLearnFilters() {
		const bar = document.querySelector<HTMLElement>('.filter-bar--animated');
		if (!bar) return;
		const pill = bar.querySelector<HTMLElement>('.filter-pill');
		const tabs = Array.from(
			bar.querySelectorAll<HTMLElement>('.filter-tab')
		);
		const cards = Array.from(
			document.querySelectorAll<HTMLElement>('.course-card')
		);

		function movePill(tab: HTMLElement) {
			if (!pill) return;
			pill.style.transform = 'translateX(' + tab.offsetLeft + 'px)';
			pill.style.width = tab.offsetWidth + 'px';
		}

		tabs.forEach((tab) => {
			tab.addEventListener('click', () => {
				tabs.forEach((t) => t.classList.remove('active'));
				tab.classList.add('active');
				const filter = tab.dataset.filter;
				cards.forEach((card) => {
					const show = filter === 'All' || card.dataset.platform === filter;
					card.style.display = show ? '' : 'none';
				});
				movePill(tab);
			});
		});

		const active = bar.querySelector<HTMLElement>('.filter-tab.active');
		if (active) {
			movePill(active);
			requestAnimationFrame(() => bar.classList.add('is-ready'));
		}
		window.addEventListener('resize', () => {
			const current = bar.querySelector<HTMLElement>('.filter-tab.active');
			if (current) movePill(current);
		});
	}

	initLearnFilters();
</script>
