---
import Layout from '../layouts/Layout.astro';
import { reader, renderMarkdoc } from '../lib/keystatic';

const learn = await reader.singletons.learn.read();
if (!learn) {
	throw new Error('Missing learn content (src/content/learn/index.mdoc)');
}

const heroHtml = await renderMarkdoc(learn.hero_copy);
const cta = learn.free_resource_cta;
---

<Layout title="Learn | Lorraine K. Lee">
	<section class="mx-auto max-w-3xl px-6 py-20">
		<h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">Learn</h1>
		<div
			class="mt-8 space-y-4 text-lg leading-relaxed text-neutral-700"
			set:html={heroHtml}
		/>
	</section>

	{
		learn.linkedin_learning_courses.length > 0 && (
			<section class="mx-auto max-w-3xl px-6 pb-16">
				<h2 class="text-2xl font-semibold tracking-tight">
					LinkedIn Learning courses
				</h2>
				<ul class="mt-6 space-y-6">
					{learn.linkedin_learning_courses.map((course) => (
						<li class="border-l-2 border-neutral-200 pl-6">
							<h3 class="text-lg font-medium text-neutral-900">
								{course.url ? (
									<a
										href={course.url}
										class="underline underline-offset-4 hover:text-neutral-600"
									>
										{course.title}
									</a>
								) : (
									course.title
								)}
							</h3>
							<p class="mt-1 text-neutral-600">{course.description}</p>
						</li>
					))}
				</ul>
			</section>
		)
	}

	{
		learn.stanford_blurb && (
			<section class="mx-auto max-w-3xl px-6 pb-16">
				<h2 class="text-2xl font-semibold tracking-tight">Stanford</h2>
				<p class="mt-4 text-lg leading-relaxed text-neutral-700">
					{learn.stanford_blurb}
				</p>
			</section>
		)
	}

	{
		cta.text && (
			<section class="mx-auto max-w-3xl px-6 pb-20">
				<div class="rounded-lg border border-neutral-200 bg-neutral-50 p-8">
					<p class="text-lg text-neutral-700">{cta.description}</p>
					{cta.url && (
						<a
							href={cta.url}
							class="mt-5 inline-block rounded-full bg-neutral-900 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-neutral-700"
						>
							{cta.text}
						</a>
					)}
				</div>
			</section>
		)
	}
</Layout>
