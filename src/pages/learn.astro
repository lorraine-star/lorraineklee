---
import SpeakingLayout from '../layouts/SpeakingLayout.astro';
import { reader } from '../lib/keystatic';
import { safeUrl } from '../lib/url';

const learn = await reader.singletons.learn.read();
if (!learn) {
	throw new Error('Missing learn content (src/content/learn/index.yaml)');
}

const {
	hero,
	newsletter,
	courses_section,
	linkedin_resources,
} = learn;

const isExternal = (url: string) => /^https?:\/\//i.test(url);

// Course catalog: read the shared LinkedIn Learning collection (real thumbnails,
// categories) instead of a hardcoded list, so the Learn grid and the /courses
// hub stay in sync. Mirror the hub's curation: only courses flagged for it.
const CATEGORY_ORDER = ['Communication', 'Leadership', 'Management', 'Career'];
const catIndex = (c?: string) => {
	const i = CATEGORY_ORDER.indexOf(c ?? '');
	return i === -1 ? CATEGORY_ORDER.length : i;
};

const allCourses = await reader.collections.courses.all();
const hubCourses = allCourses
	.map((c) => ({ slug: c.slug, ...c.entry }))
	.filter((c) => c.show_on_hub !== false)
	// `order` is per-category, so sorting by it first interleaves the categories
	// (one from each before the second of any) for a varied default-6 spread.
	.sort(
		(a, b) =>
			(a.order ?? 0) - (b.order ?? 0) ||
			catIndex(a.category) - catIndex(b.category)
	);

const DEFAULT_VISIBLE = 6;
const totalCourses = hubCourses.length;

// Filter pills: only categories that actually have courses, in canonical order.
const categories = CATEGORY_ORDER.filter((cat) =>
	hubCourses.some((c) => c.category === cat)
);
const countFor = (cat: string) =>
	hubCourses.filter((c) => c.category === cat).length;

// Prefer the external LinkedIn Learning URL, fall back to the on-site detail page.
const courseHref = (c: { url?: string | null; slug: string }) =>
	safeUrl(c.url) || `/courses/${c.slug}`;
---

<SpeakingLayout
	title="Lorraine K. Lee — Learn"
	description={hero.lead}
	activeId="learn"
>
	{/* ---------- Hero ---------- */}
	<section class="page-hero learn-hero">
		<div class="grid12 learn-hero-grid">
			<div class="learn-hero-copy fade-up">
				<div class="page-hero-eyebrow">
					<span class="dot"></span>
					<span class="eyebrow" style="color: var(--ink-500);">
						{hero.eyebrow}
					</span>
				</div>
				<h1>{hero.headline} <em>{hero.headline_accent}</em></h1>
			</div>
			<div class="learn-hero-aside fade-up" style="animation-delay: 80ms;">
				<p class="lead-large">{hero.lead}</p>
				<div class="learn-hero-cta-row">
					<a class="btn primary large" href="#course">
						Start the free course <span aria-hidden="true">&rarr;</span>
					</a>
					<a class="btn ghost" href="#courses">Browse courses</a>
				</div>
				<p class="learn-hero-trust">
					Join <strong>{hero.trust_count || '12,000+'}</strong> leaders learning with Lorraine.
				</p>
			</div>
		</div>

		<div class="grid12">
			<div
				class="learn-hero-bento reveal-stagger"
				aria-label="Featured courses and resources"
			>
				<a class="lh-card lh-card--feature bento-feature" href="#course">
					<div class="lh-card-body">
						<span class="lh-card-pill">Free · 5-day course</span>
						<h3 class="lh-card-title">From <em>Invisible</em> to Influential</h3>
						<p class="lh-card-desc">
							A free 5-day email course that helps you articulate your value
							and get visible to decision-makers.
						</p>
						<span class="lh-card-cta">
							Start the course <span aria-hidden="true">&rarr;</span>
						</span>
					</div>
					{
						newsletter.hero_card_image && (
							<div class="lh-card-media lh-card-media--feature">
								<img
									src={newsletter.hero_card_image}
									alt="Lorraine K. Lee working at her laptop"
									loading="lazy"
								/>
							</div>
						)
					}
				</a>
				<div class="lh-card lh-card--stat bento-stat">
					<div class="lh-card-body">
						<span class="lh-card-stat-num">250K<span class="suffix">+</span></span>
						<span class="lh-card-stat-label">
							Students taught on LinkedIn Learning
						</span>
					</div>
				</div>
				<a class="lh-card lh-card--poster bento-browse" href="#courses">
					{
						courses_section.hero_card_image && (
							<img
								class="lh-card-bg"
								src={courses_section.hero_card_image}
								alt="Lorraine K. Lee, LinkedIn Learning instructor"
								loading="lazy"
							/>
						)
					}
					<div class="lh-card-overlay">
						<span class="lh-card-eyebrow">LinkedIn Learning</span>
						<h3 class="lh-card-title">{totalCourses} on-demand courses</h3>
						<span class="lh-card-cta">
							Browse all <span aria-hidden="true">&rarr;</span>
						</span>
					</div>
				</a>
				{
					linkedin_resources?.map((r, i) => {
						const url = safeUrl(r.url) || '/contact';
						const external = isExternal(url);
						return (
							<a
								class:list={[
									'lh-card lh-card--poster',
									i === 0 ? 'bento-photo' : 'bento-guide',
								]}
								href={url}
								target={external ? '_blank' : undefined}
								rel={external ? 'noopener noreferrer' : undefined}
							>
								{r.image && (
									<img
										class="lh-card-bg"
										src={r.image}
										alt={r.label}
										loading="lazy"
									/>
								)}
								<div class="lh-card-overlay">
									<span class="lh-card-eyebrow">Free resource</span>
									<h3 class="lh-card-title">{r.label}</h3>
									<span class="lh-card-cta">
										{r.cta_label || 'Get it'}{' '}
										<span aria-hidden="true">&rarr;</span>
									</span>
								</div>
							</a>
						);
					})
				}
			</div>
		</div>
	</section>

	{/* ---------- Sticky jump-to-section sub-nav ---------- */}
	<nav class="learn-subnav" aria-label="Jump to a section">
		<div class="grid12">
			<ul class="learn-subnav-list" data-section-nav>
				<li>
					<a href="#course" data-section-link>Free course</a>
				</li>
				<li>
					<a href="#courses" data-section-link>Courses</a>
				</li>
			</ul>
		</div>
	</nav>

	{/* ---------- Newsletter lead block (mirrors home page Free Course section) ---------- */}
	<section id="course" class="course learn-newsletter">
		<div class="grid12 course-grid">
			<div class="course-copy">
				<div class="course-eyebrow">
					<span class="pill">{newsletter.eyebrow_pill}</span>
					<span>{newsletter.eyebrow_label}</span>
				</div>
				<h2 class="course-headline">
					{newsletter.headline} <em>{newsletter.headline_accent}</em>
				</h2>
				<p class="course-sub">{newsletter.body}</p>
				<ul class="course-bullets">
					{newsletter.bullets.map((day) => <li>{day}</li>)}
				</ul>
			</div>

			<div class="course-form">
				<div class="course-form-card">
					{/* Newsletter signup posts to Kit list 5057243 (same list as
					    /subscribe). Fires the GA newsletter_signup key event on submit
					    via [data-ga-event] (GoogleAnalytics.astro, CLI-51); Kit handles
					    the post-submit redirect. */}
					<form
						method="post"
						action="https://app.kit.com/forms/5057243/subscriptions"
						data-ga-event="newsletter_signup"
					>
						<span class="course-form-eyebrow">{newsletter.form_eyebrow}</span>
						<h3 class="course-form-title">
							{newsletter.form_title} <em>{newsletter.form_title_accent}</em>
						</h3>
						<label class="field-label" for="course-email">Email address</label>
						<input
							id="course-email"
							class="field"
							type="email"
							name="email_address"
							required
							placeholder="you@company.com"
						/>
						<button type="submit" class="btn yellow large btn-block">
							{newsletter.form_button_label} <span aria-hidden="true">&rarr;</span>
						</button>
						<div class="fineprint">{newsletter.form_fineprint}</div>
					</form>
				</div>
			</div>
		</div>
	</section>

	{/* ---------- LinkedIn Learning courses (secondary) ---------- */}
	<section class="section section--compact anchor-target" id="courses">
		<div class="grid12">
			<div class="section-head section-head--center">
				<span class="eyebrow">{courses_section.eyebrow}</span>
				<h2>
					{courses_section.heading}{' '}
					<em>{courses_section.heading_accent}</em>
				</h2>
				{courses_section.lead && <p class="lead">{courses_section.lead}</p>}
				<p class="course-catalog-count">
					{totalCourses} on-demand courses and counting.
				</p>
			</div>

			{/* Category filter (progressive enhancement: hidden until JS wires it up,
			    so it never renders as an inert control without JavaScript). */}
			<div
				class="course-filter"
				data-course-filter
				hidden
				role="group"
				aria-label="Filter courses by category"
			>
				<button
					type="button"
					class="course-filter-pill is-active"
					data-filter="all"
					aria-pressed="true"
				>
					All <span class="course-filter-num">{totalCourses}</span>
				</button>
				{
					categories.map((cat) => (
						<button
							type="button"
							class="course-filter-pill"
							data-filter={cat}
							aria-pressed="false"
						>
							{cat} <span class="course-filter-num">{countFor(cat)}</span>
						</button>
					))
				}
			</div>

			<div class="course-grid-cards reveal-stagger" data-course-grid>
				{
					hubCourses.map((c, i) => {
						const url = courseHref(c);
						const external = isExternal(url);
						return (
							<a
								class="course-card"
								data-platform="LinkedIn Learning"
								data-category={c.category}
								data-default-visible={i < DEFAULT_VISIBLE ? 'true' : undefined}
								href={url}
								target={external ? '_blank' : undefined}
								rel={external ? 'noopener noreferrer' : undefined}
							>
								<div class="course-thumb">
									{c.thumbnail ? (
										<img
											class="course-thumb-img"
											src={c.thumbnail}
											alt=""
											loading="lazy"
											width="1280"
											height="720"
										/>
									) : (
										<div class="course-thumb-deco" aria-hidden="true">
											{c.glyph}
										</div>
									)}
									<span class="platform-tag">LinkedIn Learning</span>
									<div class="play" aria-hidden="true">
										<svg viewBox="0 0 24 24" fill="currentColor">
											<path d="M8 5v14l11-7z" />
										</svg>
									</div>
									{c.duration && <span class="duration">{c.duration}</span>}
								</div>
								<div class="course-card-body">
									<h3>{c.title}</h3>
									<p class="course-desc">{c.description}</p>
									<span class="course-link">
										Watch course <span aria-hidden="true">&rarr;</span>
									</span>
								</div>
							</a>
						);
					})
				}
			</div>

			<p class="sr-only" data-course-live aria-live="polite" role="status"></p>

			<div class="courses-cta courses-cta--stack">
				<button
					type="button"
					class="btn outline large"
					data-course-expand
					hidden
					aria-expanded="false"
				>
					<span data-expand-label>Show all {totalCourses} courses</span>
					<span class="course-expand-icon" aria-hidden="true">&#8595;</span>
				</button>
				{
					courses_section.cta_label && courses_section.cta_url && (
						<a
							class="course-hub-link"
							href={safeUrl(courses_section.cta_url)}
							target={isExternal(courses_section.cta_url) ? '_blank' : undefined}
							rel={
								isExternal(courses_section.cta_url)
									? 'noopener noreferrer'
									: undefined
							}
						>
							{courses_section.cta_label} <span aria-hidden="true">&rarr;</span>
						</a>
					)
				}
			</div>
		</div>
	</section>

	{/* CLI-130: standalone Free Resources section removed; resources stay
	    surfaced via the hero bento cards above so the page reads cleanly
	    without the duplicated block. */}
</SpeakingLayout>

<script>
	// --- Course category filter + in-place expand ---
	const grid = document.querySelector<HTMLElement>('[data-course-grid]');
	const filterBar = document.querySelector<HTMLElement>('[data-course-filter]');
	const expandBtn = document.querySelector<HTMLButtonElement>('[data-course-expand]');
	const liveRegion = document.querySelector<HTMLElement>('[data-course-live]');

	if (grid && filterBar && expandBtn) {
		const cards = Array.from(grid.querySelectorAll<HTMLElement>('.course-card'));
		const pills = Array.from(
			filterBar.querySelectorAll<HTMLButtonElement>('[data-filter]')
		);
		const expandLabel = expandBtn.querySelector<HTMLElement>('[data-expand-label]');
		const total = cards.length;
		const defaultCount = cards.filter(
			(c) => c.dataset.defaultVisible === 'true'
		).length;

		let activeFilter = 'all';
		let expanded = false;
		// Skip the aria-live announcement on first paint; only narrate changes.
		let interacted = false;

		const render = () => {
			let shown = 0;
			for (const card of cards) {
				const visible =
					activeFilter === 'all'
						? expanded || card.dataset.defaultVisible === 'true'
						: card.dataset.category === activeFilter;
				card.classList.toggle('is-hidden', !visible);
				// Cards hidden at load are never seen by the scroll-reveal observer,
				// so once revealed by a filter/expand they must be forced visible.
				if (visible && interacted) card.classList.add('is-in');
				if (visible) shown += 1;
			}

			const canExpand = activeFilter === 'all' && total > defaultCount;
			expandBtn.hidden = !canExpand;
			expandBtn.setAttribute('aria-expanded', String(expanded));
			expandBtn.classList.toggle('is-expanded', expanded);
			if (expandLabel) {
				expandLabel.textContent = expanded
					? 'Show fewer courses'
					: `Show all ${total} courses`;
			}

			for (const pill of pills) {
				const on = (pill.dataset.filter || 'all') === activeFilter;
				pill.classList.toggle('is-active', on);
				pill.setAttribute('aria-pressed', String(on));
			}

			if (liveRegion && interacted) {
				if (activeFilter === 'all') {
					liveRegion.textContent =
						expanded || total <= defaultCount
							? `Showing all ${total} courses`
							: `Showing ${shown} of ${total} courses`;
				} else {
					liveRegion.textContent = `Showing ${shown} ${activeFilter} ${
						shown === 1 ? 'course' : 'courses'
					}`;
				}
			}
		};

		filterBar.hidden = false;
		pills.forEach((pill) => {
			pill.addEventListener('click', () => {
				interacted = true;
				activeFilter = pill.dataset.filter || 'all';
				// Returning to a category always shows the full (small) category;
				// reset the all-view expansion so it collapses back to the default 6.
				if (activeFilter !== 'all') expanded = false;
				render();
			});
		});
		expandBtn.addEventListener('click', () => {
			interacted = true;
			expanded = !expanded;
			render();
		});

		render();
	}

	// --- Scroll-spy: highlight the active section in the jump sub-nav ---
	const sectionLinks = Array.from(
		document.querySelectorAll<HTMLAnchorElement>('[data-section-link]')
	);
	if (sectionLinks.length && 'IntersectionObserver' in window) {
		const linkFor = new Map<Element, HTMLAnchorElement>();
		for (const link of sectionLinks) {
			const id = link.getAttribute('href')?.slice(1);
			const section = id ? document.getElementById(id) : null;
			if (section) linkFor.set(section, link);
		}
		const spy = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (!entry.isIntersecting) continue;
					const active = linkFor.get(entry.target);
					if (!active) continue;
					sectionLinks.forEach((l) => l.removeAttribute('aria-current'));
					active.setAttribute('aria-current', 'true');
				}
			},
			{ rootMargin: '-45% 0px -50% 0px' }
		);
		linkFor.forEach((_, section) => spy.observe(section));
	}
</script>

<style>
	/* ----------------------------------------------------------
	   Learn page sub-navigation: sticky jump-to-section bar
	   ---------------------------------------------------------- */
	.learn-subnav {
		position: sticky;
		top: 72px; /* sits just below the sticky site header (72px tall) */
		z-index: 40;
		background: rgba(251, 248, 242, 0.92);
		backdrop-filter: saturate(160%) blur(12px);
		-webkit-backdrop-filter: saturate(160%) blur(12px);
		border-bottom: 1px solid var(--border-soft);
	}
	.learn-subnav-list {
		grid-column: 1 / -1;
		display: flex;
		gap: 8px;
		margin: 0;
		padding: 10px 0;
		list-style: none;
		overflow-x: auto;
		scrollbar-width: none;
	}
	.learn-subnav-list::-webkit-scrollbar {
		display: none;
	}
	.learn-subnav-list a {
		display: inline-flex;
		align-items: center;
		white-space: nowrap;
		font-family: var(--font-sans);
		font-size: 13px;
		font-weight: 600;
		letter-spacing: 0.01em;
		color: var(--ink-700);
		text-decoration: none;
		padding: 8px 16px;
		border-radius: 999px;
		border: 1px solid var(--border-soft);
		background: #fff;
		transition: color 160ms var(--ease-out), background 160ms var(--ease-out),
			border-color 160ms var(--ease-out);
	}
	.learn-subnav-list a:hover {
		color: var(--accent);
		border-color: var(--accent);
	}
	.learn-subnav-list a[aria-current='true'] {
		color: var(--paper);
		background: var(--ink-900);
		border-color: var(--ink-900);
	}
	.learn-subnav-list a:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	/* Section anchors clear both the site header and this sub-nav. */
	#course,
	#courses {
		scroll-margin-top: 140px;
	}

	/* ----------------------------------------------------------
	   CLI-123 spacing pass: trim the hero-to-next gap so the page
	   starts scrolling sooner without crowding the hero. These are
	   page-local overrides of the learn-specific rules in
	   templates.css; the shared spacing scale stays untouched.
	   ---------------------------------------------------------- */
	.learn-hero {
		padding-bottom: clamp(36px, 4.5vw, 64px);
	}
	.learn-hero-bento {
		margin-top: clamp(28px, 4vw, 48px);
	}

	/* ----------------------------------------------------------
	   Course catalog: count, category filter pills, expand
	   ---------------------------------------------------------- */
	.course-catalog-count {
		font-family: var(--font-sans);
		font-size: 14px;
		font-weight: 600;
		color: var(--ink-500);
		margin: 10px 0 0;
	}

	.course-filter {
		grid-column: 1 / -1;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 10px;
		margin: 4px 0 24px;
	}
	.course-filter-pill {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		min-height: 40px;
		font-family: var(--font-sans);
		font-size: 13px;
		font-weight: 600;
		color: var(--ink-700);
		background: #fff;
		border: 1px solid var(--border-soft);
		border-radius: 999px;
		padding: 9px 18px;
		cursor: pointer;
		transition: color 160ms var(--ease-out), background 160ms var(--ease-out),
			border-color 160ms var(--ease-out);
	}
	.course-filter-pill:hover {
		color: var(--accent);
		border-color: var(--accent);
	}
	.course-filter-pill.is-active {
		color: var(--paper);
		background: var(--ink-900);
		border-color: var(--ink-900);
	}
	.course-filter-pill:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}
	.course-filter-num {
		font-size: 11px;
		font-weight: 700;
		opacity: 0.7;
		font-variant-numeric: tabular-nums;
	}

	/* Hidden state shared by the category filter and the collapse/expand. */
	.course-card.is-hidden {
		display: none;
	}

	.courses-cta--stack {
		flex-direction: column;
		gap: 16px;
		align-items: center;
	}
	[data-course-expand] {
		display: inline-flex;
		align-items: center;
		gap: 10px;
	}
	[data-course-expand] .course-expand-icon {
		transition: transform 200ms var(--ease-out);
	}
	[data-course-expand].is-expanded .course-expand-icon {
		transform: rotate(180deg);
	}
	.course-hub-link {
		font-family: var(--font-sans);
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent);
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}
	.course-hub-link:hover {
		text-decoration: underline;
	}
	.course-hub-link:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	@media (prefers-reduced-motion: reduce) {
		.learn-subnav-list a,
		.course-filter-pill,
		[data-course-expand] .course-expand-icon {
			transition: none;
		}
	}
</style>
