---
import SpeakingLayout from '../layouts/SpeakingLayout.astro';
import { reader } from '../lib/keystatic';
import { safeUrl } from '../lib/url';

const learn = await reader.singletons.learn.read();
if (!learn) {
	throw new Error('Missing learn content (src/content/learn/index.yaml)');
}

const {
	hero,
	newsletter,
	courses_section,
	courses,
	linkedin_resources_section,
	linkedin_resources,
} = learn;

const isExternal = (url: string) => /^https?:\/\//i.test(url);
---

<SpeakingLayout
	title="Lorraine K. Lee — Learn"
	description={hero.lead}
	activeId="learn"
>
	{/* ---------- Hero ---------- */}
	<section class="page-hero learn-hero">
		<div class="grid12 learn-hero-grid">
			<div class="learn-hero-copy fade-up">
				<div class="page-hero-eyebrow">
					<span class="dot"></span>
					<span class="eyebrow" style="color: var(--ink-500);">
						{hero.eyebrow}
					</span>
				</div>
				<h1>{hero.headline} <em>{hero.headline_accent}</em></h1>
			</div>
			<div class="learn-hero-aside fade-up" style="animation-delay: 80ms;">
				<p class="lead-large">{hero.lead}</p>
				<div class="learn-hero-cta-row">
					<a class="btn primary large" href="#course">
						Start the free course <span aria-hidden="true">&rarr;</span>
					</a>
					<a class="btn ghost" href="#courses">Browse courses</a>
				</div>
				<p class="learn-hero-trust">
					Join <strong>12,000+</strong> leaders learning with Lorraine.
				</p>
			</div>
		</div>

		<div class="learn-hero-rail-wrap" aria-label="Featured courses and resources">
			<ul class="learn-hero-rail reveal-stagger">
				<li>
					<a class="lh-card lh-card--feature" href="#course">
						<span class="lh-card-pill">Free · 5-day course</span>
						<h3 class="lh-card-title">
							From <em>Invisible</em> to Influential
						</h3>
						<p class="lh-card-desc">
							A free 5-day email course that helps you articulate your value
							and get visible to decision-makers.
						</p>
						<span class="lh-card-cta">
							Start the course <span aria-hidden="true">&rarr;</span>
						</span>
					</a>
				</li>
				<li>
					<div class="lh-card lh-card--stat">
						<span class="lh-card-stat-num">
							250K<span class="suffix">+</span>
						</span>
						<span class="lh-card-stat-label">
							Students taught on LinkedIn Learning
						</span>
					</div>
				</li>
				<li>
					<a class="lh-card lh-card--browse" href="#courses">
						<span class="lh-card-eyebrow">LinkedIn Learning</span>
						<h3 class="lh-card-title">{courses.length} on-demand courses</h3>
						<ul class="lh-card-list">
							{courses.slice(0, 3).map((c) => <li>{c.title}</li>)}
						</ul>
						<span class="lh-card-cta">
							Browse all <span aria-hidden="true">&rarr;</span>
						</span>
					</a>
				</li>
				{
					linkedin_resources?.map((r) => {
						const url = safeUrl(r.url) || '/contact';
						const external = isExternal(url);
						return (
							<li>
								<a
									class="lh-card lh-card--resource"
									href={url}
									target={external ? '_blank' : undefined}
									rel={external ? 'noopener noreferrer' : undefined}
								>
									<span class="lh-card-eyebrow">Free resource</span>
									<h3 class="lh-card-title">{r.label}</h3>
									<span class="lh-card-cta">
										{r.cta_label || 'Get it'}{' '}
										<span aria-hidden="true">&rarr;</span>
									</span>
								</a>
							</li>
						);
					})
				}
			</ul>
		</div>
	</section>

	{/* ---------- Newsletter lead block (mirrors home page Free Course section) ---------- */}
	<section id="course" class="course learn-newsletter">
		<div class="grid12 course-grid">
			<div class="course-copy">
				<div class="course-eyebrow">
					<span class="pill">{newsletter.eyebrow_pill}</span>
					<span>{newsletter.eyebrow_label}</span>
				</div>
				<h2 class="course-headline">
					{newsletter.headline} <em>{newsletter.headline_accent}</em>
				</h2>
				<p class="course-sub">{newsletter.body}</p>
				<ul class="course-bullets">
					{newsletter.bullets.map((day) => <li>{day}</li>)}
				</ul>
			</div>

			<div class="course-form">
				<div class="course-form-card">
					<form data-course-form>
						<span class="course-form-eyebrow">{newsletter.form_eyebrow}</span>
						<h3 class="course-form-title">
							{newsletter.form_title} <em>{newsletter.form_title_accent}</em>
						</h3>
						<label class="field-label" for="course-email">Email address</label>
						<input
							id="course-email"
							class="field"
							type="email"
							required
							placeholder="you@company.com"
						/>
						<button type="submit" class="btn yellow large btn-block">
							{newsletter.form_button_label} <span aria-hidden="true">&rarr;</span>
						</button>
						<div class="fineprint">{newsletter.form_fineprint}</div>
					</form>
					<div class="success" data-course-success hidden>
						<div class="check">
							<svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
								<polyline points="20 6 9 17 4 12"></polyline>
							</svg>
						</div>
						<div class="success-title">{newsletter.success_title}</div>
						<div
							class="success-sub"
							data-course-success-sub
							data-success-template={newsletter.success_subtitle_template}
						>
							Day 1 is on its way.
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	{/* ---------- LinkedIn Learning courses (secondary) ---------- */}
	<section class="section section--tight" id="courses">
		<div class="grid12">
			<div class="section-head section-head--center">
				<span class="eyebrow">{courses_section.eyebrow}</span>
				<h2>
					{courses_section.heading}{' '}
					<em>{courses_section.heading_accent}</em>
				</h2>
				{courses_section.lead && <p class="lead">{courses_section.lead}</p>}
			</div>

			<div class="course-grid-cards reveal-stagger">
				{
					courses.map((c) => {
						const url = c.url ?? '';
						const external = isExternal(url);
						const href = safeUrl(url) || '/contact';
						return (
							<a
								class="course-card"
								data-platform={c.platform}
								href={href}
								target={external ? '_blank' : undefined}
								rel={external ? 'noopener noreferrer' : undefined}
							>
								<div class="course-thumb">
									<div class="course-thumb-deco" aria-hidden="true">
										{c.glyph}
									</div>
									<span class="platform-tag">{c.platform}</span>
									<div class="play" aria-hidden="true">
										<svg viewBox="0 0 24 24" fill="currentColor">
											<path d="M8 5v14l11-7z" />
										</svg>
									</div>
									{c.duration && <span class="duration">{c.duration}</span>}
								</div>
								<div class="course-card-body">
									<h3>{c.title}</h3>
									<p class="course-desc">{c.description}</p>
									<span class="course-link">
										{external ? 'Watch course' : 'Learn more'}{' '}
										<span aria-hidden="true">&rarr;</span>
									</span>
								</div>
							</a>
						);
					})
				}
			</div>
		</div>
	</section>

	{/* ---------- LinkedIn lead-magnet resources ---------- */}
	{
		linkedin_resources?.length > 0 && (
			<section class="section section--tight">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{linkedin_resources_section.eyebrow}</span>
						<h2>
							{linkedin_resources_section.heading}{' '}
							<em>{linkedin_resources_section.heading_accent}</em>
						</h2>
						{linkedin_resources_section.lead && (
							<p class="lead">{linkedin_resources_section.lead}</p>
						)}
					</div>
					<div class="learn-resources reveal-stagger">
						{linkedin_resources.map((r) => {
							const url = safeUrl(r.url) || '/contact';
							const external = isExternal(url);
							return (
								<a
									class="resource-card"
									href={url}
									target={external ? '_blank' : undefined}
									rel={external ? 'noopener noreferrer' : undefined}
								>
									<span class="resource-label">{r.label}</span>
									{r.description && (
										<p class="resource-desc">{r.description}</p>
									)}
									<span class="resource-arrow">
										{r.cta_label || (external ? 'Open' : 'Download')}{' '}
										<span aria-hidden="true">&rarr;</span>
									</span>
								</a>
							);
						})}
					</div>
				</div>
			</section>
		)
	}
</SpeakingLayout>

<script>
	// --- Newsletter email form (mirrors home page free-course form) ---
	const form = document.querySelector<HTMLFormElement>('[data-course-form]');
	form?.addEventListener('submit', (e) => {
		e.preventDefault();
		if (!form.checkValidity()) {
			form.reportValidity();
			return;
		}
		const input = form.querySelector<HTMLInputElement>('#course-email');
		const email = input?.value.trim() ?? '';
		const success = document.querySelector<HTMLElement>('[data-course-success]');
		const sub = document.querySelector<HTMLElement>('[data-course-success-sub]');
		const template = sub?.dataset.successTemplate ?? 'Day 1 is on its way to {email}.';
		if (sub) sub.textContent = template.replace('{email}', email);
		form.setAttribute('hidden', '');
		success?.removeAttribute('hidden');
	});
</script>
