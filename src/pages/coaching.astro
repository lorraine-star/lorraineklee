---
import SpeakingLayout from '../layouts/SpeakingLayout.astro';
import PageHero from '../components/PageHero.astro';
import { reader } from '../lib/keystatic';
import { safeUrl } from '../lib/url';

const coaching = await reader.singletons.coaching.read();
if (!coaching) {
	throw new Error('Missing coaching content (src/content/coaching/index.yaml)');
}

const {
	hero,
	intro_section,
	intro_paragraphs,
	topics_section,
	topics,
	tiers_section,
	tiers,
	oneoff,
	audit,
	final_cta,
} = coaching;

const isExternal = (url: string) => /^https?:\/\//i.test(url);
const primaryCtaUrl = safeUrl(hero.primary_cta_url) || '/contact';
const secondaryCtaUrl = safeUrl(hero.secondary_cta_url) || '#tiers';
const auditCtaUrl = safeUrl(audit.cta_url) || '/contact';
const finalCtaUrl = safeUrl(final_cta.cta_url) || '/contact';
---

<SpeakingLayout
	title="Coaching | Lorraine K. Lee"
	description={hero.lead}
	activeId="coaching"
>
	{/* ---------- Hero (shared PageHero shell; copy + CTAs stay page-local) ---------- */}
	<PageHero
		center
		eyebrow={hero.eyebrow}
		headline={hero.headline}
		headlineAccent={hero.headline_accent}
		lead={hero.lead}
	>
		<div class="hero-cta-row">
			<a
				class="btn primary large"
				href={primaryCtaUrl}
				target={isExternal(primaryCtaUrl) ? '_blank' : undefined}
				rel={isExternal(primaryCtaUrl) ? 'noopener noreferrer' : undefined}
			>
				{hero.primary_cta_label} <span aria-hidden="true">&rarr;</span>
			</a>
			{
				hero.secondary_cta_label && (
					<a class="anchor-link" href={secondaryCtaUrl}>
						{hero.secondary_cta_label}{' '}
						<span class="arrow" aria-hidden="true">&rarr;</span>
					</a>
				)
			}
		</div>
	</PageHero>

	{/* ---------- Intro / story ---------- */}
	{
		intro_paragraphs?.length > 0 && (
			<section class="section section--tight section--cream">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{intro_section.eyebrow}</span>
						<h2>
							{intro_section.heading}{' '}
							<em>{intro_section.heading_accent}</em>
						</h2>
					</div>
					<div class="coach-intro fade-up">
						{intro_paragraphs.map((para) => (
							<p>{para}</p>
						))}
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Common topics ---------- */}
	{
		topics?.length > 0 && (
			<section class="section section--compact">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{topics_section.eyebrow}</span>
						<h2>
							{topics_section.heading}{' '}
							<em>{topics_section.heading_accent}</em>
						</h2>
						{topics_section.lead && (
							<p class="lead">{topics_section.lead}</p>
						)}
					</div>
					<ul class="coach-topics reveal-stagger">
						{topics.map((topic) => (
							<li class="coach-topic-item">
								<span class="coach-check" aria-hidden="true">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="20 6 9 17 4 12" />
									</svg>
								</span>
								<span>{topic}</span>
							</li>
						))}
					</ul>
				</div>
			</section>
		)
	}

	{/* ---------- Coaching tiers ---------- */}
	{
		tiers?.length > 0 && (
			<section class="section section--cream anchor-target" id="tiers">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{tiers_section.eyebrow}</span>
						<h2>
							{tiers_section.heading}{' '}
							<em>{tiers_section.heading_accent}</em>
						</h2>
						{tiers_section.lead && (
							<p class="lead">{tiers_section.lead}</p>
						)}
					</div>
					<div class="coach-tiers reveal-stagger">
						{tiers.map((tier) => (
							<article
								class:list={['coach-tier', { 'coach-tier--featured': tier.featured }]}
							>
								{tier.featured && (
									<span class="coach-tier-badge">Most popular</span>
								)}
								<header class="coach-tier-head">
									<h3 class="coach-tier-name">{tier.name}</h3>
									{tier.duration && (
										<span class="coach-tier-duration">{tier.duration}</span>
									)}
								</header>
								<div class="coach-tier-price">
									<span class="coach-tier-amount">{tier.price}</span>
									{tier.per_session_note && (
										<span class="coach-tier-note">
											{tier.per_session_note}
										</span>
									)}
								</div>
								{tier.summary && (
									<p class="coach-tier-summary">{tier.summary}</p>
								)}
								{tier.features?.length > 0 && (
									<ul class="coach-tier-features">
										{tier.features.map((feature) => (
											<li>
												<span class="coach-tier-check" aria-hidden="true">
													<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
														<polyline points="20 6 9 17 4 12" />
													</svg>
												</span>
												<span>{feature}</span>
											</li>
										))}
									</ul>
								)}
								{tier.footnote && (
									<p class="coach-tier-footnote">{tier.footnote}</p>
								)}
							</article>
						))}
					</div>
					{
						oneoff?.price && (
							<div class="coach-oneoff fade-up">
								<div class="coach-oneoff-copy">
									<h3 class="coach-oneoff-label">{oneoff.label}</h3>
									{oneoff.description && <p>{oneoff.description}</p>}
								</div>
								<span class="coach-oneoff-price">{oneoff.price}</span>
							</div>
						)
					}
				</div>
			</section>
		)
	}

	{/* ---------- Async LinkedIn profile audit ---------- */}
	{
		audit?.show && (
			<section class="section section--tight anchor-target" id="linkedin-audit">
				<div class="grid12">
					<div class="coach-audit fade-up">
						<div class="coach-audit-copy">
							<span class="eyebrow">{audit.eyebrow}</span>
							<h2>
								{audit.heading} <em>{audit.heading_accent}</em>
							</h2>
							{audit.description && <p class="coach-audit-desc">{audit.description}</p>}
							{audit.features?.length > 0 && (
								<ul class="coach-audit-features">
									{audit.features.map((feature) => (
										<li>
											<span class="coach-tier-check" aria-hidden="true">
												<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
													<polyline points="20 6 9 17 4 12" />
												</svg>
											</span>
											<span>{feature}</span>
										</li>
									))}
								</ul>
							)}
						</div>
						<div class="coach-audit-aside">
							{audit.price && (
								<span class="coach-audit-price">{audit.price}</span>
							)}
							{audit.price_note && (
								<span class="coach-audit-pricenote">{audit.price_note}</span>
							)}
							<a
								class="btn primary"
								href={auditCtaUrl}
								target={isExternal(auditCtaUrl) ? '_blank' : undefined}
								rel={isExternal(auditCtaUrl) ? 'noopener noreferrer' : undefined}
							>
								{audit.cta_label} <span aria-hidden="true">&rarr;</span>
							</a>
						</div>
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Final CTA ---------- */}
	<section class="section">
		<div class="grid12">
			<div class="final-cta">
				<div class="final-cta-inner">
					<span class="eyebrow">{final_cta.eyebrow}</span>
					<h2>
						{final_cta.heading} <em>{final_cta.heading_accent}</em>
					</h2>
					<p>{final_cta.body}</p>
					<a
						class="btn yellow large"
						href={finalCtaUrl}
						target={isExternal(finalCtaUrl) ? '_blank' : undefined}
						rel={isExternal(finalCtaUrl) ? 'noopener noreferrer' : undefined}
					>
						{final_cta.cta_label} <span aria-hidden="true">&rarr;</span>
					</a>
				</div>
			</div>
		</div>
	</section>
</SpeakingLayout>

<style>
	/* Intro — centered narrative column. */
	.coach-intro {
		grid-column: 1 / -1;
		max-width: 760px;
		margin: clamp(20px, 2.4vw, 30px) auto 0;
		display: grid;
		gap: 18px;
	}
	.coach-intro p {
		font-family: var(--font-sans);
		font-size: 17px;
		line-height: 1.7;
		color: var(--ink-700);
		margin: 0;
		text-align: center;
	}

	/* Common topics — two-column checklist. */
	.coach-topics {
		grid-column: 1 / -1;
		list-style: none;
		margin: clamp(20px, 2.4vw, 30px) auto 0;
		padding: 0;
		max-width: 900px;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(360px, 100%), 1fr));
		gap: 14px clamp(24px, 4vw, 56px);
	}
	.coach-topic-item {
		display: flex;
		align-items: flex-start;
		gap: 14px;
		font-family: var(--font-sans);
		font-size: 16.5px;
		line-height: 1.5;
		color: var(--ink-700);
	}
	.coach-check {
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 26px;
		height: 26px;
		border-radius: 999px;
		background: var(--brand-yellow-500);
		color: var(--ink-900);
		margin-top: 1px;
	}
	.coach-check svg {
		width: 15px;
		height: 15px;
	}

	/* Coaching tiers — pricing cards. */
	.coach-tiers {
		grid-column: 1 / -1;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
		gap: clamp(16px, 2vw, 24px);
		margin-top: clamp(24px, 3vw, 36px);
		align-items: start;
	}
	.coach-tier {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 18px;
		background: var(--bg-card);
		border: 1px solid var(--border-soft);
		border-radius: var(--radius-2xl);
		padding: clamp(26px, 3vw, 36px);
		box-shadow: 0 18px 44px -34px rgba(14, 21, 48, 0.4);
		height: 100%;
	}
	.coach-tier--featured {
		border-color: var(--brand-yellow-500);
		box-shadow: 0 26px 60px -34px rgba(14, 21, 48, 0.55);
	}
	.coach-tier-badge {
		position: absolute;
		top: 0;
		right: clamp(26px, 3vw, 36px);
		transform: translateY(-50%);
		background: var(--brand-yellow-500);
		color: var(--ink-900);
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 12px;
		letter-spacing: 0.04em;
		padding: 5px 12px;
		border-radius: 999px;
	}
	.coach-tier-head {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: 8px;
	}
	.coach-tier-name {
		font-family: var(--font-serif);
		font-weight: 600;
		font-size: clamp(22px, 2.4vw, 27px);
		line-height: 1.1;
		letter-spacing: -0.01em;
		color: var(--ink-900);
		margin: 0;
	}
	.coach-tier-duration {
		font-family: var(--font-mono, monospace);
		font-size: 12.5px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
	}
	.coach-tier-price {
		display: flex;
		flex-direction: column;
		gap: 2px;
		padding-bottom: 18px;
		border-bottom: 1px solid var(--border-soft);
	}
	.coach-tier-amount {
		font-family: var(--font-serif);
		font-weight: 700;
		font-size: clamp(30px, 3.4vw, 38px);
		line-height: 1;
		color: var(--ink-900);
	}
	.coach-tier-note {
		font-family: var(--font-sans);
		font-size: 13.5px;
		color: var(--ink-500);
	}
	.coach-tier-summary {
		font-family: var(--font-sans);
		font-size: 15px;
		line-height: 1.6;
		color: var(--ink-700);
		margin: 0;
	}
	.coach-tier-features {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 11px;
	}
	.coach-tier-features li {
		display: flex;
		align-items: flex-start;
		gap: 11px;
		font-family: var(--font-sans);
		font-size: 14.5px;
		line-height: 1.5;
		color: var(--ink-700);
	}
	.coach-tier-check {
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 20px;
		height: 20px;
		border-radius: 999px;
		background: var(--brand-yellow-500);
		color: var(--ink-900);
		margin-top: 1px;
	}
	.coach-tier-check svg {
		width: 12px;
		height: 12px;
	}
	.coach-tier-footnote {
		font-family: var(--font-sans);
		font-size: 12.5px;
		line-height: 1.5;
		color: var(--ink-500);
		margin: auto 0 0;
		padding-top: 6px;
	}

	/* One-off session — single highlighted row. */
	.coach-oneoff {
		grid-column: 1 / -1;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 16px 28px;
		margin-top: clamp(20px, 3vw, 28px);
		padding: clamp(22px, 2.6vw, 30px) clamp(24px, 3vw, 36px);
		background: var(--paper-deep);
		border: 1px solid var(--border-soft);
		border-radius: var(--radius-2xl);
	}
	.coach-oneoff-copy {
		max-width: 640px;
	}
	.coach-oneoff-label {
		font-family: var(--font-serif);
		font-weight: 600;
		font-size: clamp(19px, 2vw, 23px);
		color: var(--ink-900);
		margin: 0 0 6px;
	}
	.coach-oneoff-copy p {
		font-family: var(--font-sans);
		font-size: 15px;
		line-height: 1.6;
		color: var(--ink-700);
		margin: 0;
	}
	.coach-oneoff-price {
		font-family: var(--font-serif);
		font-weight: 700;
		font-size: clamp(24px, 2.8vw, 30px);
		color: var(--ink-900);
		white-space: nowrap;
	}

	/* Async LinkedIn audit — split offer card. */
	.coach-audit {
		grid-column: 1 / -1;
		display: grid;
		grid-template-columns: 1.6fr 1fr;
		gap: clamp(24px, 4vw, 56px);
		align-items: center;
		background: var(--bg-card);
		border: 1px solid var(--border-soft);
		border-radius: var(--radius-2xl);
		padding: clamp(28px, 4vw, 48px);
		box-shadow: 0 18px 44px -34px rgba(14, 21, 48, 0.4);
	}
	.coach-audit-copy .eyebrow {
		display: block;
		margin-bottom: 10px;
	}
	.coach-audit-copy h2 {
		margin: 0 0 14px;
	}
	.coach-audit-desc {
		font-family: var(--font-sans);
		font-size: 16px;
		line-height: 1.6;
		color: var(--ink-700);
		margin: 0 0 20px;
		max-width: 56ch;
	}
	.coach-audit-features {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 11px;
	}
	.coach-audit-features li {
		display: flex;
		align-items: flex-start;
		gap: 11px;
		font-family: var(--font-sans);
		font-size: 15px;
		line-height: 1.5;
		color: var(--ink-700);
	}
	.coach-audit-aside {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 8px;
		padding: clamp(22px, 2.6vw, 30px);
		background: var(--paper-deep);
		border: 1px solid var(--border-soft);
		border-radius: var(--radius-2xl);
	}
	.coach-audit-price {
		font-family: var(--font-serif);
		font-weight: 700;
		font-size: clamp(32px, 4vw, 44px);
		line-height: 1;
		color: var(--ink-900);
	}
	.coach-audit-pricenote {
		font-family: var(--font-sans);
		font-size: 13.5px;
		color: var(--ink-500);
		margin-bottom: 8px;
	}
	@media (max-width: 720px) {
		.coach-audit {
			grid-template-columns: 1fr;
			align-items: stretch;
		}
	}
</style>
