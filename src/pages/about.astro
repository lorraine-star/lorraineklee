---
import SpeakingLayout from '../layouts/SpeakingLayout.astro';
import TrustAsSeenIn from '../components/TrustAsSeenIn.astro';
import { reader, renderMarkdoc } from '../lib/keystatic';
import { safeUrl } from '../lib/url';

const about = await reader.singletons.about.read();
if (!about) {
	throw new Error('Missing about content (src/content/about/index.mdoc)');
}

const {
	hero,
	story_section,
	story_facts,
	career_section,
	career_highlights,
	credibility_section,
	credibility,
	final_ctas,
} = about;

const bodyHtml = await renderMarkdoc(about.body);
---

<SpeakingLayout
	title={about.seo_title || "Lorraine K. Lee | About"}
	description={about.seo_description || hero.lead}
	activeId="about"
>
	{/* ---------- Hero ---------- */}
	<section class="page-hero">
		<div class="grid12 page-hero-grid">
			<div class="page-hero-copy fade-up">
				<div class="page-hero-eyebrow">
					<span class="dot"></span>
					<span class="eyebrow" style="color: var(--ink-500);">
						{hero.eyebrow}
					</span>
				</div>
				<h1>{hero.headline} <em>{hero.headline_accent}</em></h1>
				<p class="lead-large">{hero.lead}</p>
				<div class="hero-cta-row">
					<a class="btn primary large" href={safeUrl(hero.primary_cta_url)}>
						{hero.primary_cta_label} <span aria-hidden="true">&rarr;</span>
					</a>
					<a class="btn outline" href={safeUrl(hero.secondary_cta_url)}>
						{hero.secondary_cta_label}
					</a>
				</div>
			</div>
			<div class="page-hero-aside fade-up" style="animation-delay: 120ms;">
				<div class="about-hero-photo">
					<div class="photo-mask">
						<img src={hero.headshot} alt={hero.headshot_alt} />
					</div>
					<div class="floating-card">
						<div class="num">{hero.stat_value}</div>
						<div class="lbl">{hero.stat_label}</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	{/* ---------- Story ---------- */}
	<section class="section section--tight section--cream" id="bio">
		<div class="grid12">
			<div class="section-head section-head--center">
				<span class="eyebrow">{story_section.eyebrow}</span>
				<h2>
					{story_section.heading} <em>{story_section.heading_accent}</em>
				</h2>
			</div>
			<div class="bio-body reveal" set:html={bodyHtml} />
			<div class="bio-aside reveal">
				{
					story_facts.map((f) => (
						<div class="aside-item">
							<div class="aside-k">{f.label}</div>
							<div class="aside-v">{f.value}</div>
						</div>
					))
				}
			</div>
		</div>
	</section>

	{/* ---------- Career highlights ---------- */}
	<section class="section section--tight" id="awards">
		<div class="grid12">
			<div class="section-head section-head--center">
				<span class="eyebrow">{career_section.eyebrow}</span>
				<h2>
					{career_section.heading} <em>{career_section.heading_accent}</em>
				</h2>
			</div>
			<div class="highlight-grid reveal-stagger">
				{
					career_highlights.map((h) => (
						<div class="highlight-card">
							{h.logo && (
								<div class="highlight-logo">
									<img src={h.logo} alt={h.logo_alt || h.value} />
								</div>
							)}
							<div class="eyebrow">{h.eyebrow}</div>
							<div class="highlight-value">{h.value}</div>
							<div class="highlight-label">{h.label}</div>
							{h.attribution && (
								<div class="highlight-attribution">{h.attribution}</div>
							)}
						</div>
					))
				}
			</div>
		</div>
	</section>

	{/* ---------- As seen in (shared global section) ---------- */}
	<TrustAsSeenIn />

	{/* ---------- Credibility ---------- */}
	<section class="section section--tight section--cream" id="credibility">
		<div class="grid12">
			<div class="section-head section-head--center">
				<span class="eyebrow">{credibility_section.eyebrow}</span>
				<h2>
					{credibility_section.heading}{' '}
					<em>{credibility_section.heading_accent}</em>
				</h2>
			</div>
			<div class="credibility-grid reveal-stagger">
				{
					credibility.map((c) => (
						<div class="credibility-card">
							<div class="credibility-card-body">
								<h3>{c.title}</h3>
								<p>{c.detail}</p>
							</div>
							{c.logos && c.logos.length > 0 && (
								<div
									class:list={[
										'credibility-logos',
										`credibility-logos--${c.logos.length}`,
									]}
								>
									{c.logos.map((l) => {
										const key = l.src.split('/').pop()?.replace(/\.[^.]+$/, '') ?? '';
										return (
											<span class:list={['cred-logo-frame', `cred-logo-frame--${key}`]}>
												<img
													class:list={['cred-logo', `cred-logo--${key}`]}
													src={l.src}
													alt={l.alt}
													loading="lazy"
													decoding="async"
												/>
											</span>
										);
									})}
								</div>
							)}
						</div>
					))
				}
			</div>
		</div>
	</section>

	{/* ---------- Final CTAs ---------- */}
	<section class="section">
		<div class="grid12">
			<div class="about-final reveal-stagger">
				{
					final_ctas.map((cta) => (
						<a
							class:list={['about-final-card', { dark: cta.dark }]}
							href={safeUrl(cta.cta_url)}
						>
							<span class="eyebrow">{cta.eyebrow}</span>
							<h3>
								{cta.heading} <em>{cta.heading_accent}</em>
							</h3>
							<p class="label-line">{cta.body}</p>
							<span class="arrow">
								{cta.cta_label} <span aria-hidden="true">&rarr;</span>
							</span>
						</a>
					))
				}
			</div>
		</div>
	</section>
</SpeakingLayout>
