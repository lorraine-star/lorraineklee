---
import Layout from '../layouts/Layout.astro';
import { reader, renderMarkdoc } from '../lib/keystatic';
import { safeUrl } from '../lib/url';

const contact = await reader.singletons.contact.read();
if (!contact) {
	throw new Error('Missing contact content (src/content/contact/index.mdoc)');
}

const copyHtml = await renderMarkdoc(contact.copy);

// contact_email is free-text in the CMS; only render the mailto link when it
// is a well-formed address so a malformed value cannot ship a broken link.
const email = contact.contact_email?.trim() ?? '';
const hasValidEmail = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
---

<Layout title="Contact | Lorraine K. Lee">
	<section class="mx-auto max-w-3xl px-6 py-20">
		<h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">
			{contact.headline}
		</h1>

		<div
			class="mt-8 space-y-4 text-lg leading-relaxed text-neutral-700"
			set:html={copyHtml}
		/>

		{
			hasValidEmail && (
				<p class="mt-8">
					<a
						href={`mailto:${email}`}
						class="text-lg underline underline-offset-4 hover:text-neutral-600"
					>
						{email}
					</a>
				</p>
			)
		}

		{
			contact.social_links.length > 0 && (
				<ul class="mt-8 flex flex-wrap gap-3 text-sm">
					{contact.social_links.map((social) => (
						<li>
							{social.url ? (
								<a
									href={safeUrl(social.url)}
									class="rounded-full border border-neutral-300 px-4 py-2 transition-colors hover:border-neutral-900"
								>
									{social.platform}
								</a>
							) : (
								<span class="rounded-full border border-neutral-200 px-4 py-2 text-neutral-400">
									{social.platform}
								</span>
							)}
						</li>
					))}
				</ul>
			)
		}
	</section>
</Layout>
