---
import SpeakingLayout from '../layouts/SpeakingLayout.astro';
import { reader } from '../lib/keystatic';
import { safeUrl } from '../lib/url';
import { iconFor } from '../lib/social';

const contact = await reader.singletons.contact.read();
if (!contact) {
	throw new Error('Missing contact content (src/content/contact/index.yaml)');
}

const {
	eyebrow,
	headline,
	headline_accent,
	lead,
	brand_deals_label,
	press_label,
	follow_label,
	press_email,
	brand_deals_email,
	typeform_id,
	social_links,
} = contact;

const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
const press = press_email?.trim() ?? '';
const hasPress = EMAIL_RE.test(press);
const brandDeals = brand_deals_email?.trim() ?? '';
const hasBrandDeals = EMAIL_RE.test(brandDeals);

const formId = typeform_id?.trim() ?? '';

const links = (social_links ?? []).filter((s) => s.url);
---

<SpeakingLayout title={contact.seo_title || "Lorraine K. Lee | Contact"} description={lead} activeId="contact">
	<section class="section section--tight">
		<div class="grid12">
			<div class="contact-grid">
				{/* ---------- Left: copy, direct contact, social ---------- */}
				<aside class="contact-side fade-up">
					<div class="page-hero-eyebrow">
						<span class="dot"></span>
						<span class="eyebrow" style="color: var(--ink-500);">{eyebrow}</span>
					</div>
					<h1>{headline} <em>{headline_accent}</em></h1>
					<p class="contact-lead">{lead}</p>

					{
						(hasBrandDeals || hasPress) && (
							<div class="contact-direct">
								{hasBrandDeals && (
									<div class="row">
										<span class="lbl">{brand_deals_label || 'Brand deals and partnerships'}</span>
										<a href={`mailto:${brandDeals}`}>{brandDeals}</a>
									</div>
								)}
								{hasPress && (
									<div class="row">
										<span class="lbl">{press_label || 'Press'}</span>
										<a href={`mailto:${press}`}>{press}</a>
									</div>
								)}
							</div>
						)
					}

					{
						links.length > 0 && (
							<>
								<div class="contact-follow">{follow_label || 'Follow along'}</div>
								<div class="social-row">
									{links.map((s) => (
										<a
											class="social-btn"
											href={safeUrl(s.url)}
											aria-label={s.platform}
											target="_blank"
											rel="noopener noreferrer"
											set:html={iconFor(s.platform)}
										/>
									))}
								</div>
							</>
						)
					}
				</aside>

				{/* ---------- Right: Typeform embed ---------- */}
				<div class="contact-form-card fade-up" style="animation-delay: 120ms;">
					{
						formId ? (
							<div
								data-tf-widget={formId}
								data-tf-iframe-props={`title=Contact Lorraine K. Lee`}
								data-tf-medium="snippet"
								data-tf-opacity="100"
								data-tf-on-submit="onContactSubmit"
								style="width:100%;min-height:640px;"
							/>
						) : (
							<p class="contact-fallback">
								{hasBrandDeals || hasPress ? (
									<>
										The contact form isn't connected yet. Email{' '}
										{hasBrandDeals && (
											<a href={`mailto:${brandDeals}`}>{brandDeals}</a>
										)}
										{hasBrandDeals && hasPress && ' or '}
										{hasPress && <a href={`mailto:${press}`}>{press}</a>}{' '}
										and I'll get back to you.
									</>
								) : (
									"The contact form isn't connected yet — please check back soon."
								)}
							</p>
						)
					}
				</div>
			</div>
		</div>
	</section>

	{
		formId && (
			<>
				{/*
				 * Typeform calls this (by name, via data-tf-on-submit) on a
				 * successful contact-form submission. It must live on window so the
				 * embed can find it. Routes the GA4 key event (CLI-51) through
				 * window.trackEvent, which is a no-op unless the visitor accepted
				 * analytics cookies — so a decline still blocks it. Defined before
				 * embed.js loads so the callback is registered in time.
				 */}
				<script is:inline define:vars={{ formId }}>
					window.onContactSubmit = function () {
						if (typeof window.trackEvent === 'function') {
							window.trackEvent('contact_submit', { form_id: formId });
						}
					};
				</script>
				<script is:inline src="//embed.typeform.com/next/embed.js" async />
			</>
		)
	}
</SpeakingLayout>
