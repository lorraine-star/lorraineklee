---
import SpeakingLayout from '../layouts/SpeakingLayout.astro';
import { reader } from '../lib/keystatic';
import { safeUrl } from '../lib/url';

const contact = await reader.singletons.contact.read();
if (!contact) {
	throw new Error('Missing contact content (src/content/contact/index.yaml)');
}

const {
	eyebrow,
	headline,
	headline_accent,
	lead,
	contact_email,
	press_email,
	form_heading,
	inquiry_types,
	response_note,
	success_heading,
	success_body,
	social_links,
} = contact;

const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
const email = contact_email?.trim() ?? '';
const hasEmail = EMAIL_RE.test(email);
const press = press_email?.trim() ?? '';
const hasPress = EMAIL_RE.test(press);

// Formspree endpoint id — supplied via the PUBLIC_FORMSPREE_ID env var so the
// real form can be dropped in without a code change. Empty until configured.
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID ?? '';

// Inline SVG markup for known social platforms; matched case-insensitively.
const socialIcons: Record<string, string> = {
	linkedin:
		'<svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>',
	x: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
	twitter:
		'<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
	instagram:
		'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>',
	youtube:
		'<svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.121 2.136c1.872.505 9.377.505 9.377.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.546 15.568V8.432L15.818 12l-6.272 3.568z"/></svg>',
};
const fallbackIcon =
	'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>';
const iconFor = (platform: string) =>
	socialIcons[platform.trim().toLowerCase()] ?? fallbackIcon;

const links = (social_links ?? []).filter((s) => s.url);
const formAction = formspreeId ? `https://formspree.io/f/${formspreeId}` : '';
---

<SpeakingLayout title="Lorraine K. Lee — Contact" description={lead} activeId="contact">
	<section class="section">
		<div class="grid12">
			<div class="contact-grid">
				{/* ---------- Left: copy, direct contact, social ---------- */}
				<aside class="contact-side fade-up">
					<div class="page-hero-eyebrow">
						<span class="dot"></span>
						<span class="eyebrow" style="color: var(--ink-500);">{eyebrow}</span>
					</div>
					<h1>{headline} <em>{headline_accent}</em></h1>
					<p class="contact-lead">{lead}</p>

					<div class="contact-direct">
						{
							hasEmail && (
								<div class="row">
									<span class="lbl">Email</span>
									<a href={`mailto:${email}`}>{email}</a>
								</div>
							)
						}
						<div class="row">
							<span class="lbl">Speaking</span>
							<a href="/speaking">Booking inquiries &rarr;</a>
						</div>
						{
							hasPress && (
								<div class="row">
									<span class="lbl">Press</span>
									<a href={`mailto:${press}`}>{press}</a>
								</div>
							)
						}
					</div>

					{
						links.length > 0 && (
							<>
								<div class="contact-follow">Follow along</div>
								<div class="social-row">
									{links.map((s) => (
										<a
											class="social-btn"
											href={safeUrl(s.url)}
											aria-label={s.platform}
											target="_blank"
											rel="noopener noreferrer"
											set:html={iconFor(s.platform)}
										/>
									))}
								</div>
							</>
						)
					}
				</aside>

				{/* ---------- Right: form ---------- */}
				<div class="contact-form-card fade-up" style="animation-delay: 120ms;">
					<form
						id="contact-form"
						action={formAction}
						method="POST"
						novalidate
					>
						<span class="eyebrow form-eyebrow">Send a message</span>
						<h2>{form_heading}</h2>

						<div class="form-error-banner" id="form-error" hidden role="alert">
							<span aria-hidden="true">&#9888;</span>
							<span id="form-error-text"></span>
						</div>

						<div class="row-2">
							<div class="field-group">
								<label for="name">Your name</label>
								<input
									id="name"
									name="name"
									type="text"
									autocomplete="name"
									placeholder="Jane Reyes"
								/>
								<div class="field-error" id="error-name" hidden></div>
							</div>
							<div class="field-group">
								<label for="email">Email</label>
								<input
									id="email"
									name="email"
									type="email"
									autocomplete="email"
									placeholder="jane@company.com"
								/>
								<div class="field-error" id="error-email" hidden></div>
							</div>
						</div>

						<div class="field-group">
							<label for="inquiry">Inquiry type</label>
							<select id="inquiry" name="inquiry">
								<option value="">Select one&hellip;</option>
								{
									(inquiry_types ?? []).map((t) => (
										<option value={t}>{t}</option>
									))
								}
							</select>
							<div class="field-error" id="error-inquiry" hidden></div>
						</div>

						<div class="field-group">
							<label for="message">Tell me about it</label>
							<textarea
								id="message"
								name="message"
								placeholder="Event date, audience, location, format, and what you'd like the room to leave with."
							></textarea>
							<span class="char-counter" id="char-counter" hidden></span>
							<div class="field-error" id="error-message" hidden></div>
						</div>

						{/* Honeypot — hidden from people, catches bots */}
						<div aria-hidden="true" style="position:absolute;left:-9999px;" tabindex="-1">
							<label for="company">Company</label>
							<input id="company" name="_gotcha" type="text" tabindex="-1" autocomplete="off" />
						</div>
						<input type="hidden" name="_subject" value="New contact enquiry — lorraineklee.com" />

						<div class="submit-row">
							<p class="submit-note">{response_note}</p>
							<button type="submit" class="btn primary large" id="contact-submit">
								Send message <span aria-hidden="true">&rarr;</span>
							</button>
						</div>
					</form>

					<div class="contact-success" id="contact-success" hidden aria-live="polite">
						<div class="check" aria-hidden="true">
							<svg viewBox="0 0 24 24">
								<polyline
									points="4 13 9 18 20 6"
									stroke-linecap="round"
									stroke-linejoin="round"
								></polyline>
							</svg>
						</div>
						<h3>{success_heading}</h3>
						<p id="contact-success-body"></p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<script
		is:inline
		define:vars={{ formAction, successBody: success_body, contactEmail: email }}
	>
		(() => {
			const form = document.getElementById('contact-form');
			if (!form) return;

			const MSG_MIN = 10;
			const MSG_MAX = 1200;
			const EMAIL_RE = /^\S+@\S+\.\S+$/;

			const submitBtn = document.getElementById('contact-submit');
			const submitLabel = submitBtn.innerHTML;
			const banner = document.getElementById('form-error');
			const bannerText = document.getElementById('form-error-text');
			const counter = document.getElementById('char-counter');
			const message = document.getElementById('message');

			const fields = ['name', 'email', 'inquiry', 'message'];

			const escapeHtml = (s) =>
				String(s).replace(
					/[&<>"']/g,
					(c) =>
						({
							'&': '&amp;',
							'<': '&lt;',
							'>': '&gt;',
							'"': '&quot;',
							"'": '&#39;',
						})[c]
				);

			const setError = (key, msg) => {
				const input = document.getElementById(key);
				const box = document.getElementById('error-' + key);
				if (msg) {
					box.textContent = '⚠ ' + msg;
					box.hidden = false;
					input.setAttribute('aria-invalid', 'true');
				} else {
					box.hidden = true;
					box.textContent = '';
					input.removeAttribute('aria-invalid');
				}
			};

			const showBanner = (msg) => {
				bannerText.textContent = msg;
				banner.hidden = false;
			};
			const hideBanner = () => {
				banner.hidden = true;
			};

			// Live-clear a field's error as the visitor fixes it.
			fields.forEach((key) => {
				document
					.getElementById(key)
					.addEventListener('input', () => setError(key, ''));
			});

			// Character counter for the message field.
			const updateCounter = () => {
				const len = message.value.length;
				if (len === 0) {
					counter.hidden = true;
					return;
				}
				counter.hidden = false;
				counter.textContent = len + ' / ' + MSG_MAX;
				counter.classList.toggle('over', len > MSG_MAX);
			};
			message.addEventListener('input', updateCounter);

			const validate = () => {
				const data = {
					name: document.getElementById('name').value,
					email: document.getElementById('email').value,
					inquiry: document.getElementById('inquiry').value,
					message: document.getElementById('message').value,
				};
				const errs = {};
				if (!data.name.trim()) errs.name = 'Required';
				if (!EMAIL_RE.test(data.email)) errs.email = 'Valid email required';
				if (!data.inquiry) errs.inquiry = 'Pick one';
				if (data.message.trim().length < MSG_MIN)
					errs.message = 'A few more words please';
				if (data.message.length > MSG_MAX)
					errs.message = 'Too long, keep it under ' + MSG_MAX + ' characters';
				fields.forEach((key) => setError(key, errs[key] || ''));
				return { ok: Object.keys(errs).length === 0, errs, data };
			};

			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				hideBanner();
				const { ok, errs, data } = validate();
				if (!ok) {
					const first = fields.find((k) => errs[k]);
					if (first) document.getElementById(first).focus();
					return;
				}

				if (!form.getAttribute('action')) {
					showBanner(
						'The contact form is not connected yet. Please email ' +
							(contactEmail || 'us') +
							' directly.'
					);
					return;
				}

				submitBtn.disabled = true;
				submitBtn.textContent = 'Sending…';

				try {
					const res = await fetch(form.getAttribute('action'), {
						method: 'POST',
						body: new FormData(form),
						headers: { Accept: 'application/json' },
					});
					if (!res.ok) throw new Error('Bad response ' + res.status);

					const firstName = data.name.trim().split(/\s+/)[0];
					document.getElementById('contact-success-body').innerHTML = escapeHtml(
						successBody
					)
						.replace(/\{name\}/g, escapeHtml(firstName))
						.replace(
							/\{email\}/g,
							'<strong>' + escapeHtml(data.email.trim()) + '</strong>'
						);
					form.hidden = true;
					document.getElementById('contact-success').hidden = false;
				} catch (err) {
					console.error('Contact form submission failed:', err);
					submitBtn.disabled = false;
					submitBtn.innerHTML = submitLabel;
					showBanner(
						'Something went wrong sending your message. Please try again, or email ' +
							(contactEmail || 'us') +
							' directly.'
					);
				}
			});
		})();
	</script>
</SpeakingLayout>
