---
/*
 * ┌────────────────────────────────────────────────────────────────┐
 * │  GLOBAL SECTION REGISTRY                                       │
 * │                                                                │
 * │  The following sections are SHARED across the site. Import the │
 * │  canonical component when another page needs one. Do not       │
 * │  redesign in isolation.                                        │
 * │  Search for `data-global-section="<id>"` to find each one:     │
 * │                                                                │
 * │    • trust-as-seen-in   - press marquee (TrustAsSeenIn.astro)  │
 * │    • testimonials       - client carousel (Testimonials.astro) │
 * │    • student-testimonials - student reviews                    │
 * │      (StudentTestimonials.astro)                               │
 * │    • book-promo         - "The Book" promo (BookPromo.astro)   │
 * │    • site-footer        - shared footer + socials (Footer.astro)│
 * │                                                                │
 * │  Coordinate edits to these via Linear so parallel worktrees    │
 * │  don't drift.                                                  │
 * └────────────────────────────────────────────────────────────────┘
 */
import HomeLayout from '../layouts/HomeLayout.astro';
import EditorialNav from '../components/editorial/EditorialNav.astro';
import BookPromo from '../components/BookPromo.astro';
import TrustAsSeenIn from '../components/TrustAsSeenIn.astro';
import Testimonials from '../components/Testimonials.astro';
import Footer from '../components/Footer.astro';
import { reader } from '../lib/keystatic';

const home = await reader.singletons.home.read();
if (!home) {
  throw new Error('Missing home content (src/content/home/index.yaml)');
}
const {
  hero,
  primary_cta,
  secondary_cta,
  tertiary_cta,
  four_ways,
  banner,
  free_course,
  course_popup,
  testimonials_section,
} = home;
const heroImage = hero?.image ?? '/images/v1/lorraine-hero-home.webp';

// Split a multi-line label so manual line breaks survive as <br>.
const splitLines = (value: string | null | undefined) =>
  (value ?? '').split('\n');

// Announcement banner (home-specific; links to the on-page #course section).
// Editable via the home singleton; hidden when `enabled` is false.
const showBanner = banner?.enabled !== false;

// Hero proof stats (250k+, #1). Editable via the home singleton; fall back to
// the original copy when unset.
const heroMeta =
  hero?.meta && hero.meta.length
    ? hero.meta
    : [
        { value: '250k+', label: 'students taught\non LinkedIn Learning' },
        { value: '#1', label: 'Amazon bestseller\nUnforgettable Presence®' },
      ];
const photoStat = hero?.photo_stat;

// "Four ways into the work" cards. Heading and blurbs are editable via the home
// singleton (CLI-153); the number of cards, their order, numbering, and links
// stay fixed here. Fall back to the original copy if a field is left blank.
const fourWays = [
  { n: '01', label: four_ways?.column_1?.heading || 'Speaking', desc: four_ways?.column_1?.blurb || 'Keynotes built around what your team actually needs to hear.', href: '/speaking' },
  { n: '02', label: four_ways?.column_2?.heading || 'Unforgettable Presence®', desc: four_ways?.column_2?.blurb || 'The book leadership programs already assign.', href: '/book' },
  { n: '03', label: four_ways?.column_3?.heading || 'Courses', desc: four_ways?.column_3?.blurb || 'On-demand training. 250,000+ students on LinkedIn Learning.', href: '/learn' },
  { n: '04', label: four_ways?.column_4?.heading || 'Custom programs', desc: four_ways?.column_4?.blurb || 'Cohort intensives for managers and high-potentials.', href: '/contact' },
];

const courseDays =
  free_course?.bullets && free_course.bullets.length
    ? free_course.bullets
    : [
        'Day 1 · Articulate your value so people actually listen',
        'Day 2 · Show up on LinkedIn so opportunities come to you',
        'Day 3 · Get known by the people who decide promotions',
        'Day 4 · Position yourself as the obvious choice',
        'Day 5 · Stay consistent without burning out',
      ];

// Popup CTA target: editable (keep the UTM params for tracking), with the
// original UTM-tagged link as the fallback.
const courseHref =
  course_popup?.cta_url ||
  '/from-invisible-to-influential?utm_source=lorraineklee_site&utm_medium=popup&utm_campaign=from_invisible_to_influential&utm_content=scroll_modal_v1';
---

<HomeLayout
  title={home.seo_title || "Lorraine K. Lee"}
  description={home.seo_description || "Keynotes, workshops, and coaching that help your managers and high-potentials stop being the best-kept secret at work."}
>
  <div class="shell variant-editorial">
    {/* ---------- Banner ---------- */}
    {
      showBanner && (
        <div class="banner" id="site-banner">
          <div class="banner-inner">
            <a class="banner-link" href={banner?.href || '#course'}>
              <span class="pre-mobile-hide">{banner?.prefix ?? 'From'}</span>
              <strong>{banner?.strong || 'Invisible to Influential'}</strong>
              <span>{banner?.text || 'Free 5-Day Email Course'}</span>
              <span class="arrow" aria-hidden="true">&rarr;</span>
            </a>
            <button class="banner-dismiss" aria-label="Dismiss announcement" data-banner-dismiss>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
        </div>
      )
    }

    <EditorialNav activeId="home" logoSrc="/images/v1/logo-primary.png" />

    <main>
      {/* ---------- Hero ---------- */}
      <section class="hero">
        <div class="grid12 hero-grid">
          <div class="hero-copy fade-up">
            <div class="hero-eyebrow">
              <span class="dot"></span>
              <span class="eyebrow" style="color: var(--ink-500);">
                {hero?.eyebrow ?? 'Keynote speaker · Author · Instructor'}
              </span>
            </div>
            <h1 class="hero-headline">{hero?.headline ?? 'Helping leaders build an'} <em>{hero?.headline_accent ?? 'unforgettable'}</em> {hero?.headline_tail ?? 'presence.'}</h1>
            <p class="hero-sub">
              {hero?.subheadline ??
                'Keynotes, workshops, and coaching that help your managers and high-potentials stop being the best-kept secret at work, and start driving the impact your organization needs.'}
            </p>
            <div class="hero-cta-row">
              <a class="btn primary large" href={primary_cta?.url ?? '/contact'}>
                {primary_cta?.label ?? 'Work With Me'} <span aria-hidden="true">&rarr;</span>
              </a>
              <a class="btn outline" href={secondary_cta?.url ?? '/book'}>{secondary_cta?.label ?? 'Get the Book'}</a>
              <a class="btn ghost" href={tertiary_cta?.url ?? '/speaking'}>{tertiary_cta?.label ?? 'Watch a keynote clip'}</a>
            </div>
            <div class="hero-meta">
              {
                heroMeta.map((stat, i) => (
                  <Fragment>
                    {i > 0 && <div class="divider" aria-hidden="true" />}
                    <div>
                      <div class="num">{stat.value}</div>
                      <div class="lbl">
                        {splitLines(stat.label).map((line, j) => (
                          <Fragment>{j > 0 && <br />}{line}</Fragment>
                        ))}
                      </div>
                    </div>
                  </Fragment>
                ))
              }
            </div>
          </div>

          <div class="hero-photo-wrap fade-up" style="animation-delay: 120ms;">
            <div class="photo-bg-shape" aria-hidden="true"></div>
            <div class="photo-card">
              <img src={heroImage} alt={hero?.image_alt ?? 'Lorraine K. Lee, keynote speaker'} />
            </div>
            <div class="photo-stat">
              <div class="num">{photoStat?.value || '4.9'}<span style="font-size: 18px; opacity: 0.5; font-weight: 400;">{photoStat?.suffix || '/5'}</span></div>
              <div class="lbl">
                {splitLines(photoStat?.label || 'Speaker rating across\n200+ keynotes').map((line, j) => (
                  <Fragment>{j > 0 && <br />}{line}</Fragment>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* ============================================================
           GLOBAL SECTION: trust / as-seen-in (press marquee)
           Canonical markup lives in <TrustAsSeenIn />. Edit that
           component instead of redesigning in isolation here.
           ============================================================ */}
      <TrustAsSeenIn />
      {/* /GLOBAL SECTION: trust-as-seen-in */}

      {/* ---------- Four ways ---------- */}
      <section class="four-ways">
        <div class="grid12">
          <div class="four-ways-head">
            <span class="eyebrow">{four_ways?.eyebrow || 'How I can help'}</span>
            <h2 class="four-ways-title">{four_ways?.heading || 'Four ways into the'} <em>{four_ways?.heading_accent || 'work.'}</em></h2>
          </div>
          <div class="four-ways-grid">
            {
              fourWays.map((it) => (
                <a class="fw-card" href={it.href}>
                  <div class="fw-row">
                    <span class="fw-num">{it.n}</span>
                    <span class="fw-arrow" aria-hidden="true">&#8599;</span>
                  </div>
                  <div class="fw-label">{it.label}</div>
                  <div class="fw-desc">{it.desc}</div>
                </a>
              ))
            }
          </div>
        </div>
      </section>

      {/* ============================================================
           GLOBAL SECTION: book-promo (The Book / Unforgettable Presence®)
           Canonical markup lives in src/components/BookPromo.astro.
           Reusable across pages by dropping in <BookPromo />.
           Coordinate edits via Linear.
           ============================================================ */}
      <BookPromo />
      {/* /GLOBAL SECTION: book-promo */}

      {/* ============================================================
           GLOBAL SECTION: testimonials (What clients say)
           Canonical markup lives in src/components/Testimonials.astro.
           Reusable across pages. Drop in <Testimonials /> (it reads its
           own data from Keystatic). do NOT redesign in isolation.
           Coordinate edits via Linear.
           ============================================================ */}
      <Testimonials
        eyebrow={testimonials_section?.eyebrow || undefined}
        titleHtml={testimonials_section?.heading
          ? `${testimonials_section.heading} <em>${testimonials_section.heading_accent ?? ''}</em>`
          : undefined}
        lead={testimonials_section?.lead || undefined}
      />
      {/* /GLOBAL SECTION: testimonials */}

      {/* ---------- Free course CTA ---------- */}
      <section id="course" class="course">
        <div class="grid12 course-grid">
          <div class="course-copy">
            <div class="course-eyebrow">
              <span class="pill">{free_course?.eyebrow_pill || 'Free'}</span>
              <span>{free_course?.eyebrow_label || '5-Day Email Course'}</span>
            </div>
            <h2 class="course-headline">
              {free_course?.headline || "Great at your job but can't"} <em>{free_course?.headline_accent || 'talk about it?'}</em>
            </h2>
            <p class="course-sub">
              {free_course?.body ||
                "You're not alone. Get my free 5-day course. The same frameworks I teach leaders at Amazon, Cisco, and Fortune 500 companies. Articulate your value. Make promotions inevitable."}
            </p>
            <ul class="course-bullets">
              {courseDays.map((day) => <li>{day}</li>)}
            </ul>
          </div>

          <div class="course-form">
            <div class="course-form-card">
              {/* Free-course signup: native POST to Kit (form 8913437), which
                  redirects to the funnel thank-you page. The GA free_course_signup
                  key event fires on that page's load (GoogleAnalytics.astro,
                  CLI-51), so this form is deliberately not tagged here to avoid
                  double-counting. */}
              <form
                method="post"
                action="https://app.kit.com/forms/8913437/subscriptions"
              >
                <span class="course-form-eyebrow">{free_course?.form_eyebrow || 'Start tomorrow'}</span>
                <h3 class="course-form-title">{free_course?.form_title || 'Join'} <em>{free_course?.form_title_accent || '12,000+'}</em> {free_course?.form_title_tail || 'leaders.'}</h3>
                <label class="field-label" for="course-email">{free_course?.form_email_label || 'Email address'}</label>
                <input
                  id="course-email"
                  class="field"
                  type="email"
                  name="email_address"
                  required
                  placeholder={free_course?.form_email_placeholder || 'you@company.com'}
                />
                <button type="submit" class="btn yellow large btn-block">
                  {free_course?.form_button_label || 'Send me Day 1'} <span aria-hidden="true">&rarr;</span>
                </button>
                <div class="fineprint">{free_course?.form_fineprint || 'No spam. Unsubscribe in one click.'}</div>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    {/* ---------- Footer (shared global section: site-footer) ---------- */}
    <Footer logoSrc="/images/v1/logo-primary.png" />
  </div>

  {/* ---------- Free course popup ---------- */}
  <dialog class="free-course-popup" aria-labelledby="free-course-popup-title" data-course-popup>
    <div class="free-course-popup__card">
      <button type="button" class="free-course-popup__close" aria-label="Dismiss free course popup" data-popup-dismiss>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <div class="free-course-popup__eyebrow">{course_popup?.eyebrow || 'Free 5-Day Course'}</div>
      <h2 id="free-course-popup-title" class="free-course-popup__title">
        {course_popup?.title || 'From invisible to influential.'}
      </h2>
      <p class="free-course-popup__subhead">
        {course_popup?.subhead ||
          'The 5-day system to communicate your value, get visible to decision-makers, and position yourself for the next level.'}
      </p>
      <ul class="free-course-popup__points">
        {
          (course_popup?.points && course_popup.points.length
            ? course_popup.points
            : [
                'Articulate your value.',
                'Show up on LinkedIn.',
                'Get known by decision-makers.',
              ]
          ).map((pt) => <li>{pt}</li>)
        }
      </ul>
      <div class="free-course-popup__actions">
        <a class="btn primary large" href={courseHref} data-popup-primary>
          {course_popup?.cta_label || 'Start the free course'} <span aria-hidden="true">&rarr;</span>
        </a>
        <button type="button" class="free-course-popup__dismiss" data-popup-dismiss>{course_popup?.dismiss_label || 'Not now'}</button>
      </div>
      <p class="free-course-popup__meta">{course_popup?.meta || 'Five short emails. Free.'}</p>
    </div>
  </dialog>
</HomeLayout>

<script>
  // --- Dismissible banner ---
  document
    .querySelector('[data-banner-dismiss]')
    ?.addEventListener('click', () => {
      document.getElementById('site-banner')?.setAttribute('hidden', '');
    });

  // --- Smooth in-page anchors ---
  document.addEventListener('click', (e) => {
    const link = (e.target as HTMLElement).closest?.('a[href^="#"]');
    if (!link) return;
    const id = link.getAttribute('href')!.slice(1);
    const dest = id && document.getElementById(id);
    if (!dest) return;
    e.preventDefault();
    dest.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // --- Scroll/time-triggered free-course popup ---
  (() => {
    const dialog = document.querySelector<HTMLDialogElement>('[data-course-popup]');
    if (!dialog) return;

    const DISMISSED_KEY = 'll:v1:free-course-popup:dismissedAt';
    const ENGAGED_KEY = 'll:v1:free-course-popup:engagedAt';
    const DISMISS_MS = 7 * 24 * 60 * 60 * 1000;
    const ENGAGED_MS = 30 * 24 * 60 * 60 * 1000;
    const DELAY_MS = 18 * 1000;
    const SCROLL_DEPTH = 0.35;

    function readTs(key: string): number {
      try {
        const raw = window.localStorage.getItem(key);
        const n = raw ? Number(raw) : 0;
        return Number.isFinite(n) ? n : 0;
      } catch {
        return 0;
      }
    }
    function writeTs(key: string) {
      try {
        window.localStorage.setItem(key, String(Date.now()));
      } catch {
        /* storage unavailable, popup behaves ephemerally */
      }
    }
    function suppressed(): boolean {
      const now = Date.now();
      const d = readTs(DISMISSED_KEY);
      if (d && now - d < DISMISS_MS) return true;
      const e = readTs(ENGAGED_KEY);
      return !!e && now - e < ENGAGED_MS;
    }
    function scrollDepth(): number {
      const root = document.documentElement;
      const scrollable = root.scrollHeight - window.innerHeight;
      return scrollable <= 0 ? 0 : root.scrollTop / scrollable;
    }

    if (suppressed()) return;

    let timeReady = false;
    let scrollReady = false;
    let courseSeen = false;
    let done = false;

    function open() {
      if (done || courseSeen || !timeReady || !scrollReady) return;
      done = true;
      if (typeof dialog.showModal === 'function') dialog.showModal();
      else dialog.setAttribute('open', 'open');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      if (dialog.open) dialog.close();
      document.body.style.overflow = '';
    }
    function dismiss() {
      writeTs(DISMISSED_KEY);
      done = true;
      close();
    }

    window.setTimeout(() => {
      timeReady = true;
      open();
    }, DELAY_MS);

    function onScroll() {
      if (scrollDepth() >= SCROLL_DEPTH) {
        scrollReady = true;
        window.removeEventListener('scroll', onScroll);
        open();
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    const course = document.getElementById('course');
    if (course) {
      const io = new IntersectionObserver(
        (entries) => {
          if (entries.some((en) => en.isIntersecting)) {
            courseSeen = true;
            io.disconnect();
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -20% 0px' }
      );
      io.observe(course);
    }

    dialog.querySelectorAll('[data-popup-dismiss]').forEach((el) =>
      el.addEventListener('click', dismiss)
    );
    dialog.addEventListener('cancel', (e) => {
      e.preventDefault();
      dismiss();
    });
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dismiss();
    });
    dialog.querySelector('[data-popup-primary]')?.addEventListener('click', () => {
      writeTs(ENGAGED_KEY);
      done = true;
    });
  })();
</script>
