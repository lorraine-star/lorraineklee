---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lorraine Lee">
	<main class="mx-auto flex min-h-screen max-w-2xl flex-col justify-center gap-5 px-6">
		<p class="text-sm font-medium uppercase tracking-[0.2em] text-neutral-500">
			lorraineklee.com
		</p>
		<h1 class="text-4xl font-semibold tracking-tight text-neutral-900">
			Astro project skeleton
		</h1>
		<p class="text-lg leading-relaxed text-neutral-600">
			Foundation for the lorraineklee.com migration. Astro, Tailwind CSS, and
			MDX are installed and ready for milestone 2 work.
		</p>
	</main>
</Layout>
