---
import SpeakingLayout from '../layouts/SpeakingLayout.astro';
import { reader, renderMarkdoc } from '../lib/keystatic';
import { safeUrl } from '../lib/url';
import Testimonials from '../components/Testimonials.astro';

const book = await reader.singletons.book.read();
if (!book) {
	throw new Error('Missing book content (src/content/book/index.mdoc)');
}

const {
	title,
	subtitle,
	hero,
	book_cover,
	cover_badge_top,
	cover_badge_bottom,
	accolades,
	description_section,
	retailers_section,
	retailer_links_individual,
	retailer_links_bulk,
	retailers_individual_label,
	retailers_bulk_label,
	community_section,
	featured_in_section,
	featured_in_logos,
	reviews_section,
	amazon_rating,
	reader_reviews,
	awards_section,
	awards,
	endorsements_section,
	endorsements,
	preview,
	final_cta,
} = book;

const descriptionHtml = await renderMarkdoc(book.description);

// Split each review quote into [text, isHighlighted] segments so the highlighted
// phrases render in blue inside the rest of the quote text.
function splitQuote(quote: string, phrases: readonly string[]) {
	const cleaned = phrases.filter((p): p is string => typeof p === 'string' && p.length > 0);
	if (!cleaned.length) return [{ text: quote, hl: false }];
	const escaped = cleaned.map((p) => p.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
	const re = new RegExp(`(${escaped.join('|')})`, 'g');
	return quote
		.split(re)
		.filter((s) => s.length > 0)
		.map((s) => ({ text: s, hl: cleaned.includes(s) }));
}

function renderStars(n: number) {
	return Array.from({ length: n }, (_, i) => i);
}

// Initials fallback for the shared testimonials card (used only if a headshot
// is ever missing; all current endorsements ship a headshot).
function getInitials(name: string) {
	return (
		name
			.split(/\s+/)
			.map((part) => part[0])
			.join('')
			.slice(0, 2)
			.toUpperCase() || '?'
	);
}
---

<SpeakingLayout
	title={`${title} | Lorraine K. Lee`}
	description={subtitle}
	activeId="book"
>
	{/* ---------- Product hero ---------- */}
	<section class="book-hero section--cream">
		<div class="grid12">
			<div class="book-hero-cover fade-up">
				<div class="stack">
					{
						cover_badge_top && (
							<span class="floating-badge top">{cover_badge_top}</span>
						)
					}
					{book_cover && <img src={book_cover} alt={`${title} book cover`} />}
					{
						cover_badge_bottom && (
							<span class="floating-badge bottom">{cover_badge_bottom}</span>
						)
					}
				</div>
			</div>
			<div class="book-hero-copy fade-up" style="animation-delay: 120ms;">
				<div class="page-hero-eyebrow">
					<span class="dot"></span>
					<span class="eyebrow" style="color: var(--ink-500);">
						{hero.eyebrow}
					</span>
				</div>
				<h1>{hero.headline} <em>{hero.headline_accent}</em></h1>
				<p class="book-tag">{hero.tagline}</p>
				{
					accolades.length > 0 && (
						<p class="bestseller-line">
							{accolades.map((a, i) => (
								<>
									{i > 0 && <span class="dot" />}
									{a.emphasized ? (
										<strong>{a.text}</strong>
									) : (
										<span>{a.text}</span>
									)}
								</>
							))}
						</p>
					)
				}
				<div class="hero-cta-row">
					<a class="btn primary large" href={safeUrl(hero.primary_cta_url)}>
						{hero.primary_cta_label} <span aria-hidden="true">&rarr;</span>
					</a>
					<a class="btn outline" href={safeUrl(hero.secondary_cta_url)}>
						{hero.secondary_cta_label}
					</a>
				</div>
			</div>
		</div>
	</section>

	{/* ---------- Description ---------- */}
	<section class="section">
		<div class="grid12">
			<div class="section-head section-head--center">
				<span class="eyebrow">{description_section.eyebrow}</span>
				<h2>
					{description_section.heading}{' '}
					<em>{description_section.heading_accent}</em>
				</h2>
			</div>
			<div class="book-desc reveal" set:html={descriptionHtml} />
		</div>
	</section>

	{/* ---------- Featured In (press logos) ---------- */}
	{
		featured_in_logos.length > 0 && (
			<section class="section section--tight">
				<div class="grid12">
					<div
						class="section-head section-head--center"
						style="margin-bottom: 24px;"
					>
						<span class="eyebrow">{featured_in_section.eyebrow}</span>
						{featured_in_section.heading && (
							<h2>{featured_in_section.heading}</h2>
						)}
					</div>
					<div class="logo-grid reveal-stagger">
						{featured_in_logos.map((logo) => (
							<div class="logo-cell">
								{logo.url ? (
									<a
										href={safeUrl(logo.url)}
										target="_blank"
										rel="noopener noreferrer"
										aria-label={logo.name}
									>
										<img
											class="client-logo"
											src={logo.image}
											alt={logo.name}
											loading="lazy"
										/>
									</a>
								) : (
									<img
										class="client-logo"
										src={logo.image}
										alt={logo.name}
										loading="lazy"
									/>
								)}
							</div>
						))}
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Community / readers collage ---------- */}
	{
		community_section.collage_image && (
			<section class="section community-section">
				<div class="grid12">
					<div
						class="section-head section-head--center"
						style="margin-bottom: 32px;"
					>
						<span class="eyebrow">{community_section.eyebrow}</span>
						<h2 class="community-heading">
							{community_section.heading}{' '}
							<span class="brush-underline">
								{community_section.heading_accent}
							</span>
						</h2>
					</div>
					<div class="readers-collage reveal">
						<img
							src={community_section.collage_image}
							alt={community_section.alt_text || 'Readers with the book'}
							loading="lazy"
						/>
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Reader reviews (5-star grid) ---------- */}
	{
		reader_reviews.length > 0 && (
			<section class="section section--cream reviews-section">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{reviews_section.eyebrow}</span>
						<h2>
							{reviews_section.heading}{' '}
							<em>{reviews_section.heading_accent}</em>
						</h2>
						{amazon_rating?.stars && (
							<div class="amazon-rating">
								<span class="rating-stars" aria-hidden="true">
									{renderStars(5).map(() => (
										<svg
											viewBox="0 0 24 24"
											width="20"
											height="20"
											aria-hidden="true"
										>
											<path
												d="M12 2l2.95 6.74L22 9.74l-5.5 4.78L18.18 22 12 18.27 5.82 22l1.68-7.48L2 9.74l7.05-1z"
												fill="currentColor"
											/>
										</svg>
									))}
								</span>
								<span class="rating-value">
									<strong>{amazon_rating.stars}</strong>
									<span class="rating-divider"> · </span>
									<span>{amazon_rating.count_label}</span>
								</span>
								{amazon_rating.url && (
									<a
										class="rating-link"
										href={safeUrl(amazon_rating.url)}
										target="_blank"
										rel="noopener noreferrer"
									>
										See all on Amazon →
									</a>
								)}
							</div>
						)}
					</div>
					<div class="reviews-panel reveal">
						<div class="reviews-grid">
							{reader_reviews.map((r) => {
								const segments = splitQuote(
									r.quote,
									(r.highlighted_phrases || []) as readonly string[]
								);
								return (
									<figure class="review-card">
										<div class="review-stars" aria-label={`${r.stars} out of 5 stars`}>
											{renderStars(r.stars).map(() => (
												<svg
													viewBox="0 0 24 24"
													width="22"
													height="22"
													aria-hidden="true"
												>
													<path
														d="M12 2l2.95 6.74L22 9.74l-5.5 4.78L18.18 22 12 18.27 5.82 22l1.68-7.48L2 9.74l7.05-1z"
														fill="currentColor"
													/>
												</svg>
											))}
										</div>
										<blockquote class="review-quote">
											&ldquo;
											{segments.map((seg) =>
												seg.hl ? (
													<span class="review-hl">{seg.text}</span>
												) : (
													<>{seg.text}</>
												)
											)}
											&rdquo;
										</blockquote>
									</figure>
								);
							})}
						</div>
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Awards ---------- */}
	{
		awards.length > 0 && (
			<section class="section section--tight">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{awards_section.eyebrow}</span>
						<h2>
							{awards_section.heading}{' '}
							<em>{awards_section.heading_accent}</em>
						</h2>
					</div>
					<div class="awards-row reveal-stagger">
						{awards.map((a) => (
							<div class="award-tile">
								{a.badge_image && (
									<div class="award-badge">
										<img src={a.badge_image} alt={a.badge_alt || a.name} loading="lazy" />
									</div>
								)}
								<div class="award-meta">
									<div class="award-name">{a.name}</div>
									<div class="award-result">{a.result}</div>
									<div class="award-category">{a.category}</div>
								</div>
							</div>
						))}
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Retailers (individual + bulk) ---------- */}
	<section class="section section--tight section--cream" id="retailers">
		<div class="grid12">
			<div
				class="section-head section-head--center"
				style="margin-bottom: 32px;"
			>
				<span class="eyebrow">{retailers_section.eyebrow}</span>
				<h2>
					{retailers_section.heading}{' '}
					<em>{retailers_section.heading_accent}</em>
				</h2>
			</div>
			<div class="retailer-group">
				<div class="retailer-group-label">{retailers_individual_label}</div>
				<div class="retailer-row reveal-stagger">
					{
						retailer_links_individual.map((r) => {
							const style = r.brand_color
								? `--retailer-brand: ${r.brand_color};`
								: undefined;
							return r.url ? (
								<a
									class="retailer-btn"
									href={safeUrl(r.url)}
									target="_blank"
									rel="noopener noreferrer"
									style={style}
								>
									<span class="retailer-name">{r.name}</span>
									<span aria-hidden="true">&rarr;</span>
								</a>
							) : (
								<span
									class="retailer-btn is-disabled"
									aria-disabled="true"
									style={style}
								>
									<span class="retailer-name">{r.name}</span>
								</span>
							);
						})
					}
				</div>
			</div>
			{
				retailer_links_bulk.length > 0 && (
					<div class="retailer-group retailer-group--bulk">
						<div class="retailer-group-label">{retailers_bulk_label}</div>
						<div class="retailer-row retailer-row--bulk reveal-stagger">
							{retailer_links_bulk.map((r) => {
								const style = r.brand_color
									? `--retailer-brand: ${r.brand_color};`
									: undefined;
								return r.url ? (
									<a
										class="retailer-btn"
										href={safeUrl(r.url)}
										target="_blank"
										rel="noopener noreferrer"
										style={style}
									>
										<span class="retailer-name">{r.name}</span>
										<span aria-hidden="true">&rarr;</span>
									</a>
								) : (
									<span
										class="retailer-btn is-disabled"
										aria-disabled="true"
										style={style}
									>
										<span class="retailer-name">{r.name}</span>
									</span>
								);
							})}
						</div>
					</div>
				)
			}
			{
				retailers_section.format_note && (
					<div style="grid-column: 1 / -1; text-align: center; margin-top: 24px;">
						<p class="retailer-format-note">
							{retailers_section.format_note}
						</p>
					</div>
				)
			}
		</div>
	</section>

	{/* ---------- Endorsements (global testimonials carousel) ---------- */}
	{
		endorsements.length > 0 && (
			<Testimonials
				eyebrow={endorsements_section.eyebrow}
				titleHtml={`${endorsements_section.heading} <em>${endorsements_section.heading_accent}</em>`}
				lead=""
				testimonials={endorsements.map((e) => ({
					quote: e.quote_alt,
					name: e.name,
					role: e.role,
					photo: e.headshot,
					photoAlt: `Headshot of ${e.name}`,
					initials: getInitials(e.name),
					logos: (e.logos ?? []).map((l) => ({
						image: l.image,
						alt: l.alt,
					})),
				}))}
			/>
		)
	}

	{/* ---------- Sample chapter ---------- */}
	<section class="section section--tight" id="preview">
		<div class="grid12">
			<div class="preview-callout reveal">
				<div class="preview-copy">
					<span class="eyebrow">{preview.eyebrow}</span>
					<h3>{preview.heading} <em>{preview.heading_accent}</em></h3>
					<p>{preview.body}</p>
				</div>
				<a class="btn primary" href={safeUrl(preview.cta_url)}>
					{preview.cta_label} <span aria-hidden="true">&rarr;</span>
				</a>
			</div>
		</div>
	</section>

	{/* ---------- Final CTA ---------- */}
	<section class="section">
		<div class="grid12">
			<div class="final-cta reveal">
				<div class="final-cta-inner">
					<span class="eyebrow">{final_cta.eyebrow}</span>
					<h2>{final_cta.heading} <em>{final_cta.heading_accent}</em></h2>
					<p>{final_cta.body}</p>
					<div class="hero-cta-row" style="justify-content: center;">
						<a class="btn yellow large" href={safeUrl(final_cta.cta_url)}>
							{final_cta.cta_label} <span aria-hidden="true">&rarr;</span>
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>
</SpeakingLayout>
