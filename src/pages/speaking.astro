---
import SpeakingLayout from '../layouts/SpeakingLayout.astro';
import { reader } from '../lib/keystatic';

const speaking = await reader.singletons.speaking.read();
if (!speaking) {
	throw new Error('Missing speaking content (src/content/speaking/index.yaml)');
}

const {
	hero,
	topics_section,
	topics,
	clients_section,
	past_clients,
	show_stats,
	stats_section,
	stats,
	testimonials_section,
	testimonials,
	repeats_section,
	repeats,
	as_seen_in_eyebrow,
	as_seen_in,
	final_cta,
} = speaking;

const statDisplay = (value: string, decimals: number) => {
	const n = parseFloat(value) || 0;
	return decimals > 0 ? n.toFixed(decimals) : Math.round(n).toLocaleString();
};
---

<SpeakingLayout
	title="Lorraine K. Lee — Speaking"
	description={hero.lead}
	activeId="speaking"
>
	{/* ---------- Hero ---------- */}
	<section class="page-hero">
		<div class="grid12 page-hero-grid">
			<div class="page-hero-copy fade-up">
				<div class="page-hero-eyebrow">
					<span class="dot"></span>
					<span class="eyebrow" style="color: var(--ink-500);">
						{hero.eyebrow}
					</span>
				</div>
				<h1>{hero.headline} <em>{hero.headline_accent}</em></h1>
				<p class="lead-large">{hero.lead}</p>
				<div class="hero-cta-row">
					<a class="btn primary large" href={hero.cta_url}>
						{hero.cta_label} <span aria-hidden="true">&rarr;</span>
					</a>
					<a class="btn outline" href="#past-talks">See past talks</a>
				</div>
				<div class="hero-meta">
					{
						hero.meta.map((m, i) => (
							<Fragment>
								{i > 0 && <div class="divider" aria-hidden="true" />}
								<div>
									<div class="num">{m.value}</div>
									<div class="lbl">{m.label}</div>
								</div>
							</Fragment>
						))
					}
				</div>
			</div>
			<div class="page-hero-aside fade-up" style="animation-delay: 120ms;">
				<div class="photo-card">
					<img src={hero.image} alt={hero.image_alt} />
				</div>
				<div
					class="photo-stat"
					style="background: var(--brand-yellow-500); color: var(--ink-900); border-color: var(--brand-yellow-500);"
				>
					<div class="num" style="color: var(--ink-900);">
						{hero.photo_stat_value}
					</div>
					<div class="lbl" style="color: var(--ink-900); opacity: 0.78;">
						{hero.photo_stat_label}
					</div>
				</div>
			</div>
		</div>
	</section>

	{/* ---------- Topics ---------- */}
	<section class="section section--cream" id="past-talks">
		<div class="grid12">
			<div class="section-head">
				<span class="eyebrow">{topics_section.eyebrow}</span>
				<h2>
					{topics_section.heading} <em>{topics_section.heading_accent}</em>
				</h2>
				<p class="lead">{topics_section.lead}</p>
			</div>
			<div class="topic-grid reveal-stagger">
				{
					topics.map((t) => (
						<a class="topic-card" href="/contact">
							<div class="topic-num">&#8470; {t.number}</div>
							<h3>{t.title}</h3>
							<p class="topic-desc">{t.description}</p>
							<div class="topic-meta">
								<span>{t.format}</span>
								<span style="margin-left: auto;">
									Inquire <span class="arrow">&rarr;</span>
								</span>
							</div>
						</a>
					))
				}
			</div>
		</div>
	</section>

	{/* ---------- Past clients ---------- */}
	<section class="section section--tight">
		<div class="grid12">
			<div class="section-head section-head--center">
				<span class="eyebrow">{clients_section.eyebrow}</span>
				<h2>
					{clients_section.heading} <em>{clients_section.heading_accent}</em>
				</h2>
			</div>
			<div class="logo-grid reveal">
				{
					past_clients.map((l) => (
						<div class="logo-cell">
							<span class={`logo-word ${l.style}`}>{l.name}</span>
						</div>
					))
				}
			</div>
		</div>
	</section>

	{/* ---------- Stats ---------- */}
	{
		show_stats && (
			<section class="section section--tight">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{stats_section.eyebrow}</span>
						<h2>
							{stats_section.heading}{' '}
							<em>{stats_section.heading_accent}</em>
						</h2>
					</div>
					<div class="stat-row reveal-stagger">
						{stats.map((s) => (
							<div class="stat-cell">
								<div class="stat-num">
									<span
										class="count-up"
										data-to={s.value}
										data-decimals={String(s.decimals ?? 0)}
										data-duration="1500"
									>
										{statDisplay(s.value, s.decimals ?? 0)}
									</span>
									<span class="denom">{s.denominator}</span>
								</div>
								<div class="stat-lbl">{s.label}</div>
							</div>
						))}
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Organizer testimonials ---------- */}
	<section class="section">
		<div class="grid12">
			<div class="section-head">
				<span class="eyebrow">{testimonials_section.eyebrow}</span>
				<h2>
					{testimonials_section.heading}{' '}
					<em>{testimonials_section.heading_accent}</em>
				</h2>
				<p class="lead">{testimonials_section.lead}</p>
			</div>
			<div class="testimonials-grid reveal-stagger" style="grid-column: 1 / -1;">
				{
					testimonials.map((t) => (
						<figure class:list={['t-card', { featured: t.featured }]}>
							<span class="t-mark" aria-hidden="true">&ldquo;</span>
							<blockquote class="t-quote">{t.quote}</blockquote>
							<div class="t-divider" />
							<figcaption class="t-attrib">
								<div class="t-avatar">{t.initials}</div>
								<div>
									<div class="t-name">{t.name}</div>
									<div class="t-role">{t.role}</div>
								</div>
							</figcaption>
						</figure>
					))
				}
			</div>
		</div>
	</section>

	{/* ---------- Repeat bookings ---------- */}
	<section class="section section--cream">
		<div class="grid12">
			<div class="section-head section-head--center">
				<span class="eyebrow">{repeats_section.eyebrow}</span>
				<h2>
					{repeats_section.heading} <em>{repeats_section.heading_accent}</em>
				</h2>
				<p class="lead">{repeats_section.lead}</p>
			</div>
			<div class="repeat-grid reveal-stagger">
				{
					repeats.map((r) => (
						<div class="repeat-card">
							<div class="repeat-logo">{r.name}</div>
							<div class="repeat-mult">{r.multiplier}</div>
							<div class="repeat-lbl">{r.label}</div>
						</div>
					))
				}
			</div>
		</div>
	</section>

	{/* ---------- As seen in ---------- */}
	<section class="section section--tight">
		<div class="grid12">
			<div
				class="section-head section-head--center"
				style="margin-bottom: 32px;"
			>
				<span class="eyebrow">{as_seen_in_eyebrow}</span>
			</div>
			<div class="media-strip">
				{
					as_seen_in.map((l) => (
						<span class={`logo-word ${l.style}`}>{l.name}</span>
					))
				}
			</div>
		</div>
	</section>

	{/* ---------- Final CTA ---------- */}
	<section class="section">
		<div class="grid12">
			<div class="final-cta">
				<div class="final-cta-inner">
					<span class="eyebrow">{final_cta.eyebrow}</span>
					<h2>
						{final_cta.heading} <em>{final_cta.heading_accent}</em>
					</h2>
					<p>{final_cta.body}</p>
					<a class="btn yellow large" href={final_cta.cta_url}>
						{final_cta.cta_label} <span aria-hidden="true">&rarr;</span>
					</a>
				</div>
			</div>
		</div>
	</section>
</SpeakingLayout>
