---
import SpeakingLayout from '../../layouts/SpeakingLayout.astro';
import { reader, renderMarkdoc } from '../../lib/keystatic';
import { formatDate } from '../../lib/dates';
import { safeUrl } from '../../lib/url';

export async function getStaticPaths() {
	const articles = await reader.collections.articles.all();
	return articles.map((article) => ({
		params: { slug: article.slug },
		props: { article: article.entry },
	}));
}

const { article } = Astro.props;
const contentHtml = await renderMarkdoc(article.content);
---

<SpeakingLayout
	title={`${article.title} | Lorraine K. Lee`}
	description={article.description}
	activeId="thought-leadership"
>
	<section class="section">
		<div class="grid12">
			<article class="article-detail">
				<p class="article-back">
					<a href="/articles">&larr; All articles</a>
				</p>

				<h1>{article.title}</h1>

				{article.date && <p class="article-date">{formatDate(article.date)}</p>}

				{
					article.hero_image && (
						<img class="article-hero" src={article.hero_image} alt="" />
					)
				}

				<div class="article-body" set:html={contentHtml} />

				{
					article.external_url && (
						<p class="article-original">
							<a href={safeUrl(article.external_url)}>Read the original</a>
						</p>
					)
				}
			</article>
		</div>
	</section>
</SpeakingLayout>

<style>
	.article-detail {
		grid-column: 1 / -1;
		max-width: 72ch;
		margin-inline: auto;
	}
	.article-back {
		font-size: 0.85rem;
		margin-bottom: 16px;
	}
	.article-back a {
		color: var(--ink-500);
		text-decoration: none;
	}
	.article-back a:hover {
		color: var(--ink-900);
	}
	.article-detail h1 {
		margin: 0 0 12px;
	}
	.article-date {
		color: var(--ink-500);
		font-size: 0.85rem;
		margin-bottom: 24px;
	}
	.article-hero {
		width: 100%;
		border-radius: 14px;
		margin: 8px 0 28px;
		object-fit: cover;
	}
	.article-body {
		font-size: 1.05rem;
		line-height: 1.7;
		color: var(--ink-700);
	}
	.article-body :global(p) {
		margin: 0 0 1rem;
	}
	.article-original {
		margin-top: 32px;
	}
	.article-original a {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 4px;
	}
</style>
