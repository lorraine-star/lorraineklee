---
import Layout from '../../layouts/Layout.astro';
import { reader, renderMarkdoc } from '../../lib/keystatic';

export async function getStaticPaths() {
	const articles = await reader.collections.articles.all();
	return articles.map((article) => ({
		params: { slug: article.slug },
		props: { article: article.entry },
	}));
}

const { article } = Astro.props;
const contentHtml = await renderMarkdoc(article.content);

const formatDate = (value: string | null) =>
	value
		? new Date(`${value}T00:00:00`).toLocaleDateString('en-US', {
				year: 'numeric',
				month: 'long',
				day: 'numeric',
			})
		: '';
---

<Layout
	title={`${article.title} | Lorraine K. Lee`}
	description={article.description}
>
	<article class="mx-auto max-w-3xl px-6 py-20">
		<p class="text-sm">
			<a href="/articles" class="text-neutral-500 hover:text-neutral-900">
				&larr; All articles
			</a>
		</p>

		<h1
			class="mt-4 text-balance text-4xl font-semibold tracking-tight sm:text-5xl"
		>
			{article.title}
		</h1>

		{
			article.date && (
				<p class="mt-3 text-sm text-neutral-500">
					{formatDate(article.date)}
				</p>
			)
		}

		{
			article.hero_image && (
				<img
					src={article.hero_image}
					alt=""
					class="mt-8 w-full rounded-lg object-cover"
				/>
			)
		}

		<div
			class="mt-8 space-y-4 text-lg leading-relaxed text-neutral-700"
			set:html={contentHtml}
		/>

		{
			article.external_url && (
				<p class="mt-10">
					<a
						href={article.external_url}
						class="underline underline-offset-4 hover:text-neutral-600"
					>
						Read the original
					</a>
				</p>
			)
		}
	</article>
</Layout>
