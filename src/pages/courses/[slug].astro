---
import SpeakingLayout from '../../layouts/SpeakingLayout.astro';
import { reader } from '../../lib/keystatic';
import { safeUrl } from '../../lib/url';

export async function getStaticPaths() {
	const courses = await reader.collections.courses.all();
	return courses.map((course) => ({
		params: { slug: course.slug },
		props: { course: course.entry },
	}));
}

const { course } = Astro.props;
const courseUrl = safeUrl(course.url);
---

<SpeakingLayout
	title={`${course.title} | Lorraine K. Lee`}
	description={course.description}
	activeId="learn"
>
	<section class="page-hero page-hero--center">
		<div class="grid12 page-hero-grid">
			<div class="talk-page-hero fade-up">
				<a class="talk-page-back" href="/courses">
					<span aria-hidden="true">&larr;</span> All courses
				</a>
				<div class="talk-format">LinkedIn Learning &middot; On-demand course</div>
				<h1>{course.title}</h1>
				{course.description && <p class="lead-large">{course.description}</p>}
				<div class="hero-cta-row">
					{
						courseUrl && (
							<a
								class="btn primary large"
								href={courseUrl}
								target="_blank"
								rel="noopener noreferrer"
							>
								Watch on LinkedIn Learning{' '}
								<span aria-hidden="true">&rarr;</span>
							</a>
						)
					}
					<a class="anchor-link" href="/courses">
						See other courses{' '}
						<span class="arrow" aria-hidden="true">&rarr;</span>
					</a>
				</div>
				<p class="learn-hero-trust">
					Free to watch with a LinkedIn Learning subscription.
				</p>
			</div>
		</div>
	</section>
</SpeakingLayout>
