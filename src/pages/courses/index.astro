---
import SpeakingLayout from '../../layouts/SpeakingLayout.astro';
import { reader } from '../../lib/keystatic';
import { safeUrl } from '../../lib/url';

// Category order mirrors the old WordPress /learning-courses/ hub.
const CATEGORY_ORDER = ['Communication', 'Leadership', 'Management', 'Career'];

const page = await reader.singletons.coursesPage.read();
if (!page) {
	throw new Error('Missing courses page content (src/content/courses-page/index.yaml)');
}
const { hero, rating, testimonials_section, testimonials, final_cta } = page;

const all = await reader.collections.courses.all();
const courses = all
	.map((c) => ({ slug: c.slug, ...c.entry }))
	.sort((a, b) => (a.order ?? 0) - (b.order ?? 0));

const grouped = CATEGORY_ORDER.map((category) => ({
	category,
	items: courses.filter((c) => c.category === category),
})).filter((g) => g.items.length > 0);

const isExternal = (url: string) => /^https?:\/\//i.test(url);
const heroCtaUrl = safeUrl(hero.primary_cta_url) || '#courses';
const finalCtaUrl = safeUrl(final_cta.cta_url) || '/learn#course';
---

<SpeakingLayout
	title="LinkedIn Learning Courses | Lorraine K. Lee"
	description={hero.lead}
	activeId="learn"
>
	{/* ---------- Hero + rating ---------- */}
	<section class="page-hero page-hero--center">
		<div class="grid12 page-hero-grid">
			<div class="page-hero-copy fade-up">
				<div class="page-hero-eyebrow">
					<span class="dot"></span>
					<span class="eyebrow" style="color: var(--ink-500);">{hero.eyebrow}</span>
				</div>
				<h1>{hero.headline} <em>{hero.headline_accent}</em></h1>
				<p class="lead-large">{hero.lead}</p>
				<div class="hero-cta-row">
					<a
						class="btn primary large"
						href={heroCtaUrl}
						target={isExternal(heroCtaUrl) ? '_blank' : undefined}
						rel={isExternal(heroCtaUrl) ? 'noopener noreferrer' : undefined}
					>
						{hero.primary_cta_label} <span aria-hidden="true">&rarr;</span>
					</a>
					<a class="anchor-link" href="#courses">
						Browse courses <span class="arrow" aria-hidden="true">&rarr;</span>
					</a>
				</div>

				{
					rating?.value && (
						<div class="course-rating">
							<div class="amazon-rating">
								<span class="rating-stars" aria-hidden="true">
									{Array.from({ length: 5 }).map(() => (
										<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
											<path
												d="M12 2l2.95 6.74L22 9.74l-5.5 4.78L18.18 22 12 18.27 5.82 22l1.68-7.48L2 9.74l7.05-1z"
												fill="currentColor"
											/>
										</svg>
									))}
								</span>
								<span class="rating-value">
									<strong>{rating.value}{rating.scale}</strong>
									{rating.students_label && (
										<>
											<span class="rating-divider"> · </span>
											<span>{rating.students_label}</span>
										</>
									)}
								</span>
							</div>
							{rating.note && <p class="course-rating-note">{rating.note}</p>}
						</div>
					)
				}
			</div>
		</div>
	</section>

	{/* ---------- Courses, grouped by category ---------- */}
	<div id="courses">
		{
			grouped.map(({ category, items }) => (
				<section class="section section--tight anchor-target" id={category.toLowerCase()}>
					<div class="grid12">
						<div class="section-head section-head--center">
							<span class="eyebrow">{category}</span>
							<h2>
								{category} <em>courses</em>
							</h2>
						</div>

						<div class="course-grid-cards reveal-stagger">
							{items.map((c) => (
								<a class="course-card" data-platform="LinkedIn Learning" href={`/courses/${c.slug}`}>
									<div class="course-thumb">
										{c.thumbnail ? (
											<img class="course-thumb-img" src={c.thumbnail} alt="" loading="lazy" />
										) : (
											<div class="course-thumb-deco" aria-hidden="true">
												{c.glyph}
											</div>
										)}
										<span class="platform-tag">LinkedIn Learning</span>
										<div class="play" aria-hidden="true">
											<svg viewBox="0 0 24 24" fill="currentColor">
												<path d="M8 5v14l11-7z" />
											</svg>
										</div>
										{c.duration && <span class="duration">{c.duration}</span>}
									</div>
									<div class="course-card-body">
										<h3>{c.title}</h3>
										<p class="course-desc course-desc--clamp">{c.description}</p>
										<span class="course-link">
											View course <span aria-hidden="true">&rarr;</span>
										</span>
									</div>
								</a>
							))}
						</div>
					</div>
				</section>
			))
		}
	</div>

	{/* ---------- Student testimonials ---------- */}
	{
		testimonials?.length > 0 && (
			<section class="section section--tight anchor-target" id="testimonials">
				<div class="grid12">
					<div class="section-head section-head--center">
						<span class="eyebrow">{testimonials_section.eyebrow}</span>
						<h2>
							{testimonials_section.heading}{' '}
							<em>{testimonials_section.heading_accent}</em>
						</h2>
					</div>
					<div class="attendee-masonry reveal">
						{testimonials.map((t) => (
							<figure class="t-card">
								<span class="t-mark" aria-hidden="true">&ldquo;</span>
								<blockquote class="t-quote">{t.quote}</blockquote>
								<div class="t-divider" />
								<figcaption class="t-attrib">
									<div class="t-avatar">{t.initials}</div>
									<div>
										<div class="t-name">{t.name}</div>
										<div class="t-role">LinkedIn Learning student</div>
									</div>
								</figcaption>
							</figure>
						))}
					</div>
				</div>
			</section>
		)
	}

	{/* ---------- Final CTA — free 5-day course ---------- */}
	<section class="section">
		<div class="grid12">
			<div class="final-cta">
				<div class="final-cta-inner">
					<span class="eyebrow">{final_cta.eyebrow}</span>
					<h2>
						{final_cta.heading} <em>{final_cta.heading_accent}</em>
					</h2>
					<p>{final_cta.body}</p>
					<a class="btn yellow large" href={finalCtaUrl}>
						{final_cta.cta_label} <span aria-hidden="true">&rarr;</span>
					</a>
				</div>
			</div>
		</div>
	</section>
</SpeakingLayout>

<style>
	/* Keep card copy to a tidy, even height regardless of description length. */
	.course-desc--clamp {
		display: -webkit-box;
		-webkit-line-clamp: 3;
		line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.course-rating {
		margin-top: 28px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 6px;
	}
	.course-rating-note {
		font-family: var(--font-sans);
		font-size: 13px;
		color: var(--ink-500);
		margin: 0;
	}
</style>
