---
import SpeakingLayout from '../../layouts/SpeakingLayout.astro';
import { reader } from '../../lib/keystatic';
import { safeUrl } from '../../lib/url';
import { getTestimonials } from '../../lib/testimonials';

// Category order mirrors the old WordPress /learning-courses/ hub.
const CATEGORY_ORDER = ['Communication', 'Leadership', 'Management', 'Career'];

const page = await reader.singletons.coursesPage.read();
if (!page) {
	throw new Error('Missing courses page content (src/content/courses-page/index.yaml)');
}
const { hero, rating, filter_bar, why_section, final_cta, labels } = page;

const all = await reader.collections.courses.all();
const mapped = all
	.map((c) => ({ slug: c.slug, ...c.entry }))
	.sort((a, b) => (a.order ?? 0) - (b.order ?? 0));

// Featured block: at most one course, derived from the full set (independent
// of show_on_hub) so a featured course can never silently vanish from the page.
const featured = mapped.filter((c) => c.featured).slice(0, 1)[0] ?? null;

// Mirror the curated WordPress hub: only courses flagged for it. Pre-sorted by
// category then in-category order so the unfiltered grid still groups cleanly.
// The featured course is kept in the grid too (it stays browsable under its
// category) per the design.
const hubCourses = mapped
	.filter((c) => c.show_on_hub !== false)
	.sort(
		(a, b) =>
			CATEGORY_ORDER.indexOf(a.category) - CATEGORY_ORDER.indexOf(b.category) ||
			(a.order ?? 0) - (b.order ?? 0)
	);

const counts: Record<string, number> = { all: hubCourses.length };
for (const cat of CATEGORY_ORDER) {
	counts[cat] = hubCourses.filter((c) => c.category === cat).length;
}
const categories = CATEGORY_ORDER.filter((cat) => counts[cat] > 0);

const isExternal = (url: string) => /^https?:\/\//i.test(url);
const linkedinUrl = safeUrl(hero.primary_cta_url) || 'https://www.linkedin.com/learning/instructors/lorraine-lee';
const finalCtaUrl = safeUrl(final_cta.cta_url) || '/from-invisible-to-influential/';

// Resolve a course link: prefer the external LinkedIn Learning URL, fall back
// to the on-site detail page.
const courseHref = (c: { url?: string | null; slug: string }) =>
	safeUrl(c.url) || `/courses/${c.slug}`;

const whyPoints = why_section?.points ?? [];

// Compact proof strip: pull real course/student reviews from the shared
// testimonials collection (CLI-118); take at most two. No invented quotes.
const proofQuotes = (await getTestimonials({ placement: 'courses' })).slice(0, 2);
---

<SpeakingLayout
	title={page.seo_title || "LinkedIn Learning Courses | Lorraine K. Lee"}
	description={page.seo_description || hero.lead}
	activeId="learn"
>
	<div class="courses-page">
		{/* ---------- Hero (editorial) ---------- */}
		<section class="courses-hero hero-editorial">
			<div class="container hero-editorial-grid">
				<div class="hero-text">
					<span class="eyebrow eyebrow-hero">{hero.eyebrow}</span>
					<h1 class="h-hero">
						{hero.headline}{' '}
						<span class="accent-italic">{hero.headline_accent}</span>{hero.headline_tail}
					</h1>
					<p class="hero-lead">{hero.lead}</p>
					<div class="hero-ctas">
						<a class="btn primary large" href="#course-grid">{labels?.explore_courses || 'Explore courses'}</a>
						<a
							class="btn outline large"
							href={linkedinUrl}
							target="_blank"
							rel="noopener noreferrer"
						>
							{hero.primary_cta_label} <span aria-hidden="true">&#8599;</span>
						</a>
					</div>
					{
						rating?.value && (
							<div class="hero-stats">
								{rating.students_value && (
									<div class="hero-stat">
										<div class="hero-stat-num">{rating.students_value}</div>
										<div class="hero-stat-label">{rating.students_label}</div>
									</div>
								)}
								<div class="hero-stat">
									<div class="hero-stat-num">{mapped.length}</div>
									<div class="hero-stat-label">LinkedIn Learning courses</div>
								</div>
								<div class="hero-stat">
									<div class="hero-stat-num">
										{rating.value}
										<span class="hero-stat-unit">{rating.scale}</span>
									</div>
									<div class="hero-stat-label">{rating.value_label}</div>
								</div>
							</div>
						)
					}
				</div>

				{
					hero.image && (
						<aside class="hero-side">
							<div class="hero-photo-frame editorial">
								<div class="hero-photo-bg" aria-hidden="true" />
								<img
									src={hero.image}
									alt={hero.image_alt}
									class="hero-photo-img"
									loading="eager"
								/>
							</div>
							<div class="hero-credentials">
								<div class="cred-pill">
									<span class="cred-dot" aria-hidden="true" />
									{hero.credential_pill || 'Top-rated LinkedIn Learning instructor'}
								</div>
								{rating?.value && (
									<div class="cred-pill">
										<span class="cred-star" aria-hidden="true">&#9733;</span>
										{rating.value}{rating.scale} across the library
									</div>
								)}
							</div>
						</aside>
					)
				}
			</div>
		</section>

		{/* ---------- Featured course ---------- */}
		{
			featured && (
				<section class="featured-section wide">
					<div class="container">
						<div class="featured-wide">
							<div class="featured-wide-text">
								<div class="eyebrow featured-eyebrow">
									<span class="featured-eyebrow-dot" aria-hidden="true" />
									{labels?.featured_badge || "Lorraine's pick · Start here"}
								</div>
								<h2 class="featured-title">{featured.title}</h2>
								<p class="featured-summary">{featured.description}</p>
								<ul class="featured-tags" aria-label="Course tags">
									{featured.category && (
										<li class="featured-tag">{featured.category}</li>
									)}
									<li class="featured-tag">{labels?.free_with_linkedin || 'Free with LinkedIn Learning'}</li>
								</ul>
								<div class="featured-meta">
									<span class="featured-meta-item">LinkedIn Learning</span>
									<span class="featured-meta-item">Free with a subscription</span>
								</div>
								<div class="featured-ctas">
									<a
										class="btn primary large"
										href={courseHref(featured)}
										target={isExternal(courseHref(featured)) ? '_blank' : undefined}
										rel={isExternal(courseHref(featured)) ? 'noopener noreferrer' : undefined}
									>
										{labels?.start_this_course || 'Start this course'} <span aria-hidden="true">&rarr;</span>
									</a>
									<a class="btn ghost" href={`/courses/${featured.slug}`}>
										{labels?.see_whats_inside || "See what's inside"} <span aria-hidden="true">&rarr;</span>
									</a>
								</div>
							</div>
							<div class="featured-wide-image">
								<div class="featured-wide-bg" aria-hidden="true" />
								{featured.thumbnail && (
									<img
										src={featured.thumbnail}
										alt={featured.title}
										class="featured-wide-photo"
										loading="lazy"
									/>
								)}
							</div>
						</div>
					</div>
				</section>
			)
		}

		{/* ---------- Category filter (sticky) ---------- */}
		<div class="filter-bar" id="course-grid">
			<div class="container filter-bar-inner">
				<div class="filter-bar-label">
					<span class="eyebrow">{filter_bar?.eyebrow || 'Find the right course'}</span>
					<h2 class="filter-bar-heading">{filter_bar?.heading || 'Which course is right for you?'}</h2>
				</div>
				<div class="filter-pills" role="tablist" aria-label="Course categories">
					<button
						type="button"
						class="filter-pill is-active"
						data-filter="all"
						role="tab"
						aria-selected="true"
					>
						{labels?.all_courses_filter || 'All courses'}
						<span class="filter-pill-count">{counts.all}</span>
					</button>
					{
						categories.map((cat) => (
							<button
								type="button"
								class="filter-pill"
								data-filter={cat}
								role="tab"
								aria-selected="false"
							>
								{cat}
								<span class="filter-pill-count">{counts[cat]}</span>
							</button>
						))
					}
				</div>
			</div>
		</div>

		{/* ---------- Course grid ---------- */}
		<section class="grid-section">
			<div class="container">
				<div class="grid-section-head">
					<div class="grid-section-title">
						<span class="grid-count" data-grid-count>{counts.all}</span>
						<span class="grid-count-label" data-grid-label>courses &middot; all categories</span>
					</div>
					<a
						class="grid-section-link"
						href={linkedinUrl}
						target="_blank"
						rel="noopener noreferrer"
					>
						{labels?.view_on_linkedin || 'View on LinkedIn Learning'} <span aria-hidden="true">&#8599;</span>
					</a>
				</div>

				<div class="course-grid" data-course-grid>
					{
						hubCourses.map((c) => {
							const url = courseHref(c);
							const ext = isExternal(url);
							return (
								<a
									class="course-card"
									data-category={c.category}
									href={url}
									target={ext ? '_blank' : undefined}
									rel={ext ? 'noopener noreferrer' : undefined}
								>
									<div class="thumb">
										{c.thumbnail ? (
											<img class="thumb-img" src={c.thumbnail} alt="" loading="lazy" />
										) : (
											<div class="thumb-glyph" aria-hidden="true">{c.glyph}</div>
										)}
										<div class="thumb-meta">
											<span class="thumb-platform">LinkedIn Learning</span>
										</div>
										{c.duration && <span class="thumb-duration">{c.duration}</span>}
									</div>
									<div class="course-card-body">
										<div class="course-card-tagline">
											<span class="course-cat">{c.category}</span>
											{c.duration && (
												<>
													<span class="course-dot" aria-hidden="true">&middot;</span>
													<span class="course-dur">{c.duration}</span>
												</>
											)}
										</div>
										<h3 class="course-card-title">{c.title}</h3>
										<p class="course-card-summary">{c.description}</p>
										<div class="course-card-foot">
											<span class="course-cta">{labels?.view_course || 'View course'} <span aria-hidden="true">&rarr;</span></span>
										</div>
									</div>
								</a>
							);
						})
					}
				</div>
				<div class="grid-empty" data-grid-empty hidden>
					<p>{labels?.empty_state || 'No courses in this category yet. New ones are added regularly.'}</p>
				</div>
			</div>
		</section>

		{/* ---------- Outcomes band (why these courses) ---------- */}
		{
			whyPoints.length > 0 && (
				<section class="outcomes-section outcomes-dark">
					<div class="container">
						<div class="outcomes-head">
							{why_section.eyebrow && (
								<div class="eyebrow eyebrow-on-dark">{why_section.eyebrow}</div>
							)}
							<h2 class="outcomes-heading">
								{why_section.heading}{' '}
								<span class="accent-italic-light">{why_section.heading_accent}</span>
							</h2>
							{why_section.lead && <p class="outcomes-lead">{why_section.lead}</p>}
						</div>
						<ul class="outcomes-grid">
							{whyPoints.map((p, i) => (
								<li class="outcome">
									<div class="outcome-glyph">{String(i + 1).padStart(2, '0')}</div>
									<div class="outcome-title">{p.title}</div>
									<div class="outcome-body">{p.description}</div>
								</li>
							))}
						</ul>
					</div>
				</section>
			)
		}

		{/* ---------- Proof strip ---------- */}
		{
			rating?.value && (
				<section class="proof-strip">
					<div class="container proof-strip-inner">
						<div class="proof-strip-stat">
							<div class="proof-strip-num">
								{rating.value}
								<span class="proof-strip-unit">{rating.scale}</span>
							</div>
							<div class="proof-strip-stat-label">
								{rating.value_label} across
								<br />
								<strong>{rating.students_value} learners</strong> on LinkedIn Learning
							</div>
						</div>
						{proofQuotes.length > 0 && (
							<div class="proof-strip-quotes">
								{proofQuotes.map((q) => (
									<figure class="proof-quote">
										<blockquote class="proof-quote-text">&ldquo;{q.quote}&rdquo;</blockquote>
										<figcaption class="proof-quote-who">
											<strong>{q.author}</strong>
											{q.roleOrCompany && (
												<span class="proof-quote-role"> &middot; {q.roleOrCompany}</span>
											)}
										</figcaption>
									</figure>
								))}
							</div>
						)}
					</div>
				</section>
			)
		}

		{/* ---------- Final CTA ---------- */}
		<section class="courses-final-cta">
			<div class="container narrow text-center">
				<span class="eyebrow eyebrow-on-brand">{final_cta.eyebrow}</span>
				<h2 class="final-cta-heading">
					{final_cta.heading}{' '}
					<span class="final-cta-italic">{final_cta.heading_accent}</span>
				</h2>
				<p class="final-cta-lead">{final_cta.body}</p>
				<div class="final-cta-ctas">
					<a
						class="btn yellow large"
						href={linkedinUrl}
						target="_blank"
						rel="noopener noreferrer"
					>
						{labels?.see_all_courses || 'See all courses on LinkedIn Learning'} <span aria-hidden="true">&#8599;</span>
					</a>
					<a class="btn outline-on-brand large" href={finalCtaUrl}>
						{final_cta.cta_label}
					</a>
				</div>
			</div>
		</section>
	</div>
</SpeakingLayout>

<script>
	// Lightweight category filter (vanilla DOM — no island, so it works
	// regardless of hydration quirks). Filters the grid by the data-category
	// on each card and keeps the count + label in sync.
	function setupCourseFilter() {
		const bar = document.querySelector<HTMLElement>('.filter-pills');
		const grid = document.querySelector<HTMLElement>('[data-course-grid]');
		const empty = document.querySelector<HTMLElement>('[data-grid-empty]');
		const countEl = document.querySelector<HTMLElement>('[data-grid-count]');
		const labelEl = document.querySelector<HTMLElement>('[data-grid-label]');
		if (!bar || !grid) return;

		const pills = Array.from(
			bar.querySelectorAll<HTMLButtonElement>('.filter-pill')
		);
		const cards = Array.from(
			grid.querySelectorAll<HTMLElement>('.course-card')
		);

		const apply = (filter: string) => {
			let shown = 0;
			for (const card of cards) {
				const match = filter === 'all' || card.dataset.category === filter;
				card.hidden = !match;
				if (match) shown++;
			}
			if (empty) empty.hidden = shown !== 0;
			if (countEl) countEl.textContent = String(shown);
			if (labelEl) {
				labelEl.textContent = '';
				if (filter === 'all') {
					labelEl.append('courses · all categories');
				} else {
					labelEl.append('courses in ');
					const em = document.createElement('em');
					em.textContent = filter;
					labelEl.append(em);
				}
			}
		};

		bar.addEventListener('click', (e) => {
			const pill = (e.target as HTMLElement).closest<HTMLButtonElement>('.filter-pill');
			if (!pill) return;
			for (const p of pills) {
				const active = p === pill;
				p.classList.toggle('is-active', active);
				p.setAttribute('aria-selected', active ? 'true' : 'false');
			}
			apply(pill.dataset.filter || 'all');
		});
	}

	setupCourseFilter();
</script>

<style>
	/* =================================================================
	   Courses page — ported from the Claude Design "Courses Page"
	   handoff bundle, wired to real CMS data. Resolves against the
	   editorial design tokens already loaded by SpeakingLayout.
	   ================================================================= */
	.courses-page { display: block; }

	/* container helpers — aligned to the site grid (nav/footer) width. */
	.container {
		width: 100%;
		max-width: var(--grid-max);
		margin: 0 auto;
		padding: 0 var(--grid-pad);
	}
	.container.narrow { max-width: var(--container-sm); }
	.text-center { text-align: center; }

	/* ---------- shared hero helpers ---------- */
	.eyebrow-hero {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		margin-bottom: 24px;
	}
	.eyebrow-hero::before {
		content: '';
		width: 28px;
		height: 1px;
		background: var(--accent);
	}
	.h-hero {
		font-family: var(--font-serif);
		font-size: clamp(36px, 4.4vw, 62px);
		font-weight: 500;
		line-height: 1.05;
		letter-spacing: -0.025em;
		color: var(--ink-900);
		margin: 0 0 28px;
		text-wrap: balance;
	}
	.h-hero .accent-italic { color: var(--accent); font-style: italic; }
	.hero-lead {
		font-family: var(--font-serif);
		font-size: clamp(18px, 1.6vw, 22px);
		line-height: 1.55;
		color: var(--ink-700);
		margin: 0 0 36px;
		max-width: 600px;
		text-wrap: pretty;
	}
	.hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 48px; }
	.hero-stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
		padding-top: 28px;
		border-top: 1px solid var(--border-soft);
		max-width: 560px;
	}
	.hero-stat-num {
		font-family: var(--font-serif);
		font-size: clamp(28px, 3vw, 44px);
		font-weight: 500;
		color: var(--accent);
		line-height: 1;
		letter-spacing: -0.02em;
	}
	.hero-stat-unit { font-size: 0.6em; opacity: .55; }
	.hero-stat-label {
		font-family: var(--font-sans);
		font-size: 12px;
		color: var(--fg-muted);
		margin-top: 8px;
		letter-spacing: .01em;
		line-height: 1.35;
	}

	/* ---------- hero editorial ---------- */
	.courses-hero { padding: clamp(56px, 8vw, 96px) 0 clamp(64px, 8vw, 112px); }
	.hero-editorial-grid {
		display: grid;
		grid-template-columns: 1.25fr 1fr;
		gap: clamp(40px, 6vw, 80px);
		align-items: center;
	}
	.hero-editorial-grid .hero-text { max-width: 640px; }
	.hero-side { display: flex; flex-direction: column; gap: 32px; align-items: stretch; }
	.hero-photo-frame {
		position: relative;
		border-radius: 28px;
		overflow: hidden;
		background: var(--brand-blue-100);
		aspect-ratio: 4/5;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		box-shadow: var(--shadow-lg);
	}
	.hero-photo-bg {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(120% 80% at 35% 25%, #FFE7C7 0%, transparent 55%),
			radial-gradient(80% 80% at 70% 70%, #C9D6FF 0%, transparent 60%),
			linear-gradient(135deg, var(--brand-blue-100) 0%, var(--brand-blue-300) 100%);
	}
	.hero-photo-img {
		position: relative;
		z-index: 1;
		width: 96%;
		height: 110%;
		object-fit: contain;
		object-position: center bottom;
		filter: drop-shadow(0 22px 30px rgba(15, 30, 75, 0.18));
	}
	.hero-credentials { display: flex; flex-direction: column; gap: 10px; }
	.cred-pill {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		background: #fff;
		border: 1px solid var(--border-soft);
		border-radius: 999px;
		padding: 10px 18px;
		font-family: var(--font-sans);
		font-size: 13px;
		font-weight: 500;
		color: var(--ink-900);
		box-shadow: var(--shadow-xs);
	}
	.cred-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--success);
		box-shadow: 0 0 0 3px rgba(46, 139, 87, 0.18);
		flex-shrink: 0;
	}
	.cred-star { color: var(--brand-yellow-500); font-size: 15px; }

	/* ---------- featured course ---------- */
	.featured-section { padding: clamp(40px, 5vw, 72px) 0 clamp(40px, 5vw, 80px); }
	.featured-wide {
		position: relative;
		display: grid;
		grid-template-columns: 1.05fr 1fr;
		background: #fff;
		border-radius: 28px;
		border: 1px solid var(--border-soft);
		overflow: hidden;
		box-shadow: var(--shadow-md);
	}
	.featured-wide-text {
		padding: clamp(36px, 4vw, 64px);
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
	.featured-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: var(--accent);
		margin-bottom: 18px;
	}
	.featured-eyebrow-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--brand-yellow-500);
		box-shadow: 0 0 0 4px var(--brand-yellow-100);
	}
	.featured-title {
		font-family: var(--font-serif);
		font-size: clamp(32px, 3.5vw, 52px);
		font-weight: 500;
		line-height: 1.05;
		letter-spacing: -0.02em;
		color: var(--ink-900);
		margin: 0 0 20px;
		text-wrap: balance;
	}
	.featured-summary {
		font-family: var(--font-serif);
		font-size: clamp(17px, 1.4vw, 20px);
		line-height: 1.55;
		color: var(--ink-700);
		margin: 0 0 24px;
	}
	.featured-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		list-style: none;
		padding: 0;
		margin: 0 0 28px;
	}
	.featured-tag {
		font-family: var(--font-sans);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: .04em;
		padding: 6px 14px;
		background: var(--brand-blue-50);
		color: var(--brand-blue-900);
		border-radius: 999px;
		border: 1px solid var(--brand-blue-100);
	}
	.featured-meta {
