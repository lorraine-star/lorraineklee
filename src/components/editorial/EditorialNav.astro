---
import { isNavChildActive, isNavItemActive, mainNavItems } from '../../lib/nav';
import { reader } from '../../lib/keystatic';

interface Props {
  activeId?: string;
  logoSrc?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  activeId = 'home',
  logoSrc = '/images/editorial/logo-primary.png',
  ctaHref,
  ctaLabel,
} = Astro.props;

const currentPath = Astro.url.pathname;

// Nav is editable via the `siteSettings` singleton (CLI-159). Fall back to the
// hardcoded mainNavItems (and the Contact CTA defaults) when the CMS entry is
// missing or empty, so the nav renders identically until edited. Each item's
// `id` is the stable key the per-page `activeId` matches for highlighting.
const site = await reader.singletons.siteSettings.read();
const navItems = site?.nav?.items?.length
  ? site.nav.items.map((item) => ({
      id: item.id,
      label: item.label,
      href: item.href,
      children: item.children?.length
        ? item.children.map((child) => ({ label: child.label, href: child.href }))
        : undefined,
    }))
  : mainNavItems;
const resolvedCtaHref = ctaHref ?? site?.nav?.cta_href ?? '/contact';
const resolvedCtaLabel = ctaLabel ?? site?.nav?.cta_label ?? 'Contact';
---

<nav class="nav">
  <div class="nav-inner">
    <a class="nav-logo" href="/" aria-label="Lorraine Lee, home">
      <img src={logoSrc} alt="Lorraine Lee" />
    </a>
    <div class="nav-links" id="site-nav-menu" data-nav-menu>
      {
        /* Contact is surfaced as the primary CTA button below, so omit the
           duplicate inline link here. */
        navItems
          .filter((item) => item.id !== 'contact')
          .map((item) => {
          const active =
            isNavItemActive(item, activeId) ||
            !!item.children?.some((child) => isNavChildActive(child, currentPath));
          return item.children?.length ? (
            <div class:list={['nav-item', 'nav-menu-item', { active }]} data-nav-menu-item>
              {/* CLI-130: the parent label is a real link to its own page,
                  so clicking it navigates directly. The chevron is a
                  separate small button so mobile users can still expand
                  the submenu without leaving the page. Desktop continues
                  to open the dropdown on hover/focus. */}
              <div class="nav-summary">
                <a
                  class:list={['nav-link', 'nav-summary-link', { active }]}
                  href={item.href}
                  aria-current={active ? 'page' : undefined}
                >
                  {item.label}
                </a>
                <button
                  class="nav-submenu-toggle"
                  type="button"
                  aria-haspopup="menu"
                  aria-expanded="false"
                  aria-label={`Toggle ${item.label} menu`}
                  data-nav-submenu-toggle
                >
                  <span class="nav-chevron" aria-hidden="true">&#9662;</span>
                </button>
              </div>
              <div class="nav-dropdown" role="menu">
                {item.children.map((child) => {
                  const childActive = isNavChildActive(child, currentPath);
                  return (
                    <a
                      class:list={['nav-dropdown-link', { active: childActive }]}
                      href={child.href}
                      role="menuitem"
                      aria-current={childActive ? 'page' : undefined}
                    >
                      {child.label}
                    </a>
                  );
                })}
              </div>
            </div>
          ) : (
            <a
              class:list={['nav-link', { active }]}
              href={item.href}
              aria-current={active ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </div>
    <button
      class="nav-menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-nav-menu"
      data-nav-menu-toggle
    >
      <span class="sr-only">Toggle navigation</span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
    <a
      class="btn primary"
      href={resolvedCtaHref}
      aria-current={activeId === 'contact' ? 'page' : undefined}
    >
      {resolvedCtaLabel}
    </a>
  </div>
</nav>

<script>
  document.querySelectorAll<HTMLElement>('.nav').forEach((nav) => {
    const toggle = nav.querySelector<HTMLButtonElement>('[data-nav-menu-toggle]');
    const menu = nav.querySelector<HTMLElement>('[data-nav-menu]');
    if (!toggle || !menu) return;
    const desktopQuery = window.matchMedia('(min-width: 901px)');
    const menuItems = Array.from(
      nav.querySelectorAll<HTMLElement>('[data-nav-menu-item]')
    );

    function setItemOpen(item: HTMLElement, open: boolean) {
      item.classList.toggle('is-open', open);
      item
        .querySelector<HTMLButtonElement>('[data-nav-submenu-toggle]')
        ?.setAttribute('aria-expanded', String(open));
    }

    function closeSubmenus(except?: HTMLElement) {
      menuItems.forEach((item) => {
        if (item !== except) setItemOpen(item, false);
      });
    }

    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('nav-open', !expanded);
    });

    menuItems.forEach((item) => {
      const submenuToggle = item.querySelector<HTMLButtonElement>(
        '[data-nav-submenu-toggle]'
      );

      item.addEventListener('mouseenter', () => {
        if (!desktopQuery.matches) return;
        closeSubmenus(item);
        setItemOpen(item, true);
      });

      item.addEventListener('mouseleave', () => {
        if (!desktopQuery.matches) return;
        setItemOpen(item, false);
      });

      item.addEventListener('focusin', () => {
        if (!desktopQuery.matches) return;
        closeSubmenus(item);
        setItemOpen(item, true);
      });

      item.addEventListener('focusout', (event) => {
        if (!desktopQuery.matches) return;
        const nextTarget = event.relatedTarget as Node | null;
        if (!nextTarget || !item.contains(nextTarget)) setItemOpen(item, false);
      });

      submenuToggle?.addEventListener('click', () => {
        if (desktopQuery.matches) return;
        const expanded = submenuToggle.getAttribute('aria-expanded') === 'true';
        closeSubmenus(item);
        setItemOpen(item, !expanded);
      });

      submenuToggle?.addEventListener('mousedown', (event) => {
        if (!desktopQuery.matches) return;
        event.preventDefault();
      });
    });

    nav.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      closeSubmenus();
      toggle.setAttribute('aria-expanded', 'false');
      nav.classList.remove('nav-open');
    });

    desktopQuery.addEventListener('change', () => {
      closeSubmenus();
      toggle.setAttribute('aria-expanded', 'false');
      nav.classList.remove('nav-open');
    });
  });
</script>
