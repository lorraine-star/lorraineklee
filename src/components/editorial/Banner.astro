---
// Dismissible yellow announcement strip. Sits above the nav.
---

<div class="banner" id="site-banner">
  <div class="banner-inner">
    <a class="banner-link" href="/contact">
      <strong>Free 5-day course:</strong>
      <span>Invisible to Influential</span>
      <span class="arrow" aria-hidden="true">&rarr;</span>
    </a>
    <button class="banner-dismiss" type="button" aria-label="Dismiss announcement" data-banner-dismiss>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
</div>
