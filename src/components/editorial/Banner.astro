---
// Dismissible yellow announcement strip. Sits above the nav.
//
// Content is editable via the `siteSettings` singleton (CLI-159). Set
// banner.enabled to false to hide it sitewide. Fields fall back to the previous
// hardcoded copy so the strip renders identically until edited.
import { reader } from '../../lib/keystatic';

const site = await reader.singletons.siteSettings.read();
const banner = site?.banner;

const enabled = banner?.enabled ?? true;
const textStrong = banner?.text_strong || 'Free 5-day course:';
const text = banner?.text || 'Invisible to Influential';
const href = banner?.href || '/from-invisible-to-influential';
---

{
  enabled && (
    <div class="banner" id="site-banner">
      <div class="banner-inner">
        <a class="banner-link" href={href}>
          <strong>{textStrong}</strong>
          <span>{text}</span>
          <span class="arrow" aria-hidden="true">&rarr;</span>
        </a>
        <button
          class="banner-dismiss"
          type="button"
          aria-label="Dismiss announcement"
          data-banner-dismiss
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
    </div>
  )
}
