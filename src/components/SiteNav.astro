---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/speaking', label: 'Speaking' },
  { href: '/learn', label: 'Learn' },
  { href: '/book', label: 'Book' },
  { href: '/articles', label: 'Articles' },
  { href: '/contact', label: 'Contact' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(`${href}/`);
---

<nav class="border-b border-neutral-200">
  <div
    class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-x-8 gap-y-3 px-6 py-4"
  >
    <a href="/" class="font-semibold tracking-tight text-neutral-900">
      Lorraine K. Lee
    </a>
    <ul class="flex flex-wrap gap-x-5 gap-y-1 text-sm">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
              class:list={[
                'transition-colors hover:text-neutral-900',
                isActive(link.href)
                  ? 'font-medium text-neutral-900'
                  : 'text-neutral-500',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>
