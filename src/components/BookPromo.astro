---
/**
 * Global book promo section.
 *
 * Canonical markup for the shared "The Book" promo. Edit this component when
 * the section needs to change anywhere it appears.
 *
 * Styling depends on the .book-promo rules in src/styles/v1/home.css.
 */
---

<section class="book-promo v3" data-global-section="book-promo">
  <div class="grid12">
    <div class="book-cover-col">
      <div class="book-cover-stack">
        <img
          class="book-cover"
          src="/images/v1/book-with-seals.png"
          alt="Unforgettable Presence by Lorraine K. Lee, book cover"
        />
      </div>
    </div>
    <div class="book-copy-col">
      <span class="eyebrow book-eyebrow">The Book</span>
      <h2 class="book-bigtitle"><em>Unforgettable Presence&reg;</em></h2>
      <p class="book-tagline">Get seen. Gain influence. Catapult your career.</p>
      <p class="book-body">
        The operator's manual for getting credit for your work. Used in
        leadership programs at Zoom, LinkedIn, and Salesforce. Five parts,
        fifty-two short chapters, no fluff.
      </p>
      <blockquote class="book-blockquote">
        <p>
          "The clearest, most actionable book on executive presence I've read
          in a decade."
        </p>
        <footer>VP, People &middot; Fortune 100 Tech</footer>
      </blockquote>
      <div class="book-cta-row">
        <a class="btn primary large" href="/book">
          Get your copy <span aria-hidden="true">&#8599;</span>
        </a>
      </div>
    </div>
  </div>
</section>
