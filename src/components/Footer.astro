---
// Canonical shared site footer (data-global-section="site-footer").
//
// Content is editable via the `siteSettings` singleton (CLI-159); see
// keystatic.config.ts and src/content/site-settings/index.yaml. Every field
// falls back to its previous hardcoded value, so the footer renders identically
// when the CMS entry is missing or a field is left blank.
//
// Styling note: this component is intentionally CSS-agnostic. It relies on the
// footer classes (footer, footer-wave, footer-grid, footer-brand, footer-tag,
// footer-socials, social-btn, footer-touch, footer-explore, footer-base,
// footer-base-links) being defined in the per-design-system global stylesheet
// loaded by the page: src/styles/v1/home.css for the homepage (HomeLayout) and
// src/styles/editorial/templates.css for editorial pages (SpeakingLayout). Do
// NOT add a scoped <style> block here; scoped styles would not match those
// global selectors and would break the footer.
import { reader } from '../lib/keystatic';
import { socialLinks, iconFor } from '../lib/social';
import { safeUrl } from '../lib/url';

interface Props {
  logoSrc?: string;
}

const { logoSrc = '/images/editorial/logo-primary.png' } = Astro.props;
const year = new Date().getFullYear();

const site = await reader.singletons.siteSettings.read();
const f = site?.footer;

const taglineBefore = f?.tagline_before || 'Helping leaders build an ';
const taglineEmphasis = f?.tagline_emphasis || 'unforgettable';
const taglineAfter = f?.tagline_after || ' presence.';

const socials =
  f?.socials && f.socials.length
    ? f.socials.map((s) => ({
        platform: s.platform,
        label: s.label || s.platform,
        url: s.url ?? '',
      }))
    : socialLinks.map((s) => ({
        platform: s.platform,
        label: s.ariaLabel,
        url: s.url,
      }));

const contactHeading = f?.contact_heading || 'Get in touch';
const contactBlurb =
  f?.contact_blurb || 'Speaking and coaching inquiries use the contact form.';
const contactLinks =
  f?.contact_links && f.contact_links.length
    ? f.contact_links
    : [
        { label: 'Contact Lorraine', href: '/contact' },
        {
          label: 'press@lorraineklee.com',
          href: 'mailto:press@lorraineklee.com',
        },
        {
          label: 'meagan@lorraineklee.com',
          href: 'mailto:meagan@lorraineklee.com',
        },
      ];

const exploreHeading = f?.explore_heading || 'Explore';
const exploreLinks =
  f?.explore_links && f.explore_links.length
    ? f.explore_links
    : [
        { label: 'About', href: '/about' },
        { label: 'Speaking', href: '/speaking' },
        { label: 'Learn', href: '/learn' },
        { label: 'The Book', href: '/book' },
        { label: 'Contact', href: '/contact' },
      ];

const legalEntity =
  f?.legal_entity || 'Lorraine Lee · RISE Learning Solutions Corp.';
const legalLinks =
  f?.legal_links && f.legal_links.length
    ? f.legal_links
    : [
        { label: 'Terms and Conditions', href: '/terms-privacy-legal/' },
        { label: 'Privacy Policy', href: '/privacy-policy/' },
        { label: 'Contact', href: '/contact' },
      ];
---

<div class="footer-wave-wrap">
  <svg class="footer-wave" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
    <path
      fill="var(--paper-deep)"
      d="M0,60 C240,120 480,10 720,50 C960,90 1200,120 1440,60 L1440,120 L0,120 Z"
    ></path>
  </svg>
</div>

<footer class="footer" data-global-section="site-footer">
  <div class="grid12 footer-grid">
    <div class="footer-brand">
      <img src={logoSrc} alt="Lorraine Lee" />
      <p class="footer-tag">
        {taglineBefore}<em>{taglineEmphasis}</em>{taglineAfter}
      </p>
      <div class="footer-socials">
        {
          socials.map((s) => (
            <a
              class="social-btn"
              href={safeUrl(s.url)}
              aria-label={s.label}
              target="_blank"
              rel="noopener noreferrer"
              set:html={iconFor(s.platform)}
            />
          ))
        }
      </div>
    </div>
    <div class="footer-touch">
      <h4>{contactHeading}</h4>
      <p>{contactBlurb}</p>
      {
        contactLinks.map((l) => (
          <a class="footer-email" href={l.href}>{l.label}</a>
        ))
      }
    </div>
    <div class="footer-explore">
      <h4>{exploreHeading}</h4>
      <ul>
        {exploreLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>
  </div>
  <div class="grid12">
    <div class="footer-base" style="grid-column: 1 / -1;">
      <div>&copy; {year} {legalEntity}</div>
      <div class="footer-base-links">
        {legalLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
    </div>
  </div>
</footer>
