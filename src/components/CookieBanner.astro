---
// Native cookie-consent banner — no third-party tool (CLI-52).
//
// The visitor's choice is stored in localStorage under "cookie-consent" as
// either "accepted" or "declined". The banner shows only when no choice has
// been stored yet, so a returning visitor never sees it again.
//
// Analytics integrations (Google Analytics — CLI-51, Microsoft Clarity —
// CLI-50) MUST gate on consent:
//   - on load, initialise only when localStorage["cookie-consent"] === "accepted"
//   - also listen for the "cookie-consent-change" window event
//     (event.detail.consent) so they can start the moment a visitor accepts,
//     without needing a page reload.
// Declining stores "declined" and dispatches the same event, so any
// consent-gated script stays off.
---

<div
	id="cookie-banner"
	class="fixed inset-x-0 bottom-0 z-50 border-t border-neutral-200 bg-white"
	role="region"
	aria-label="Cookie consent"
	hidden
>
	<div
		class="mx-auto flex max-w-5xl flex-col gap-4 px-6 py-4 sm:flex-row sm:items-center sm:justify-between"
	>
		<p class="text-sm leading-relaxed text-neutral-600">
			This site uses cookies to measure how visitors use it. You can accept
			analytics cookies or decline. Declining keeps only what the site needs
			to work.
		</p>
		<div class="flex shrink-0 gap-3">
			<button
				type="button"
				data-cookie-decline
				class="rounded-full border border-neutral-300 px-5 py-2 text-sm font-medium text-neutral-700 transition-colors hover:bg-neutral-100"
			>
				Decline
			</button>
			<button
				type="button"
				data-cookie-accept
				class="rounded-full bg-neutral-900 px-5 py-2 text-sm font-medium text-white transition-colors hover:bg-neutral-700"
			>
				Accept
			</button>
		</div>
	</div>
</div>

<script>
	const STORAGE_KEY = 'cookie-consent';
	const banner = document.getElementById('cookie-banner');

	if (banner) {
		let stored = null;
		try {
			stored = localStorage.getItem(STORAGE_KEY);
		} catch {
			// localStorage unavailable (private mode / disabled) — show the banner.
		}

		if (stored !== 'accepted' && stored !== 'declined') {
			banner.hidden = false;
		}

		const record = (consent) => {
			try {
				localStorage.setItem(STORAGE_KEY, consent);
			} catch {
				// Can't persist — the choice still applies for this page view.
			}
			banner.hidden = true;
			window.dispatchEvent(
				new CustomEvent('cookie-consent-change', {
					detail: { consent },
				})
			);
		};

		banner
			.querySelector('[data-cookie-accept]')
			?.addEventListener('click', () => record('accepted'));
		banner
			.querySelector('[data-cookie-decline]')
			?.addEventListener('click', () => record('declined'));
	}
</script>
