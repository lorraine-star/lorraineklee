---
/**
 * Global scroll-to-top button.
 *
 * Rendered once per page by every layout (the same way CookieBanner is). Stays
 * hidden until the visitor scrolls past a threshold, then fades in; clicking
 * returns to the top (smooth, or instant under prefers-reduced-motion).
 * Self-contained styles use the design tokens with literal fallbacks so it
 * matches on every layout, including the Tailwind default one.
 */
---

<button
	type="button"
	id="scroll-to-top"
	class="scroll-to-top"
	aria-label="Scroll back to top"
>
	<svg
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2.2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<path d="M12 19V5"></path>
		<path d="M5 12l7-7 7 7"></path>
	</svg>
</button>

<style>
	.scroll-to-top {
		position: fixed;
		right: clamp(16px, 4vw, 28px);
		bottom: clamp(16px, 4vw, 28px);
		z-index: 55;
		width: 48px;
		height: 48px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		border: 1px solid var(--border-soft, #eceef3);
		background: var(--white, #fff);
		color: var(--ink-900, #0e1530);
		box-shadow: 0 14px 32px -18px rgba(14, 21, 48, 0.55);
		cursor: pointer;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transform: translateY(8px);
		transition:
			opacity 220ms ease,
			transform 220ms ease,
			visibility 0s linear 220ms,
			background-color 180ms ease,
			color 180ms ease;
		-webkit-tap-highlight-color: transparent;
	}

	.scroll-to-top.is-visible {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transform: translateY(0);
		transition:
			opacity 220ms ease,
			transform 220ms ease,
			visibility 0s,
			background-color 180ms ease,
			color 180ms ease;
	}

	.scroll-to-top:hover {
		background: var(--ink-900, #0e1530);
		color: var(--paper, #fbf8f2);
		transform: translateY(-2px);
	}

	.scroll-to-top:focus-visible {
		outline: 2px solid var(--accent, #1a4dff);
		outline-offset: 3px;
	}

	.scroll-to-top svg {
		width: 20px;
		height: 20px;
	}

	@media (prefers-reduced-motion: reduce) {
		.scroll-to-top,
		.scroll-to-top.is-visible {
			transform: none;
			transition:
				opacity 120ms linear,
				visibility 0s;
		}
	}
</style>

<script>
	const btn = document.getElementById('scroll-to-top');

	if (btn) {
		const THRESHOLD = 600; // px scrolled before the button appears
		let ticking = false;

		const update = () => {
			ticking = false;
			const scrolled = window.scrollY || document.documentElement.scrollTop || 0;
			btn.classList.toggle('is-visible', scrolled > THRESHOLD);
		};

		const onScroll = () => {
			if (!ticking) {
				ticking = true;
				requestAnimationFrame(update);
			}
		};

		window.addEventListener('scroll', onScroll, { passive: true });
		window.addEventListener('resize', onScroll, { passive: true });
		update();

		const prefersReduced = window.matchMedia(
			'(prefers-reduced-motion: reduce)'
		).matches;

		btn.addEventListener('click', () => {
			window.scrollTo({ top: 0, behavior: prefersReduced ? 'auto' : 'smooth' });
		});
	}
</script>
