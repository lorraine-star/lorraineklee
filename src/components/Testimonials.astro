---
/**
 * Global "What clients say" testimonials section.
 *
 * Canonical markup for the testimonials carousel. Self-contained for data:
 * by default it reads from the shared testimonials collection (CLI-118),
 * filtered to `showOnHomepage`, so a page can drop in <Testimonials /> with
 * no props. Heading copy can be overridden per page, and a caller may pass
 * its own `testimonials` array (the book page does this for endorsement
 * logos that don't live in the shared collection).
 *
 * Styling: this section depends on the shared layout primitives (.grid12,
 * .eyebrow) and the .testimonials / .t-* rules in src/styles/v1/home.css.
 * The home page loads that stylesheet via HomeLayout. Any other page that
 * uses this component must also load src/styles/v1/home.css.
 *
 * This is a GLOBAL section — coordinate edits via Linear so parallel
 * worktrees don't drift.
 */
import HomeTestimonialsCarousel from './HomeTestimonialsCarousel';
import { getTestimonials, toCarouselCard } from '../lib/testimonials';
import './home-testimonials-carousel.css';

type Testimonial = {
  quote: string;
  name: string;
  role: string;
  photo?: string;
  photoAlt?: string;
  initials: string;
  /** Optional company / book-cover logos (used by the book page endorsements). */
  logos?: { image: string; alt: string }[];
};

interface Props {
  eyebrow?: string;
  /** Heading markup; may contain inline HTML such as <em>. */
  titleHtml?: string;
  lead?: string;
  /** Override the testimonials shown; defaults to the shared `showOnHomepage` set. */
  testimonials?: Testimonial[];
}

const {
  eyebrow = 'What clients say',
  titleHtml = 'Companies bring her back <em>for more.</em>',
  lead = "From Fortune 500 leadership programs to high-potential cohorts at fast-growth tech companies, Lorraine's frameworks travel.",
  testimonials: testimonialsProp,
} = Astro.props;

let testimonials = testimonialsProp;
if (!testimonials) {
  // TEMPORARY (CLI-120): the homepage now shows the curated `showOnHomepage`
  // picks from the shared collection instead of the old hardcoded 16. This
  // selection is provisional pending review — see CLI-120 for how to adjust
  // the picks (toggle `showOnHomepage`) or fully revert.
  const shared = await getTestimonials({ placement: 'homepage' });
  testimonials = shared.map(toCarouselCard);
}
---

<section class="testimonials" data-global-section="testimonials">
  <div class="grid12">
    <div class="testimonials-head">
      <span class="eyebrow">{eyebrow}</span>
      <h2 class="testimonials-title" set:html={titleHtml}></h2>
      {lead && <p class="lead">{lead}</p>}
    </div>
    <HomeTestimonialsCarousel testimonials={testimonials} client:load />
  </div>
</section>
